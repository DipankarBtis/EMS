					+ "AND B.PLANT_SEQ=C.PLANT_SEQ AND B.CONTRACT_TYPE=C.CONTRACT_TYPE " 
					+ "AND B.GAS_DT=C.GAS_DT AND B.CARGO_NO=A.CARGO_NO) ";

			String buyerNomCount = "SELECT COUNT(*) " 
