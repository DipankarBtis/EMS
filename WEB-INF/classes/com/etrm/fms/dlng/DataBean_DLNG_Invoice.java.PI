			String queryString1="SELECT CONT_REF_NO,TO_CHAR(DDA_DT,'DD-MON-YY'),TRADE_REF_NO,TO_CHAR(SIGNING_DT,'DD-MON-YY'),AGMT_BASE,DCQ,MDCQ_PERCENTAGE  "
