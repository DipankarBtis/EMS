			String tcs_tds="";
			String tcsStructCd="";
			String tcsStructDt="";
			String tdsStructCd="";
			String tdsStructDt="";
			String tcs_amt="";
			String tds_amt="";
			String tax_amt="";
			String invoiceAmt="";
			
			String fms_MessageId="";
			
			String plant_seq="";
		    String plantAddress="";
		    String plantCity="";
		    String plantState="";
		    String plantPin="";
		    String plantNm="";
		    
		    String cash_flow="";
		    
		    String tcs_factor="";
		    String tds_factor="";
		    
