			VPDF_COL1.add(srno);
			VPDF_COL2.add(invAmtLbl);
			VPDF_COL3.add("");
			VPDF_COL4.add("INR");
			VPDF_COL5.add("");
			VPDF_COL6.add("");
			VPDF_COL7.add(invoice_amt.equals("")?"":nf.format(Math.abs(Double.parseDouble(invoice_amt))));
			
			if(applicable_abbr.equals("TCS"))
			{
