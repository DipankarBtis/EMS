					if(AllMailPdf.equals(""))
					{
						AllMailPdf=temp;
					}
					else
					{
						AllMailPdf+=","+temp;
					}
					
				}
				rset6.close();
				stmt6.close();
				
				VPDF_SIGNED_FLAG.add("All");
				VSIGN_PDF_TYPE.add(AllMailPdf);
