				//inv_entered_on = rset.getString(38)==null?"":rset.getString(38);
				//inv_approved_on = rset.getString(39)==null?"":rset.getString(39);
				
				String fiscal_yr=rset.getString(40)==null?"":rset.getString(40);
				
