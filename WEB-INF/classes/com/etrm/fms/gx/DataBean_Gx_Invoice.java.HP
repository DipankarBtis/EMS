					tds_factor=rset.getString(37)==null?"":nf3.format(rset.getDouble(37));
					tds_struct_cd=rset.getString(38)==null?"":rset.getString(38);
					tds_struct_dt=rset.getString(39)==null?"":rset.getString(39);
