					+ "INVOICE_NO,INVOICE_DT,INVOICE_AMT,NET_PAYABLE_AMT,INV_STATUS,TO_CHAR(DUE_DT,'DD/MM/YYYY'),"
					+ "TO_CHAR(APPROVED_DT,'DD/MM/YYYY'),APPROVED_BY,APPROVED_FLAG,ADDR_FLAG,'FFLOW' "
