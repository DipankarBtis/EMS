					+ "AND D.EFF_DT <= TO_DATE(TO_CHAR(SYSDATE, 'DD/MM/YYYY'), 'DD/MM/YYYY'))   "
					//+ "AND  Z.COMPANY_CD = B.COMPANY_CD   "
