						 fms_ref=inv_invoice_no;
						 post_status="";
						 post_dt="";
						 post_time="";
						 idoc_no="";
						 idoc_status="";
						 status_msg = "";
						 doc_no="";
						 company_code = "";
						 fiscal_yr = "";
						 msg_status="";
