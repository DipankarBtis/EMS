					stmtement1.setString(2, counterparty_cd);
					stmtement1.setString(3, cont_no);
					stmtement1.setString(4, agmt_no);
					stmtement1.setString(5, contract_type);
					stmtement1.setString(6, date);
					resultset1=stmtement1.executeQuery();
					if(resultset1.next())
					{
						amt-=resultset1.getDouble(1);
					}
					resultset1.close();
					stmtement1.close();
					
					queryString1="SELECT SUM(HOLD_AMT) "
							+ "FROM FMS_DLNG_FFLOW_INV_MST A "
							+ "WHERE A.COMPANY_CD=? AND A.COUNTERPARTY_CD=? AND A.CONT_NO=? AND A.AGMT_NO=? AND A.CONTRACT_TYPE=? "
							+ "AND A.INVOICE_DT=TO_DATE(?,'DD/MM/YYYY') AND A.INVOICE_TYPE IN ('DR','CDR','T') ";
					stmtement1 = conn.prepareStatement(queryString1);
					stmtement1.setString(1, comp_cd);
					stmtement1.setString(2, counterparty_cd);
					stmtement1.setString(3, cont_no);
					stmtement1.setString(4, agmt_no);
					stmtement1.setString(5, contract_type);
					stmtement1.setString(6, date);
					resultset1=stmtement1.executeQuery();
					if(resultset1.next())
					{
						amt-=resultset1.getDouble(1);
					}
					resultset1.close();
					stmtement1.close();
					
					//HOLD RELEASE
					queryString1="SELECT SUM(A.HOLD_AMT) "
							+ "FROM FMS_DLNG_FFLOW_INV_MST A, FMS_CFORM_MST C, FMS_CFORM_DTL D "
							+ "WHERE A.COMPANY_CD=? AND A.COUNTERPARTY_CD=? AND A.CONT_NO=? AND A.AGMT_NO=? AND A.CONTRACT_TYPE=? "
							+ "AND C.CFORM_DT<=TO_DATE(?,'DD/MM/YYYY') "
							//+ "AND A.COMPANY_CD=B.COMPANY_CD AND A.INVOICE_SEQ=B.INVOICE_SEQ AND A.BU_STATE_TIN=B.BU_STATE_TIN AND A.FINANCIAL_YEAR=B.FINANCIAL_YEAR AND A.INVOICE_TYPE=B.INVOICE_TYPE "
							+ "AND C.COMPANY_CD=D.COMPANY_CD AND C.CFORM_CD=D.CFORM_CD AND D.INVOICE_NO=A.INVOICE_NO "
							+ "AND A.COMPANY_CD=C.COMPANY_CD ";
					stmtement1 = conn.prepareStatement(queryString1);
					stmtement1.setString(1, comp_cd);
					stmtement1.setString(2, counterparty_cd);
					stmtement1.setString(3, cont_no);
					stmtement1.setString(4, agmt_no);
					stmtement1.setString(5, contract_type);
					stmtement1.setString(6, date);
					resultset1=stmtement1.executeQuery();
					if(resultset1.next())
					{
						amt+=resultset1.getDouble(1);
					}
					resultset1.close();
					stmtement1.close();
					
					//FFLOW CREDIT NOTE, CCR
					queryString1="SELECT SUM(NVL(NET_PAYABLE_AMT,0)-NVL(TDS_GROSS_AMT,0)-NVL(TDS_TAX_AMT,0)) "
							+ "FROM FMS_DLNG_FFLOW_INV_MST A  "
							+ "WHERE COMPANY_CD=? AND COUNTERPARTY_CD=? "
							+ "AND CONT_NO=? AND AGMT_NO=? AND CONTRACT_TYPE=? "
							+ "AND INVOICE_DT=TO_DATE(?,'DD/MM/YYYY') "
							+ "AND INVOICE_TYPE IN ('CR','CCR') "
							+ "AND PDF_INV_DTL IS NOT NULL";
					stmtement1 = conn.prepareStatement(queryString1);
