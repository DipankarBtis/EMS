					resultset.close();
					stmtement.close();
					
					//HOLD RELEASE
					queryString2="SELECT SUM(A.HOLD_AMT) "
							+ "FROM FMS_INVOICE_MST A, FMS_CFORM_MST C, FMS_CFORM_DTL D "
