						{
							pay_received_amt+=resultset3.getDouble(1); //AS DISCUSSED WITH VIJAY, ADD(+) CREDIT NOTE AMT IN BALANCE AMT 20250802
							pay_received_count+=resultset3.getInt(2);
						}
						resultset3.close();
						stmtement3.close();
						
						queryString3="SELECT SUM(ABS(NVL(A.NET_PAYABLE_AMT,0) - NVL(A.TDS_GROSS_AMT,0) - NVL(A.TDS_TAX_AMT,0))),COUNT(*) "
								+ "FROM FMS_DLNG_INVOICE_MST A "
								+ "WHERE A.COMPANY_CD=? AND A.COUNTERPARTY_CD=? AND A.CONT_NO=? AND A.AGMT_NO=? AND A.CONTRACT_TYPE=? "
								+ "AND INVOICE_DT=TO_DATE(?,'DD/MM/YYYY') "
								+ "AND A.INV_FLAG IN ('CR') ";
						stmtement3 = conn.prepareStatement(queryString3);
						stmtement3.setString(1, comp_cd);
						stmtement3.setString(2, counterparty_cd);
						stmtement3.setString(3, cont_no);
						stmtement3.setString(4, agmt_no);
						stmtement3.setString(5, contract_type);
						stmtement3.setString(6, date);
						resultset3=stmtement3.executeQuery();
						if(resultset3.next())
						{
							pay_received_amt+=resultset3.getDouble(1); //AS DISCUSSED WITH VIJAY, ADD(+) CREDIT NOTE AMT IN BALANCE AMT 20250802
							pay_received_count+=resultset3.getInt(2);
						}
						resultset3.close();
						stmtement3.close();
						
						//TAKING other invoice amt
						queryString3="SELECT SUM(A.NET_PAYABLE_AMT),COUNT(*) "
								+ "FROM FMS_DLNG_FFLOW_INV_MST A "
								+ "WHERE A.COMPANY_CD=? AND A.COUNTERPARTY_CD=? AND A.CONT_NO=? AND A.AGMT_NO=? AND A.CONTRACT_TYPE=? "
								+ "AND A.INVOICE_DT=TO_DATE(?,'DD/MM/YYYY') "
								+ "AND A.INVOICE_TYPE IN ('DR','CDR','T','LP') ";
						stmtement3 = conn.prepareStatement(queryString3);
						stmtement3.setString(1, comp_cd);
						stmtement3.setString(2, counterparty_cd);
						stmtement3.setString(3, cont_no);
						stmtement3.setString(4, agmt_no);
						stmtement3.setString(5, contract_type);
						stmtement3.setString(6, date);
						resultset3=stmtement3.executeQuery();
						if(resultset3.next())
						{
							other_inv_amt+=resultset3.getDouble(1);
							other_inv_count=resultset3.getInt(2);	
						}
						resultset3.close();
						stmtement3.close();
						
						queryString3="SELECT SUM(A.NET_PAYABLE_AMT),COUNT(*) "
								+ "FROM FMS_DLNG_INVOICE_MST A "
								+ "WHERE A.COMPANY_CD=? AND A.COUNTERPARTY_CD=? AND A.CONT_NO=? AND A.AGMT_NO=? AND A.CONTRACT_TYPE=? "
								+ "AND A.INVOICE_DT=TO_DATE(?,'DD/MM/YYYY') "
								+ "AND A.INV_FLAG IN ('DR','LP') ";
						stmtement3 = conn.prepareStatement(queryString3);
						stmtement3.setString(1, comp_cd);
						stmtement3.setString(2, counterparty_cd);
						stmtement3.setString(3, cont_no);
						stmtement3.setString(4, agmt_no);
						stmtement3.setString(5, contract_type);
						stmtement3.setString(6, date);
						resultset3=stmtement3.executeQuery();
						if(resultset3.next())
						{
							other_inv_amt+=resultset3.getDouble(1);
							other_inv_count=resultset3.getInt(2);	
						}
						resultset3.close();
						stmtement3.close();
					}
					else
					{
						queryString3="SELECT SUM(NVL(B.PAY_RECV_AMT,0) - NVL(B.ADV_AMT,0)),SUM(B.ADV_AMT),COUNT(*) "
								+ "FROM FMS_INVOICE_MST A, FMS_INV_PAY_RECV_DTL B "
								+ "WHERE A.COMPANY_CD=? AND A.COUNTERPARTY_CD=? AND A.CONT_NO=? AND A.AGMT_NO=? AND A.CONTRACT_TYPE=? AND B.PAY_RECV_DT=TO_DATE(?,'DD/MM/YYYY') "
								+ "AND A.INV_FLAG NOT IN ('CR') "
								+ "AND A.COMPANY_CD=B.COMPANY_CD AND A.INVOICE_SEQ=B.INVOICE_SEQ AND A.BU_STATE_TIN=B.BU_STATE_TIN AND A.FINANCIAL_YEAR=B.FINANCIAL_YEAR ";
						stmtement3 = conn.prepareStatement(queryString3);
						stmtement3.setString(1, comp_cd);
						stmtement3.setString(2, counterparty_cd);
						stmtement3.setString(3, cont_no);
						stmtement3.setString(4, agmt_no);
						stmtement3.setString(5, contract_type);
						stmtement3.setString(6, date);
						resultset3=stmtement3.executeQuery();
						if(resultset3.next())
						{
							pay_received_amt+=resultset3.getDouble(1);
							adv_adjust_amt+=resultset3.getDouble(2);
							//pay_received_count=resultset3.getInt(3);
							
							if(resultset3.getDouble(1) > 0)
							{
								pay_received_count++;
							}
							
							if(resultset3.getDouble(2) > 0)
							{
								adv_adjust_count++;
							}
						}
						resultset3.close();
						stmtement3.close();
						
						//TAKING TDS, HOLD AMT
						queryString3="SELECT SUM(NVL(A.TDS_GROSS_AMT,0) + NVL(A.TDS_TAX_AMT,0)),SUM(A.HOLD_AMT),COUNT(*) "
								+ "FROM FMS_INVOICE_MST A "
								+ "WHERE A.COMPANY_CD=? AND A.COUNTERPARTY_CD=? AND A.CONT_NO=? AND A.AGMT_NO=? AND A.CONTRACT_TYPE=? "
								+ "AND A.INVOICE_DT=TO_DATE(?,'DD/MM/YYYY') AND A.INV_FLAG NOT IN ('CR','LP') ";
								//+ "AND A.PAY_RECV_DT IS NOT NULL AND PAY_RECV_AMT IS NOT NULL ";
								//+ "AND (SELECT MIN(B.PAY_RECV_DT) FROM FMS_INV_PAY_RECV_DTL B WHERE A.COMPANY_CD=B.COMPANY_CD AND A.INVOICE_SEQ=B.INVOICE_SEQ "
								//+ "AND A.BU_STATE_TIN=B.BU_STATE_TIN AND A.FINANCIAL_YEAR=B.FINANCIAL_YEAR)=TO_DATE(?,'DD/MM/YYYY')";
						stmtement3 = conn.prepareStatement(queryString3);
						stmtement3.setString(1, comp_cd);
						stmtement3.setString(2, counterparty_cd);
						stmtement3.setString(3, cont_no);
						stmtement3.setString(4, agmt_no);
						stmtement3.setString(5, contract_type);
						stmtement3.setString(6, date);
						resultset3=stmtement3.executeQuery();
						if(resultset3.next())
						{
							tds_amt+=resultset3.getDouble(1);
							hold_amt+=resultset3.getDouble(2);
							//tds_count=resultset3.getInt(3);
							
							if(resultset3.getDouble(1) > 0)
							{
								tds_count++;
							}
							if(resultset3.getDouble(2) > 0)
							{
								hold_count++;
							}
						}
						resultset3.close();
						stmtement3.close();
						
						//HOLD RELEASE
						queryString3="SELECT SUM(A.HOLD_AMT),COUNT(*) "
								+ "FROM FMS_INVOICE_MST A, FMS_CFORM_MST C, FMS_CFORM_DTL D "
								+ "WHERE A.COMPANY_CD=? AND A.COUNTERPARTY_CD=? AND A.CONT_NO=? AND A.AGMT_NO=? AND A.CONTRACT_TYPE=? "
								+ "AND C.CFORM_DT=TO_DATE(?,'DD/MM/YYYY') "
								//+ "AND A.COMPANY_CD=B.COMPANY_CD AND A.INVOICE_SEQ=B.INVOICE_SEQ AND A.BU_STATE_TIN=B.BU_STATE_TIN AND A.FINANCIAL_YEAR=B.FINANCIAL_YEAR "
								+ "AND C.COMPANY_CD=D.COMPANY_CD AND C.CFORM_CD=D.CFORM_CD AND D.INVOICE_NO=A.INVOICE_NO "
								+ "AND A.COMPANY_CD=C.COMPANY_CD ";
						stmtement3 = conn.prepareStatement(queryString3);
						stmtement3.setString(1, comp_cd);
						stmtement3.setString(2, counterparty_cd);
						stmtement3.setString(3, cont_no);
						stmtement3.setString(4, agmt_no);
						stmtement3.setString(5, contract_type);
						stmtement3.setString(6, date);
						resultset3=stmtement3.executeQuery();
						if(resultset3.next())
						{
							hold_amt-=resultset3.getDouble(1);
							if(resultset3.getDouble(1) > 0)
							{
								hold_count++;
							}
						}
						resultset3.close();
						stmtement3.close();
						
						//TAKING DEBIT NOTE, CDR, S, LP PAYAMENT RECEIVED
						queryString3="SELECT SUM(NVL(B.PAY_RECV_AMT,0) - NVL(B.ADV_AMT,0)),SUM(B.ADV_AMT),COUNT(*) "
								+ "FROM FMS_FFLOW_INV_MST A, FMS_FFLOW_INV_PAY_RECV_DTL B "
								+ "WHERE A.COMPANY_CD=? AND A.COUNTERPARTY_CD=? AND A.CONT_NO=? AND A.AGMT_NO=? AND A.CONTRACT_TYPE=? AND B.PAY_RECV_DT=TO_DATE(?,'DD/MM/YYYY') "
								+ "AND A.INVOICE_TYPE IN ('DR','CDR','LP','S') "
								+ "AND A.COMPANY_CD=B.COMPANY_CD AND A.INVOICE_SEQ=B.INVOICE_SEQ AND A.BU_STATE_TIN=B.BU_STATE_TIN AND A.FINANCIAL_YEAR=B.FINANCIAL_YEAR AND A.INVOICE_TYPE=B.INVOICE_TYPE ";
						stmtement3 = conn.prepareStatement(queryString3);
						stmtement3.setString(1, comp_cd);
						stmtement3.setString(2, counterparty_cd);
						stmtement3.setString(3, cont_no);
						stmtement3.setString(4, agmt_no);
						stmtement3.setString(5, contract_type);
						stmtement3.setString(6, date);
						resultset3=stmtement3.executeQuery();
						if(resultset3.next())
						{
							pay_received_amt+=resultset3.getDouble(1);
							adv_adjust_amt+=resultset3.getDouble(2);
							//pay_received_count=resultset3.getInt(3);
							
							if(resultset3.getDouble(1) > 0)
							{
								pay_received_count++;
							}
							if(resultset3.getDouble(2) > 0)
							{
								adv_adjust_count++;
							}	
						}
						resultset3.close();
						stmtement3.close();
						
						//TAKING TDS, HOLD AMT
						queryString3="SELECT SUM(NVL(A.TDS_GROSS_AMT,0) + NVL(A.TDS_TAX_AMT,0)),SUM(A.HOLD_AMT),COUNT(*) "
								+ "FROM FMS_FFLOW_INV_MST A "
								+ "WHERE A.COMPANY_CD=? AND A.COUNTERPARTY_CD=? AND A.CONT_NO=? AND A.AGMT_NO=? AND A.CONTRACT_TYPE=? "
								+ "AND A.INVOICE_DT=TO_DATE(?,'DD/MM/YYYY') "
								+ "AND A.INVOICE_TYPE IN ('DR','CDR','S') ";
								//+ "AND A.PAY_RECV_DT IS NOT NULL AND PAY_RECV_AMT IS NOT NULL ";
								//+ "AND (SELECT MIN(B.PAY_RECV_DT) FROM FMS_INV_PAY_RECV_DTL B WHERE A.COMPANY_CD=B.COMPANY_CD AND A.INVOICE_SEQ=B.INVOICE_SEQ "
								//+ "AND A.BU_STATE_TIN=B.BU_STATE_TIN AND A.FINANCIAL_YEAR=B.FINANCIAL_YEAR)=TO_DATE(?,'DD/MM/YYYY')";
						stmtement3 = conn.prepareStatement(queryString3);
						stmtement3.setString(1, comp_cd);
						stmtement3.setString(2, counterparty_cd);
						stmtement3.setString(3, cont_no);
						stmtement3.setString(4, agmt_no);
						stmtement3.setString(5, contract_type);
						stmtement3.setString(6, date);
						resultset3=stmtement3.executeQuery();
						if(resultset3.next())
						{
							tds_amt+=resultset3.getDouble(1);
							hold_amt+=resultset3.getDouble(2);
							//tds_count=resultset3.getInt(3);
							
							if(resultset3.getDouble(1) > 0)
							{
								tds_count++;
							}
							if(resultset3.getDouble(2) > 0)
							{
								hold_count++;
							}
						}
						resultset3.close();
						stmtement3.close();
						
						//HOLD RELEASE
						queryString3="SELECT SUM(A.HOLD_AMT),COUNT(*) "
								+ "FROM FMS_FFLOW_INV_MST A, FMS_CFORM_MST C, FMS_CFORM_DTL D "
								+ "WHERE A.COMPANY_CD=? AND A.COUNTERPARTY_CD=? AND A.CONT_NO=? AND A.AGMT_NO=? AND A.CONTRACT_TYPE=? "
								+ "AND C.CFORM_DT=TO_DATE(?,'DD/MM/YYYY') "
								//+ "AND A.COMPANY_CD=B.COMPANY_CD AND A.INVOICE_SEQ=B.INVOICE_SEQ AND A.BU_STATE_TIN=B.BU_STATE_TIN AND A.FINANCIAL_YEAR=B.FINANCIAL_YEAR AND A.INVOICE_TYPE=B.INVOICE_TYPE "
								+ "AND C.COMPANY_CD=D.COMPANY_CD AND C.CFORM_CD=D.CFORM_CD AND D.INVOICE_NO=A.INVOICE_NO "
								+ "AND A.COMPANY_CD=C.COMPANY_CD ";
						stmtement3 = conn.prepareStatement(queryString3);
						stmtement3.setString(1, comp_cd);
						stmtement3.setString(2, counterparty_cd);
						stmtement3.setString(3, cont_no);
						stmtement3.setString(4, agmt_no);
						stmtement3.setString(5, contract_type);
						stmtement3.setString(6, date);
						resultset3=stmtement3.executeQuery();
						if(resultset3.next())
						{
							hold_amt-=resultset3.getDouble(1);
							if(resultset3.getDouble(1) > 0)
							{
								hold_count++;
							}
						}
						resultset3.close();
						stmtement3.close();
						
						//TAKING CRDEIT NOTE, CCR
						queryString3="SELECT SUM(NVL(A.NET_PAYABLE_AMT,0) - NVL(A.TDS_GROSS_AMT,0) - NVL(A.TDS_TAX_AMT,0)),COUNT(*) "
								+ "FROM FMS_FFLOW_INV_MST A "
								+ "WHERE A.COMPANY_CD=? AND A.COUNTERPARTY_CD=? AND A.CONT_NO=? AND A.AGMT_NO=? AND A.CONTRACT_TYPE=? "
								+ "AND INVOICE_DT=TO_DATE(?,'DD/MM/YYYY') "
								+ "AND A.INVOICE_TYPE IN ('CR','CCR') ";
						stmtement3 = conn.prepareStatement(queryString3);
						stmtement3.setString(1, comp_cd);
						stmtement3.setString(2, counterparty_cd);
						stmtement3.setString(3, cont_no);
						stmtement3.setString(4, agmt_no);
						stmtement3.setString(5, contract_type);
						stmtement3.setString(6, date);
						resultset3=stmtement3.executeQuery();
						if(resultset3.next())
						{
							pay_received_amt+=resultset3.getDouble(1); //AS DISCUSSED WITH VIJAY, ADD(+) CREDIT NOTE AMT IN BALANCE AMT 20250802
							pay_received_count+=resultset3.getInt(2);
						}
						resultset3.close();
						stmtement3.close();
						
						queryString3="SELECT SUM(ABS(NVL(A.NET_PAYABLE_AMT,0) - NVL(A.TDS_GROSS_AMT,0) - NVL(A.TDS_TAX_AMT,0))),COUNT(*) "
								+ "FROM FMS_INVOICE_MST A "
								+ "WHERE A.COMPANY_CD=? AND A.COUNTERPARTY_CD=? AND A.CONT_NO=? AND A.AGMT_NO=? AND A.CONTRACT_TYPE=? "
								+ "AND INVOICE_DT=TO_DATE(?,'DD/MM/YYYY') "
								+ "AND A.INV_FLAG IN ('CR') ";
						stmtement3 = conn.prepareStatement(queryString3);
						stmtement3.setString(1, comp_cd);
						stmtement3.setString(2, counterparty_cd);
						stmtement3.setString(3, cont_no);
						stmtement3.setString(4, agmt_no);
						stmtement3.setString(5, contract_type);
						stmtement3.setString(6, date);
						resultset3=stmtement3.executeQuery();
						if(resultset3.next())
						{
							pay_received_amt+=resultset3.getDouble(1); //AS DISCUSSED WITH VIJAY, ADD(+) CREDIT NOTE AMT IN BALANCE AMT 20250802
							pay_received_count+=resultset3.getInt(2);
						}
						resultset3.close();
						stmtement3.close();
						
						//TAKING other invoice amt
						queryString3="SELECT SUM(A.NET_PAYABLE_AMT),COUNT(*) "
								+ "FROM FMS_FFLOW_INV_MST A "
								+ "WHERE A.COMPANY_CD=? AND A.COUNTERPARTY_CD=? AND A.CONT_NO=? AND A.AGMT_NO=? AND A.CONTRACT_TYPE=? "
								+ "AND A.INVOICE_DT=TO_DATE(?,'DD/MM/YYYY') "
								+ "AND A.INVOICE_TYPE IN ('DR','CDR','S','LP') ";
						stmtement3 = conn.prepareStatement(queryString3);
						stmtement3.setString(1, comp_cd);
						stmtement3.setString(2, counterparty_cd);
						stmtement3.setString(3, cont_no);
						stmtement3.setString(4, agmt_no);
						stmtement3.setString(5, contract_type);
						stmtement3.setString(6, date);
						resultset3=stmtement3.executeQuery();
						if(resultset3.next())
						{
							other_inv_amt+=resultset3.getDouble(1);
							other_inv_count=resultset3.getInt(2);	
						}
						resultset3.close();
						stmtement3.close();
						
						queryString3="SELECT SUM(A.NET_PAYABLE_AMT),COUNT(*) "
								+ "FROM FMS_INVOICE_MST A "
								+ "WHERE A.COMPANY_CD=? AND A.COUNTERPARTY_CD=? AND A.CONT_NO=? AND A.AGMT_NO=? AND A.CONTRACT_TYPE=? "
								+ "AND A.INVOICE_DT=TO_DATE(?,'DD/MM/YYYY') "
								+ "AND A.INV_FLAG IN ('DR','LP') ";
						stmtement3 = conn.prepareStatement(queryString3);
						stmtement3.setString(1, comp_cd);
						stmtement3.setString(2, counterparty_cd);
						stmtement3.setString(3, cont_no);
						stmtement3.setString(4, agmt_no);
						stmtement3.setString(5, contract_type);
						stmtement3.setString(6, date);
						resultset3=stmtement3.executeQuery();
						if(resultset3.next())
						{
							other_inv_amt+=resultset3.getDouble(1);
							other_inv_count=resultset3.getInt(2);	
						}
						resultset3.close();
						stmtement3.close();
					}
					
					double net_amt = total_gross_amt+tax_amt;
					cumulative_net_amt+=net_amt+other_inv_amt;
					
					//cumulative_advance_amt+=advance_amt;
					//cumulative_cash_deposit+=cash_deposit;
					double pay_total=tds_amt+adv_adjust_amt+pay_received_amt;
					cumulative_pay_received_amt+=pay_total;
					double adv_adj_total=adv_adjust_amt+hold_amt;
					cumulative_adv_adj_amt+=adv_adj_total;
					
				}
				
				double total_allowable_credit= LC_AMT + BG_AMT + cumulative_advance_amt + cumulative_cash_deposit + pcgValue + ExceedValue;
				double balance_amt=(total_allowable_credit-cumulative_net_amt-cumulative_adv_adj_amt)+cumulative_pay_received_amt;
				amt=balance_amt;
			}
		}
		catch(Exception e)
		{
			throw e;
		}
		return amt;
	}
	
	public Double getContExchangeRate(Connection conn, String comp_cd, String counterparty_cd, String agmt_no, String cont_no, String contract_type, String date) throws Exception
	{
		String function_nm="getContExchangeRate()";
		double exchangRate=0;
		try
		{
			if(conn!=null)
			{
				String exchng_rate_cd="";
				String exchang_criteria="";
				String exchng_rate_cal="";
				String fixed_exchng_val="";
				
				String queryString_temp="SELECT EXCHNG_RATE_CD,EXCHNG_CRITERIA,EXCHNG_RATE_CAL,"
						+ "EXCHG_VAL "
						+ "FROM FMS_SUPPLY_BILLING_DTL A "
						+ "WHERE COMPANY_CD=? AND COUNTERPARTY_CD=? "
						+ "AND AGMT_NO=? "//AND AGMT_REV='"+agmt_rev_no+"' "
						+ "AND CONT_NO=? "//AND CONT_REV='"+cont_rev_no+"' "
						+ "AND CONTRACT_TYPE=? "
						+ "AND EFF_DT=(SELECT MAX(B.EFF_DT) FROM FMS_SUPPLY_BILLING_DTL B WHERE A.COMPANY_CD=B.COMPANY_CD "
						+ "AND A.COUNTERPARTY_CD=B.COUNTERPARTY_CD AND A.AGMT_NO=B.AGMT_NO AND A.CONT_NO=B.CONT_NO "
						+ "AND A.CONTRACT_TYPE=B.CONTRACT_TYPE AND B.EFF_DT<=TO_DATE(?,'DD/MM/YYYY')) ";
				stmt_temp = conn.prepareStatement(queryString_temp);
				stmt_temp.setString(1, comp_cd);
				stmt_temp.setString(2, counterparty_cd);
				stmt_temp.setString(3, agmt_no);
				stmt_temp.setString(4, cont_no);
				stmt_temp.setString(5, contract_type);
				stmt_temp.setString(6, date);
				rset_temp=stmt_temp.executeQuery();
				if(rset_temp.next())
				{
					exchng_rate_cd = rset_temp.getString(1)==null?"":rset_temp.getString(1);
					exchang_criteria = rset_temp.getString(2)==null?"":rset_temp.getString(2);
					exchng_rate_cal = rset_temp.getString(3)==null?"":rset_temp.getString(3);
					
					fixed_exchng_val=nf2.format(rset_temp.getDouble(4));
				}
				else
				{	
					fixed_exchng_val=nf2.format(0);
				}
				rset_temp.close();
				stmt_temp.close();
				
				if(exchng_rate_cd.equals("0")) //FOR FIXED EXCHANGE RATE
				{
					exchangRate=Double.parseDouble(fixed_exchng_val);
				}
				else
				{
					String queryString_temp1="SELECT EXCHG_VAL "
							+ "FROM FMS_EXCHG_RATE_ENTRY A "
							+ "WHERE EXCHG_RATE_CD=? "
							+ "AND EFF_DT=(SELECT MAX(EFF_DT) FROM FMS_EXCHG_RATE_ENTRY B "
							+ "WHERE A.EXCHG_RATE_CD=B.EXCHG_RATE_CD AND B.EFF_DT <= TO_DATE(?,'DD/MM/YYYY'))";
					stmt_temp1 = conn.prepareStatement(queryString_temp1);
					stmt_temp1.setString(1, exchng_rate_cd);
					stmt_temp1.setString(2, date);
					rset_temp1=stmt_temp1.executeQuery();
					if(rset_temp1.next())
					{
						exchangRate=rset_temp1.getDouble(1);
					}
					rset_temp1.close();
					stmt_temp1.close();
				}
				
				if(Double.doubleToRawLongBits(exchangRate)==Double.doubleToRawLongBits(0)) //IF EXCHNG_RATE==0, DEFAULT 'Shell Treasury Rate' WILL BE CONSIDERED
				{
					String rate_nm="Shell Treasury Rate";
					
					String queryString_temp1="SELECT EXC_RATE_CD "
							+ "FROM FMS_EXCHG_RATE_MST "
							+ "WHERE UPPER(EXC_RATE_NM) = ?";
					stmt_temp1 = conn.prepareStatement(queryString_temp1);
					stmt_temp1.setString(1, rate_nm.toUpperCase());
					rset_temp1=stmt_temp1.executeQuery();
					if(rset_temp1.next())
					{
						exchng_rate_cd = rset_temp1.getString(1)==null?"":rset_temp1.getString(1);
					}
					rset_temp1.close();
					stmt_temp1.close();
					
					String queryString="SELECT EXCHG_VAL "
							+ "FROM FMS_EXCHG_RATE_ENTRY A "
							+ "WHERE EXCHG_RATE_CD=? "
							+ "AND EFF_DT =(SELECT MAX(B.EFF_DT) FROM FMS_EXCHG_RATE_ENTRY B "
							+ "WHERE A.EXCHG_RATE_CD=B.EXCHG_RATE_CD  "
							+ "AND B.EFF_DT <= TO_DATE(TO_CHAR(SYSDATE,'DD/MM/YYYY'),'DD/MM/YYYY')) AND FLAG=?";
					stmt_temp1 = conn.prepareStatement(queryString);
					stmt_temp1.setString(1, exchng_rate_cd);
					stmt_temp1.setString(2, "Y");
					rset_temp1=stmt_temp1.executeQuery();
					if(rset_temp1.next())
					{
						exchangRate = rset_temp1.getDouble(1);
					}
					rset_temp1.close();
					stmt_temp1.close();
				}
			}
		}
		catch(Exception e)
		{
			throw e;
		}
		
		return exchangRate;
	}
	
	public Double getConsumedAdvanceAmount(Connection conn,String comp_cd,String counterparty_cd, String agmt_no, String cont_no, String contract_type, String gx, String date)
	{
		String function_nm="getConsumedAdvanceAmount()";
		double amt=0;
		try
		{
			if(conn!=null)
			{
				if(contract_type.equals("Q") || contract_type.equals("O"))
				{
					String queryString_temp="SELECT SUM(B.AMOUNT) "
							+ "FROM FMS_INVOICE_MST A, FMS_INV_ADV_DTL B "
							+ "WHERE A.COMPANY_CD=? AND A.COUNTERPARTY_CD=? AND A.CONTRACT_TYPE=? AND A.AGMT_NO=? AND A.CONT_NO=? "
							+ "AND A.INVOICE_DT <= TO_DATE(?,'DD/MM/YYYY') AND PDF_INV_DTL IS NOT NULL "
							+ "AND A.COMPANY_CD=B.COMPANY_CD AND A.BU_STATE_TIN=B.BU_STATE_TIN AND A.FINANCIAL_YEAR=B.FINANCIAL_YEAR AND A.INVOICE_SEQ=B.INVOICE_SEQ ";
					stmt_temp = conn.prepareStatement(queryString_temp);
					stmt_temp.setString(1, comp_cd);
					stmt_temp.setString(2, counterparty_cd);
					stmt_temp.setString(3, contract_type);
					stmt_temp.setString(4, agmt_no);
					stmt_temp.setString(5, cont_no);
					stmt_temp.setString(6, date);
					rset_temp=stmt_temp.executeQuery();
					if(rset_temp.next())
					{
						amt+=rset_temp.getDouble(1);
					}
					rset_temp.close();
					stmt_temp.close();
				}
				else if(contract_type.equals("E") || contract_type.equals("F") || contract_type.equals("W"))
				{
					//DLNG INVOICE
					String queryString_temp ="SELECT SUM(B.ADV_AMT) "
							+ "FROM FMS_DLNG_INVOICE_MST A, FMS_DLNG_INV_PAY_RECV_DTL B "
							+ "WHERE A.COMPANY_CD=? AND A.COUNTERPARTY_CD=? AND A.CONT_NO=? AND A.AGMT_NO=? AND A.CONTRACT_TYPE=? "
							+ "AND B.PAY_RECV_DT<=TO_DATE(?,'DD/MM/YYYY') "
							+ "AND A.COMPANY_CD=B.COMPANY_CD AND A.INVOICE_SEQ=B.INVOICE_SEQ AND A.BU_STATE_TIN=B.BU_STATE_TIN AND A.FINANCIAL_YEAR=B.FINANCIAL_YEAR ";
