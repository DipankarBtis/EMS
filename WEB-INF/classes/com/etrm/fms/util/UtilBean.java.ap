		{
			if(inv_type.equals("S")){nm="Sales Invoice (S)";}
			else if(inv_type.equals("SI")){nm="Re-Gas Invoice (SI)";}
			else if(inv_type.equals("UG")){nm="SUG Invoice (UG)";}
			else if(inv_type.equals("ST")){nm="Storage Invoice (ST)";}
			else if(inv_type.equals("DI")){nm="Deficiency Invoice (DI)";}					
			else if(inv_type.equals("DTM")){nm="DLNG Transport Mgmt Service (DTM)";}										
			else if(inv_type.equals("TLU")){nm="DLNG Service Charge (TLU)";}										
			else if(inv_type.equals("TC")) {nm="Transmission Charges (TC)";}
			else if(inv_type.equals("IC")) {nm="Imbalance Charges (IC)";}
			else if(inv_type.equals("PC")) {nm="Parking Charges (PC)";}					
			else if(inv_type.equals("CH")) {nm="CH Agent Fee (CH)";}
			else if(inv_type.equals("SF")) {nm="Surveyor Fee (SF)";}
			else if(inv_type.equals("VA")) {nm="Vessel Agent Fee (VA)";}
			else if(inv_type.equals("TX")) {nm="Transaction Charges (TX)";}
			else if(inv_type.equals("RV")){nm="Receipt Voucher (RV)";}
			else if(inv_type.equals("CR")){nm="Credit Note (CR)";}
			else if(inv_type.equals("DR")){nm="Debit Note (DR)";}
			else if(inv_type.equals("CCR")){nm="Commercial Credit Note (CCR)";}
			else if(inv_type.equals("CDR")){nm="Commercial Debit Note (CDR)";}
			else if(inv_type.equals("LP")){nm="Late Payment (LP)";}
			else if(inv_type.equals("OR")){nm="Other (OR)";}
			else {nm =inv_type;} // MISSING DICTIONARY UPDATE
		}
		catch(Exception e)
		{
			throw e;
		}
		return nm;
	}

	
