	public String getEntityBankFormula(Connection conn, String comp_cd, String counterparty_cd, String entity_role, String category, String eff_dt) throws Exception
	{
		String function_nm="getEntityBankFormula()";
		String bank_formula="";
		try
		{
			if(conn!=null)
			{
				int selCnt=0;
				String queryString="SELECT * "
						+ "FROM ( SELECT * "
							+ "FROM ( SELECT COUNTERPARTY_CD, ENTITY, TO_CHAR(EFF_DT,'DD/MM/YYYY') AS EFF_DT, BANK_NAME, ACCOUNT_ID, IFSC_CODE, BRANCH_NAME, STATE_NM, 1 AS PRIORITY "
								+ "FROM FMS_ENTITY_BANK_MST A "
								+ "WHERE ENTITY = ? "
								+ "AND COUNTERPARTY_CD = ? "
								+ "AND COMPANY_CD = ? "
								+ "AND CATEGORY = ? "
								+ "AND EFF_DT = ( SELECT MAX(B.EFF_DT) "
								+ "FROM FMS_ENTITY_BANK_MST B "
								+ "WHERE A.COUNTERPARTY_CD = B.COUNTERPARTY_CD "
								+ "AND A.ENTITY = B.ENTITY "
								+ "AND A.COMPANY_CD = B.COMPANY_CD "
								+ "AND A.CATEGORY = B.CATEGORY "
								+ "AND B.EFF_DT <= TO_DATE(?,'DD/MM/YYYY') ) "
							+ "UNION ALL SELECT COUNTERPARTY_CD, ENTITY, TO_CHAR(EFF_DT,'DD/MM/YYYY') AS EFF_DT, BANK_NAME, ACCOUNT_ID, IFSC_CODE, BRANCH_NAME, STATE_NM, 2 AS PRIORITY "
								+ "FROM FMS_ENTITY_BANK_MST A "
								+ "WHERE ENTITY = ? "
								+ "AND COUNTERPARTY_CD = ? "
								+ "AND COMPANY_CD = ? "
								+ "AND CATEGORY = ? "
								+ "AND EFF_DT = ( SELECT MAX(B.EFF_DT) "
								+ "FROM FMS_ENTITY_BANK_MST B "
								+ "WHERE A.COUNTERPARTY_CD = B.COUNTERPARTY_CD "
								+ "AND A.ENTITY = B.ENTITY "
								+ "AND A.COMPANY_CD = B.COMPANY_CD "
								+ "AND A.CATEGORY = B.CATEGORY "
								+ "AND B.EFF_DT <= TO_DATE(?,'DD/MM/YYYY') ) ) "
							+ "ORDER BY PRIORITY ) "
						+ "WHERE ROWNUM = 1 ";
				stmt_temp1 = conn.prepareStatement(queryString);
				stmt_temp1.setString(++selCnt, entity_role); // preferred entity
				stmt_temp1.setString(++selCnt, counterparty_cd);
				stmt_temp1.setString(++selCnt, comp_cd);
				stmt_temp1.setString(++selCnt, category);
				stmt_temp1.setString(++selCnt, eff_dt);
				stmt_temp1.setString(++selCnt, "B");// fallback 'B'
				stmt_temp1.setString(++selCnt, comp_cd);
				stmt_temp1.setString(++selCnt, comp_cd);
				stmt_temp1.setString(++selCnt, category);
				stmt_temp1.setString(++selCnt, eff_dt);
				rset_temp1=stmt_temp1.executeQuery();
				if(rset_temp1.next())
				{
					String bank_eff_dt = rset_temp1.getString(3)==null?"":rset_temp1.getString(3);
					String bank_name=rset_temp1.getString(4)==null?"":rset_temp1.getString(4);
					String bank_account_no=rset_temp1.getString(5)==null?"":rset_temp1.getString(5);
					String ifsc_code=rset_temp1.getString(6)==null?"":rset_temp1.getString(6);
					String bank_branch=rset_temp1.getString(7)==null?"":rset_temp1.getString(7);
					String bank_state=rset_temp1.getString(8)==null?"":rset_temp1.getString(8);
					
					String codeType = "IFSC Code";
					
					if(category.equals("DERV"))
					{
						codeType = "Swift Code";
					}
					
					bank_formula=bank_name+", "+bank_branch+", "+bank_state+", A/C No : "+bank_account_no+", "+codeType+" : "+ifsc_code;
				}
				rset_temp1.close();
				stmt_temp1.close();
			}
		}
		catch(Exception e)
		{
			throw e;
		}
		return bank_formula;
	}
	
