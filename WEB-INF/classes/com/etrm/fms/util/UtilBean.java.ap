	public double getContractMigrationOffSetQty(Connection conn,String comp_cd,String counterparty_cd,String agmt_no,String cont_no,String contract_type,String buy_sell) throws Exception
	{
		String function_nm="getContractMigrationOffSetQty()";
		double qty=0;
		try
		{
			if(conn!=null)
			{
				String query="SELECT SUM(QTY_MMBTU) "
		  				+ "FROM FMS_OFFSET_ALLOCATION_DTL "
		  				+ "WHERE CONT_NO=? AND AGMT_NO=? "
						+ "AND COMPANY_CD=? AND COUNTERPARTY_CD=? "
						+ "AND CONTRACT_TYPE=? "
						+ "AND BUY_SELL = ? ";
				stmtement=conn.prepareStatement(query);
				stmtement.setString(1, cont_no);
				stmtement.setString(2, agmt_no);
				stmtement.setString(3, comp_cd);
				stmtement.setString(4, counterparty_cd);
				stmtement.setString(5, contract_type);
				stmtement.setString(6, buy_sell);
				resultset=stmtement.executeQuery();
				if(resultset.next())
				{
					qty=resultset.getDouble(1);
				}
				resultset.close();
				stmtement.close();
				
			}
		}
		catch(Exception e)
		{
			throw e;
		}
		return qty;
	}
	
	public String getAutomationKeyDetail(Connection conn,String key_nm) throws Exception
	{
		String function_nm="getAutomationKeyDetail()";
		String key_value="";
		try
		{
			if(conn!=null)
			{
				String query = "SELECT KEY_VALUE "
						+ "FROM FMS_AUTOMATION_KEY "
						+ "WHERE KEY_NM = ?";
				stmtement = conn.prepareStatement(query);
				stmtement.setString(1, key_nm);
				resultset = stmtement.executeQuery();
				while(resultset.next())
				{
					key_value=resultset.getString(1)==null?"":resultset.getString(1);
				}
				stmtement.close();
				resultset.close();
				
			}
		}
		catch(Exception e)
		{
			throw e;
		}
		return key_value;
	}
	
	
