	public String RateNumberFormat(double rate, String rate_unit)
	{
		String function_nm="RateNumberFormat()";
		String number="";
		try
		{
			if(rate_unit.equals("1"))
			{
				number = nf.format(rate);
			}
			else if(rate_unit.equals("2"))
			{
				number = nf2.format(rate);
			}
			else
			{
				number = nf.format(rate);
			}
		}
		catch(Exception e)
		{
			throw e;
		}
		return number;
	}
	
