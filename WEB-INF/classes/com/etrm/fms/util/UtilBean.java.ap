	public String RemovePrePaddingZero(String code)
	{
		String function_nm="RemovePrePaddingZero()";
		String final_code="";
		try
		{
			int number = code.length();
			int count=0;
			for(int i=0;i<number;i++)
			{
				String temp = ""+code.charAt(i);
				if(temp.equals("0"))
				{
					count++;
				}
				else
				{
					break;
				}
			}
			
			final_code=code.substring(count, number);
		}
		catch(Exception e)
		{
			throw e;
		}
		
		return final_code;
	}
	
