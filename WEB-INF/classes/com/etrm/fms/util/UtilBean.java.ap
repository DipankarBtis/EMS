	public String DueDateCalculation(Connection conn,String inv_date,String days,String type,String exclude_sat,String comp_cd,String holiday_state) throws Exception
	{
		String function_nm="DueDateCalculation()";
		String date="";

		String temp_holiday_state="";
		if(!holiday_state.equals(""))
		{
			String[] split = holiday_state.split("@");
			for(int i=0; i<split.length;i++)
			{
				temp_holiday_state+=temp_holiday_state.equals("")?"'"+split[i]+"'":",'"+split[i]+"'";
			}
		}
		temp_holiday_state+=temp_holiday_state.equals("")?"'00'":",'00'";
		
		try
		{
			if(conn!=null)
			{
				if(type.equals("C")) //CALENDAR DAYS
				{
					if(!days.equals(""))
					{
						int day=Integer.parseInt(days);
						for(int i=1; i <=day; i++)
		    			{
							date=dateUtil.getDate(inv_date, ""+i);
							
							int noOfSat=dateUtil.getNumberOfSaturdayForMonth(date);
							String shortDaynm=dateUtil.getShortWeekDaysName(date).toUpperCase();
							if(exclude_sat.contains(""+noOfSat) || shortDaynm.equals("SUN"))
							{
								day = day + 1;
							}	
						}
					}
				}
				else if(type.equals("B")) //BUSINESS DAY
				{
					if(!days.equals(""))
					{
						int day=Integer.parseInt(days);
						for(int i=1; i <=day; i++)
		    			{
							date=dateUtil.getDate(inv_date, ""+i);
							int count=0;
							if(!temp_holiday_state.equals(""))
							{
								String query1="SELECT COUNT(*) "
										+ "FROM FMS_HOLIDAY_DTL "
										+ "WHERE HOLIDAY_DT=TO_DATE(?,'DD/MM/YYYY') "
										+ "AND FLAG='Y' AND STATE_TIN IN ("+temp_holiday_state+") ";
								String temp_query1=query1;
								stmtement1 = conn.prepareStatement(temp_query1);
								stmtement1.setString(1, date);
								resultset1=stmtement1.executeQuery();
								if(resultset1.next())
								{
									count = resultset1.getInt(1);
									if(count >= 1)
									{
										day = day + 1; 
									}
								}
								stmtement1.close();
								resultset1.close();
							}
							
							if(count==0)
							{
								int noOfSat=dateUtil.getNumberOfSaturdayForMonth(date);
								String shortDaynm=dateUtil.getShortWeekDaysName(date).toUpperCase();
								if(exclude_sat.contains(""+noOfSat) || shortDaynm.equals("SUN"))
								{
									day = day + 1;
								}
							}
		    			}
					}
				}
			}
		}
		catch(Exception e)
		{
			throw e;
		}
		return date;
	}
		
	public String getContVariableDCQ(Connection conn,String comp_cd,String counterparty_cd, String agmt_no, String cont_no, String cont_type, String date) throws Exception
	{
		String function_nm="getContVariableDCQ()";
		String dcq="";
		try
		{
			if(conn!=null)
			{
				String query="SELECT DCQ "
						+ "FROM FMS_SUPPLY_CONT_DCQ_DTL "
						+ "WHERE COMPANY_CD=? AND COUNTERPARTY_CD=? "
						+ "AND AGMT_NO=? AND CONT_NO=? "
						+ "AND CONTRACT_TYPE=? AND STATUS='Y' "
						+ "AND FROM_DT<=TO_DATE(?,'DD/MM/YYYY') AND TO_DT>=TO_DATE(?,'DD/MM/YYYY') ";
				stmtement = conn.prepareStatement(query);
				stmtement.setString(1, comp_cd);
				stmtement.setString(2, counterparty_cd);
