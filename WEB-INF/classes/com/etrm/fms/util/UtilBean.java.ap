	public String getTaxDescr(Connection conn,String struct_cd, String struct_dt) throws Exception
	{
		String function_nm="getTaxDescr()";
		String struct_info="";
		try
		{
			if(conn!=null)
			{
				String query="SELECT DESCR "
						+ "FROM FMS_TAX_STRUCTURE "
						+ "WHERE TAX_STR_CD=? "
						+ "AND APP_DATE=TO_DATE(?,'DD/MM/YYYY')";
				stmtement = conn.prepareStatement(query);
				stmtement.setString(1, struct_cd);
				stmtement.setString(2, struct_dt);
				resultset = stmtement.executeQuery();
				if(resultset.next())
				{
					struct_info=resultset.getString(1)==null?"":resultset.getString(1);
				}
				stmtement.close();
				resultset.close();
				
			}
		}
		catch(Exception e)
		{
			throw e;
		}
		return struct_info;
	}
	
