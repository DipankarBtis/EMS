	public String getShipName(Connection conn,String cd) throws Exception
	{
		String function_nm="getShipName()";
		String name="";
		try
		{
			if(conn!=null)
			{
				String query="SELECT SHIP_NAME "
						+ "FROM FMS_SHIP_MST A "
						+ "WHERE SHIP_CD=? "
						+ "AND EFF_DT=(SELECT MAX(B.EFF_DT) FROM FMS_SHIP_MST B WHERE A.SHIP_CD=B.SHIP_CD) "
						+ "ORDER BY SHIP_CD DESC";
				stmtement = conn.prepareStatement(query);
				stmtement.setString(1, cd);
				resultset = stmtement.executeQuery();
				if(resultset.next())
				{
					name = resultset.getString(1)==null?"":resultset.getString(1);
				}
				stmtement.close();
				resultset.close();
				
			}
		}
		catch(Exception e)
		{
			throw e;
		}
		return name;
	}
	
