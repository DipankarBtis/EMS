	public String PrePaddingZero(String code, int numLen)
	{
		String function_nm="PrePaddingZero()";
		String final_code="";
		try
		{
			final_code=code;
			int number = numLen-code.length();
			for(int i=0;i<number;i++)
			{
				final_code="0"+final_code;
			}
		}
		catch(Exception e)
		{
			throw e;
		}
		
		return final_code;
	}
	
