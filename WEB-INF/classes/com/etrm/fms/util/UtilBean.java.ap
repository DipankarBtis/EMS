					if(resultset1.next())
					{
						amt+=resultset1.getDouble(1);
					}
					resultset1.close();
					stmtement1.close();
					
					//CREDIT NOTE
					queryString1="SELECT SUM(ABS(NVL(NET_PAYABLE_AMT,0)-NVL(TDS_GROSS_AMT,0)-NVL(TDS_TAX_AMT,0))) "
							+ "FROM FMS_DLNG_INVOICE_MST A  "
