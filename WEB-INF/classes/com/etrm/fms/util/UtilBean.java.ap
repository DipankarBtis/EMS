	// This is for Display only --- ADRESSING SAP NEED
	public String NewDealMappingId(String comp_cd, String counterparty_cd,String agmt, String agmt_rev, String cont, String cont_rev, String cont_type, String cargo_no)
	{
		String function_nm="NewDealMappingId()";
		String map="";
		String entity_type = "";
		
		try
		{		
			// Set Entity Type
			if(cont_type.equals("S") || cont_type.equals("L") || cont_type.equals("X"))
			{
				entity_type = "C";
			}
			else if(cont_type.equals("C") || cont_type.equals("R") || cont_type.equals("K"))
			{
				entity_type = "R";
			}	
			
			// Set Mapping		
			if(cont_type.equals("S") || cont_type.equals("C") || cont_type.equals("R"))
			{
				//map=comp_cd+entity_type+counterparty_cd+"-"+cont_type+""+agmt+"-"+cont;
				map=comp_cd+entity_type+counterparty_cd+""+cont_type+""+agmt+"-"+cont; // Adjusted for SAP 12 digit Limitation
			}
			else if(cont_type.equals("L") || cont_type.equals("X"))
			{
				//map=comp_cd+entity_type+counterparty_cd+"-"+cont_type+""+cont;
				map=comp_cd+entity_type+counterparty_cd+""+cont_type+""+cont; // Adjusted for SAP 12 digit Limitation
			}
			else if(cont_type.equals("V") || cont_type.equals("N") 
					|| cont_type.equals("G") || cont_type.equals("P") || cont_type.equals("Q") || cont_type.equals("O")) // LTCORA, Derivative and LNG Cargo CN
			{
				// Contract# gets incremented over calendar year irrespective of any Counter-party.
				// So I don’t need to display AGMT# here for uniqueness
				if (cargo_no.equals("") || cargo_no.equals("0"))
				{	
					map=comp_cd+""+cont_type+""+cont; 
				}
				else
				{
					map=comp_cd+""+cont_type+""+cont+"-"+cargo_no;; 
				}	
			}				
			else if(cont_type.equals("D") || cont_type.equals("T") || cont_type.equals("I")
					|| cont_type.equals("H") || cont_type.equals("Y")|| cont_type.equals("A") 
					|| cont_type.equals("F") || cont_type.equals("E")|| cont_type.equals("W") 
					|| cont_type.equals("B") || cont_type.equals("M") || cont_type.equals("K")) // Purchase, Cargo Service, DLNG, Parking
			{
				// Contract# gets incremented over calendar year irrespective of any Counter-party.
				// So I don’t need to display AGMT# here for uniqueness
				map=comp_cd+""+cont_type+""+cont; 
			}				
			else if(cont_type.equals("Z")) // This is for Storage
			{
				map=comp_cd+""+cont_type+""+cont;
			}						
		}
		catch(Exception e)
		{
			throw e;
		}
		return map;
	}

	
	public String NewAgmtMappingId(String comp_cd, String counterparty_cd,String agmt, String agmt_rev, String agmt_type)
	{
		String function_nm="NewAgmtMappingId()";
		String map="";
		String entity_type = "";
		
		try
		{		
			// Set Entity Type
			if(agmt_type.equals("F") || agmt_type.equals("D") || agmt_type.equals("T"))
			{
				entity_type = "C";
			}
			else if(agmt_type.equals("M") || agmt_type.equals("L") || agmt_type.equals("U"))
			{
				entity_type = "T";
			}
			else if(agmt_type.equals("G") || agmt_type.equals("P"))
			{
				entity_type = "R";
			}
			
			
			// Set Mapping		
			
			map=comp_cd+entity_type+counterparty_cd+"-"+agmt_type+""+agmt;
			
				
		}
		catch(Exception e)
		{
			throw e;
		}
		return map;
	}
	
	public String  getContractTypeName(String cont_type)
	{
		String function_nm="getContractTypeName()";
		String nm="";
		try
		{			
			if(cont_type.equals("S"))
			{
				nm="Supply Notice";
			}
			else if(cont_type.equals("L")) 
			{
				nm="LoA";
			}
			else if(cont_type.equals("X")) 
			{
				nm="IGX(Sell)";
			} 
			else if(cont_type.equals("O")) 
			{
				nm="LTCORA(Sell) CN";
			} 
			else if(cont_type.equals("Q"))
			{
				nm="LTCORA(Sell) Period";
			}
			else if(cont_type.equals("V"))
			{
				nm="Derivative (Hedge)";
			}
			else if(cont_type.equals("F")) 
			{
				nm="DLNG Supply Notice";
			}
			else if(cont_type.equals("E")) 
			{
				nm="DLNG LoA";
			}
			else if(cont_type.equals("W")) 
			{
				nm="DLNG IGX(Sell)";
			}
			else if(cont_type.equals("B"))
			{
				nm="Service Order";
			}
			else if(cont_type.equals("M"))
			{
				nm="Term Sheet";
			}						
			else if(cont_type.equals("I")) 
			{
				nm="IGX(Buy)";
			} 
			else if(cont_type.equals("D")) 
			{
				nm="Domestic NG";
			}
			else if(cont_type.equals("T")) 
			{
				nm="In Tank LNG/RLNG";
			}
			else if(cont_type.equals("N"))
			{
				nm="LNG Cargo";
			}	
			else if(cont_type.equals("G")) 
			{
				nm="LTCORA(Buy) CN";
			} 
			else if(cont_type.equals("P"))
			{
				nm="LTCORA(Buy) Period";
			}
			else if(cont_type.equals("Y"))
			{
				nm="Surveyor Agent Contract";
			}
			else if(cont_type.equals("A"))
			{
				nm="Vessel Agent Contract";
			}
			else if(cont_type.equals("H"))
			{
				nm="Custom House Agent Contract";
			}
			else if(cont_type.equals("R"))
			{
				nm="Capacity Tranche (Transporter)";
			}
			else if(cont_type.equals("C"))
			{
				nm="Capacity Tranche (Customer)";
			}
			else if(cont_type.equals("K"))
			{
				nm="Parking Contract";
			}
			else if(cont_type.equals("Z"))
			{
				nm="Storage";
			}			
			else // if(nm.equals("")) // MISSING DICTIONARY UPDATE
			{
				nm =cont_type;
			}
		}
		
		catch(Exception e)
		{
			throw e;
		}
		
		return nm;
	}
	

	public String  getMR_ContractTypeName(String cont_type)
	{
		String function_nm="getMR_ContractTypeName()";
		String nm="";
		try
		{			
			if(cont_type.equals("S"))
			{
				nm="RLNG-BL";
			}
			else if(cont_type.equals("L")) 
			{
				nm="RLNG-BL";
			}
			else if(cont_type.equals("X")) 
			{
				nm="RLNG-IGX";
			} 
			else if(cont_type.equals("V"))
			{
				nm="Hedge";
			}
			else if(cont_type.equals("F")) 
			{
