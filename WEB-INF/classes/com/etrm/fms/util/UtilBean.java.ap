	public String getFreqNm(String freq)
	{
		String function_nm="getFreqNm()";
		String freq_nm="";
		try
		{
			if(freq.equals("1"))
			{
				freq_nm="1st-Fortnight";
			}
			else if(freq.equals("2"))
			{
				freq_nm="2nd-Fortnight";
			}
			else if(freq.equals("3"))
			{
				freq_nm="1st-Weekly";
			}
			else if(freq.equals("4"))
			{
				freq_nm="2nd-Weekly";
			}
			else if(freq.equals("5"))
			{
				freq_nm="3rd-Weekly";
			}
			else if(freq.equals("6"))
			{
				freq_nm="4th-Weekly";
			}
			else if(freq.equals("7"))
			{
				freq_nm="Monthly";
			}
			else if(freq.equals("8"))
			{
				freq_nm="Other";
			}
			else if(freq.equals("9"))
			{
				freq_nm="5th-Weekly";
			}
			else if(freq.equals("10"))
			{
				freq_nm="Delivery Period";
			}
		}
		catch(Exception e)
		{
			throw e;
		}
		return freq_nm;
	}
	
