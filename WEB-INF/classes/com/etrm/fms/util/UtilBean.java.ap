					resultset1=stmtement1.executeQuery();
					if(resultset1.next())
					{
						amt+=resultset1.getDouble(1);
					}
					resultset1.close();
					stmtement1.close();
					
					//FFLOW CREDIT NOTE, CCR
					queryString1="SELECT SUM(NVL(NET_PAYABLE_AMT,0)-NVL(TDS_GROSS_AMT,0)-NVL(TDS_TAX_AMT,0)) "
							+ "FROM FMS_FFLOW_INV_MST A  "
							+ "WHERE COMPANY_CD=? AND COUNTERPARTY_CD=? "
							+ "AND CONT_NO=? AND AGMT_NO=? AND CONTRACT_TYPE=? "
							+ "AND INVOICE_DT=TO_DATE(?,'DD/MM/YYYY') "
							+ "AND INVOICE_TYPE IN ('CR','CCR') "
							+ "AND PDF_INV_DTL IS NOT NULL";
					stmtement1 = conn.prepareStatement(queryString1);
					stmtement1.setString(1, comp_cd);
					stmtement1.setString(2, counterparty_cd);
					stmtement1.setString(3, cont_no);
					stmtement1.setString(4, agmt_no);
					stmtement1.setString(5, contract_type);
					stmtement1.setString(6, date);
					resultset1=stmtement1.executeQuery();
					if(resultset1.next())
					{
						amt+=resultset1.getDouble(1);
					}
					resultset1.close();
					stmtement1.close();
					
					//CREDIT NOTE
					queryString1="SELECT SUM(ABS(NVL(NET_PAYABLE_AMT,0)-NVL(TDS_GROSS_AMT,0)-NVL(TDS_TAX_AMT,0))) "
							+ "FROM FMS_INVOICE_MST A  "
							+ "WHERE COMPANY_CD=? AND COUNTERPARTY_CD=? "
							+ "AND CONT_NO=? AND AGMT_NO=? AND CONTRACT_TYPE=? "
							+ "AND INVOICE_DT=TO_DATE(?,'DD/MM/YYYY') "
							+ "AND INV_FLAG IN ('CR') "
							+ "AND PDF_INV_DTL IS NOT NULL";
					stmtement1 = conn.prepareStatement(queryString1);
					stmtement1.setString(1, comp_cd);
					stmtement1.setString(2, counterparty_cd);
					stmtement1.setString(3, cont_no);
					stmtement1.setString(4, agmt_no);
					stmtement1.setString(5, contract_type);
					stmtement1.setString(6, date);
					resultset1=stmtement1.executeQuery();
					if(resultset1.next())
					{
						amt+=resultset1.getDouble(1);
					}
					resultset1.close();
					stmtement1.close();
				}
				
				if(amt < 0)
				{
					amt=0;
				}
			}
		}
		catch(Exception e)
		{
			throw e;
		}
		return amt;
	}
	
	public Double getCFormHoldPercent(Connection conn,String state_tin,String date) throws Exception
	{
		String function_nm="getCFormHoldPercent()";
		double percent=0;
		try
		{
			if(conn!=null)
			{
				String queryString ="SELECT HOLD_PERCNT "
						+ "FROM FMS_CFORM_HOLD_PERCNT A "
						+ "WHERE A.STATE_TIN=? "
						+ "AND A.EFF_DT=(SELECT MAX(EFF_DT) FROM FMS_CFORM_HOLD_PERCNT B WHERE A.STATE_TIN=B.STATE_TIN "
						+ "AND B.EFF_DT<= TO_DATE(?,'DD/MM/YYYY'))";
				stmtement = conn.prepareStatement(queryString);
				stmtement.setString(1, state_tin);
				stmtement.setString(2, date);
				resultset=stmtement.executeQuery();
				if(resultset.next())
				{
					percent=resultset.getDouble(1);
				}
				resultset.close();
				stmtement.close();
			}
		}
		catch(Exception e)
		{
			throw e;
		}
		return percent;
	}
	
	public Double getInvoiceHoldAmount(Connection conn,String comp_cd,String counterparty_cd, String agmt_no, String cont_no, String contract_type, String plant_seq, String bu_unit, 
			String date, String tax_struct_dtl, String gross_amt, String bu_state_tin, String invoice_dt) throws Exception
	{
		String function_nm="getInvoiceHoldAmount()";
		double amt=0;
		try
		{
			if(conn!=null)
			{
				int adv_entry=0;
				String queryString3 ="SELECT COUNT(*) "
						+ "FROM FMS_SECURITY_MST A,FMS_SECURITY_DEAL_MAP B "
						+ "WHERE A.COMPANY_CD=? AND A.COUNTERPARTY_CD=? AND A.GX=? "
						+ "AND B.AGMT_NO=? AND B.CONT_NO=? AND B.CONTRACT_TYPE=? "
						+ "AND SEC_TYPE IN ('ADV') AND STATUS IN ('O') "
						+ "AND A.COMPANY_CD=B.COMPANY_CD AND A.COUNTERPARTY_CD=B.COUNTERPARTY_CD AND A.SEQ_NO=B.SEQ_NO "
						+ "AND A.SEQ_REV_NO=B.SEQ_REV_NO AND A.GX=B.GX";
				stmtement3 = conn.prepareStatement(queryString3);
				stmtement3.setString(1, comp_cd);
				stmtement3.setString(2, counterparty_cd);
				stmtement3.setString(3, "K");
				stmtement3.setString(4, agmt_no);
				stmtement3.setString(5, cont_no);
				stmtement3.setString(6, contract_type);
				resultset3=stmtement3.executeQuery();
				if(resultset3.next())
				{
					adv_entry=resultset3.getInt(1);
				}
				resultset3.close();
				stmtement3.close();
				
				
				String cform_flag="";
				if(adv_entry > 0)
				{
	        		String queryString="SELECT CFORM_FLAG "
							+ "FROM FMS_SUPPLY_CFORM_DTL A "
							+ "WHERE COMPANY_CD=? AND COUNTERPARTY_CD=? "
							+ "AND AGMT_NO=? AND CONT_NO=? "
							+ "AND CONTRACT_TYPE=? AND PLANT_SEQ=? AND BU_SEQ=? "
							+ "AND EFF_DT=(SELECT MAX(B.EFF_DT) FROM FMS_SUPPLY_CFORM_DTL B WHERE A.COMPANY_CD=B.COMPANY_CD "
							+ "AND A.COUNTERPARTY_CD=B.COUNTERPARTY_CD AND A.CONTRACT_TYPE=B.CONTRACT_TYPE "
							+ "AND A.AGMT_NO=B.AGMT_NO AND A.CONT_NO=B.CONT_NO AND A.PLANT_SEQ=B.PLANT_SEQ AND A.BU_SEQ=B.BU_SEQ "
							+ "AND B.EFF_DT<= TO_DATE(?,'DD/MM/YYYY'))";
					stmtement = conn.prepareStatement(queryString);
					stmtement.setString(1, comp_cd);
					stmtement.setString(2, counterparty_cd);
					stmtement.setString(3, agmt_no);
					stmtement.setString(4, cont_no);
					stmtement.setString(5, contract_type);
					stmtement.setString(6, plant_seq);
					stmtement.setString(7, bu_unit);
					stmtement.setString(8, date);
					resultset=stmtement.executeQuery();
					if(resultset.next())
					{
						cform_flag=resultset.getString(1)==null?"":resultset.getString(1);
					}
					resultset.close();
					stmtement.close();
				}
				
				cform_flag=cform_flag.equals("Y")?tax_struct_dtl.equals("CST 2%")?"Y":"":"";
				if(cform_flag.equals("Y"))
				{
					double hold_percent=getCFormHoldPercent(conn, bu_state_tin, invoice_dt);
					if(hold_percent>0)
					{
						amt=(Double.parseDouble(gross_amt) * hold_percent)/100;
					}
				}
			}
		}
		catch(Exception e)
		{
			throw e;
		}
		return amt;
	}
	
	public Double getAllowableCreditAmount(Connection conn,String comp_cd,String counterparty_cd, String agmt_no, String cont_no, String contract_type, String gx, String report_date, String sel_plant_seq, String sel_bu_unit) throws Exception
	{
		String function_nm="getAllowableCreditAmount()";
		double amt=0;
		try
		{
			if(conn!=null)
			{	
				String creditCalcDate =dateUtil.getSysdate();
				
				String contract_start_dt="";
				String contract_end_dt="";
				String dcq="";
				String price="";
				String price_unit="";
				String queryString="SELECT TO_CHAR(START_DT,'DD/MM/YYYY'),TO_CHAR(END_DT,'DD/MM/YYYY'),DCQ,RATE,RATE_UNIT,"
						+ "CONT_REF_NO,TRADE_REF_NO "
						+ "FROM FMS_SUPPLY_CONT_MST A "
						+ "WHERE COMPANY_CD=? AND COUNTERPARTY_CD=? AND AGMT_NO=? AND CONT_NO=? AND CONTRACT_TYPE=? "
						+ "AND CONT_REV = (SELECT MAX(CONT_REV) FROM FMS_SUPPLY_CONT_MST B WHERE A.COMPANY_CD=B.COMPANY_CD "
						+ "AND A.COUNTERPARTY_CD=B.COUNTERPARTY_CD AND A.CONT_NO=B.CONT_NO AND A.AGMT_NO=B.AGMT_NO AND A.AGMT_REV=B.AGMT_REV "
						+ "AND A.CONTRACT_TYPE=B.CONTRACT_TYPE) "; 
				stmtement=conn.prepareStatement(queryString);
				stmtement.setString(1, comp_cd);
				stmtement.setString(2, counterparty_cd);
				stmtement.setString(3, agmt_no);
				stmtement.setString(4, cont_no);
				stmtement.setString(5, contract_type);
				resultset=stmtement.executeQuery();
				if(resultset.next())
				{
					contract_start_dt=resultset.getString(1)==null?"":resultset.getString(1);
					contract_end_dt=resultset.getString(2)==null?"":resultset.getString(2);
					dcq=resultset.getString(3)==null?"":nf.format(resultset.getDouble(3));
					price_unit=resultset.getString(5)==null?"":resultset.getString(5);
					price=resultset.getString(4)==null?"":RateNumberFormat(resultset.getDouble(4), price_unit);
					
				}
				resultset.close();
				stmtement.close();
				
				double cumulative_net_amt=0;
				double cumulative_pay_received_amt=0;
				double cumulative_advance_amt=0;
				double cumulative_cash_deposit=0;
				double cumulative_adv_adj_amt=0;
				
				String yesdate=dateUtil.getPreviousDate();
				
				double advance_amt=0;
				int advance_count=0;
				double cash_deposit=0;
				int cash_deposit_count=0;
				String adv_info="";
				
				double first_exchng_rate=getContExchangeRate(conn,comp_cd, counterparty_cd, agmt_no, cont_no, contract_type, report_date);
				
				String queryString3 ="SELECT NVL(A.VALUE,0),A.CURRENCY,A.SEC_TYPE,A.SEC_REF_NO,TO_CHAR(A.RECEIPT_DT,'DD/MM/YYYY'),"
						+ "B.SHARE_PERCENT,A.CR_DR,NVL(A.TDS_AMT,0) "
						+ "FROM FMS_SECURITY_MST A,FMS_SECURITY_DEAL_MAP B "
						+ "WHERE A.COMPANY_CD=? AND A.COUNTERPARTY_CD=? AND A.GX=? "
						+ "AND B.AGMT_NO=? AND B.CONT_NO=? AND B.CONTRACT_TYPE=? "
						+ "AND SEC_TYPE IN ('ADV','DPT') AND STATUS IN ('O') "
						+ "AND RECEIPT_DT <= TO_DATE(?,'DD/MM/YYYY') "
						+ "AND A.COMPANY_CD=B.COMPANY_CD AND A.COUNTERPARTY_CD=B.COUNTERPARTY_CD AND A.SEQ_NO=B.SEQ_NO "
						+ "AND A.SEQ_REV_NO=B.SEQ_REV_NO AND A.GX=B.GX";
				stmtement3 = conn.prepareStatement(queryString3);
				stmtement3.setString(1, comp_cd);
				stmtement3.setString(2, counterparty_cd);
				stmtement3.setString(3, "K");
				stmtement3.setString(4, agmt_no);
				stmtement3.setString(5, cont_no);
				stmtement3.setString(6, contract_type);
				stmtement3.setString(7, creditCalcDate);
				resultset3=stmtement3.executeQuery();
				while(resultset3.next())
				{
					double secuVal=resultset3.getDouble(1);
					double tdsamt=resultset3.getDouble(8);
					
					secuVal=secuVal+tdsamt;
					
					double oriSecuVal=secuVal;
					String currency=resultset3.getString(2)==null?"":resultset3.getString(2);
					String secType=resultset3.getString(3)==null?"":resultset3.getString(3);
					String secRef=resultset3.getString(4)==null?"":resultset3.getString(4);
					secRef=comp_cd+"-"+secRef;
					
					double split_percent=resultset3.getDouble(6);
					String splitPercent=resultset3.getString(6)==null?"":resultset3.getString(6);
					String crdr=resultset3.getString(7)==null?"":resultset3.getString(7);
					
					if(crdr.equals("DR"))
					{
						secuVal*=-1;
					}
					
					if(!splitPercent.equals(""))
					{
						secuVal=(secuVal*split_percent)/100;
					}
					
					double amount=0;
					if(currency.equals("2"))
					{
						amount=secuVal*first_exchng_rate;
					}
					else
					{
						amount=secuVal;
					}
					
					if(secType.equals("ADV"))
					{
						advance_amt+=amount;
						advance_count++;
						
						String temp =secType+" ("+secRef+") : "+nf.format(advance_amt);
						adv_info+=adv_info.equals("")?temp:"\n"+temp;
					}
					else if(secType.equals("DPT"))
					{
						cash_deposit+=amount;
						cash_deposit_count++;
					}
					
				}
				resultset3.close();
				stmtement3.close();
				
				double LC_AMT=0;
				int  LC_COUNT=0;
				double BG_AMT=0;
				int  BG_COUNT=0;
				double pcgValue=0;
				int pcgCount=0;
				
				String queryString2 ="SELECT NVL(A.VALUE,0),A.CURRENCY,A.SEC_TYPE,A.SEC_REF_NO,TO_CHAR(A.EXPIRE_DT,'DD/MM/YYYY'),"
						+ "B.SHARE_PERCENT,A.GUARANTOR_CD "
						+ "FROM FMS_SECURITY_MST A,FMS_SECURITY_DEAL_MAP B "
						+ "WHERE A.COMPANY_CD=? AND A.COUNTERPARTY_CD=? AND A.GX=? "
						+ "AND B.AGMT_NO=? AND B.CONT_NO=? AND B.CONTRACT_TYPE=? "
						+ "AND A.SEC_CATEGORY='R' AND SEC_TYPE IN ('LC','BG','PCG') AND STATUS IN ('O','C','R') "
						+ "AND ISSUE_DT<=TO_DATE(?,'DD/MM/YYYY') AND (EXPIRE_DT>=TO_DATE(?,'DD/MM/YYYY') "
						+ "AND (TO_DATE(TO_CHAR(CANCEL_DT,'DD/MM/YYYY'),'DD/MM/YYYY')-1 >= TO_DATE(?,'DD/MM/YYYY') OR CANCEL_DT IS NULL)) "
						+ "AND A.COMPANY_CD=B.COMPANY_CD AND A.COUNTERPARTY_CD=B.COUNTERPARTY_CD AND A.SEQ_NO=B.SEQ_NO "
						+ "AND A.SEQ_REV_NO=B.SEQ_REV_NO AND A.GX=B.GX";
				stmtement2 = conn.prepareStatement(queryString2);
				stmtement2.setString(1, comp_cd);
				stmtement2.setString(2, counterparty_cd);
				stmtement2.setString(3, "K");
				stmtement2.setString(4, agmt_no);
				stmtement2.setString(5, cont_no);
				stmtement2.setString(6, contract_type);
				stmtement2.setString(7, creditCalcDate);
				stmtement2.setString(8, creditCalcDate);
				stmtement2.setString(9, creditCalcDate);
				resultset2=stmtement2.executeQuery();
				while(resultset2.next())
				{
					double secuVal=resultset2.getDouble(1);
					double oriSecuVal=secuVal;
					String currency=resultset2.getString(2)==null?"":resultset2.getString(2);
					String secType=resultset2.getString(3)==null?"":resultset2.getString(3);
					String secRef=resultset2.getString(4)==null?"":resultset2.getString(4);
					//secRef=companyCd+"-"+secRef;
					
					double split_percent=resultset2.getDouble(6);
					String splitPercent=resultset2.getString(6)==null?"":resultset2.getString(6);
					String guarantor_cd=resultset2.getString(7)==null?"":resultset2.getString(7);
					
					if(!splitPercent.equals(""))
					{
						secuVal=(secuVal*split_percent)/100;
					}
					
					double amount=0;
					if(currency.equals("2"))
					{
						amount=secuVal*first_exchng_rate;
					}
					else
					{
						amount=secuVal;
					}
					
					if(secType.equalsIgnoreCase("LC"))
					{
						LC_AMT += amount;
						LC_COUNT++;
					}
					else if(secType.equalsIgnoreCase("BG"))
					{
						BG_AMT += amount;
						BG_COUNT++;
					}
					else if(secType.equalsIgnoreCase("PCG"))
					{
						if(guarantor_cd.equals(""))
						{
							//pcg_deal_value+=amount;
							pcgValue+=amount;
							pcgCount+=1;
						}
						else
						{
							//pcg_uncapped_value+=amount;
						}
					}
				}
				resultset2.close();
				stmtement2.close();
				
				int isApprovedExceedDayConfig=0;
				int isExceedDayConfig=0;
				double ExceedValue=0;
				String currency="";
				queryString="SELECT COUNT(*),VALUE,CURRENCY "
						+ "FROM FMS_CREDIT_EXCEED_DAYS "
						+ "WHERE COMPANY_CD=? AND COUNTERPARTY_CD=? "
						+ "AND AGMT_NO=? AND CONT_NO=? AND CONTRACT_TYPE=? AND STATUS=? "
						+ "AND FROM_DT <= TO_DATE(?,'DD/MM/YYYY') AND TO_DT >= TO_DATE(?,'DD/MM/YYYY') "
						+ "GROUP BY VALUE,CURRENCY ";
				stmtement=conn.prepareStatement(queryString);
				stmtement.setString(1, comp_cd);
				stmtement.setString(2, counterparty_cd);
				stmtement.setString(3, agmt_no);
				stmtement.setString(4, cont_no);
				stmtement.setString(5, contract_type);
				stmtement.setString(6, "O");
				stmtement.setString(7, creditCalcDate);
				stmtement.setString(8, report_date);
				resultset=stmtement.executeQuery();
				if(resultset.next())
				{
					isExceedDayConfig=resultset.getInt(1);
					ExceedValue=resultset.getDouble(2);
					currency=getRateUnitNm(conn,resultset.getString(3)==null?"":resultset.getString(3));
				}
				resultset.close();
				stmtement.close();
				
				cumulative_advance_amt+=advance_amt;
				cumulative_cash_deposit+=cash_deposit;
				
				///////////////////////////////////////////////////////////////////////////////
				int days=dateUtil.getDays(contract_end_dt, contract_start_dt);
				for(int i=0;i<days;i++)
				{
					String date = dateUtil.getDate(contract_start_dt, ""+i);	
					int countRu=dateUtil.getDays(date, yesdate);
					String ru=countRu<=1?"R":"U";
					
					String cont_price="";
					String queryString1 = "SELECT DISTINCT NEW_SALE_PRICE "
							+ "FROM FMS_SUPPLY_ALLOC_REVISED A "
							+ "WHERE COMPANY_CD=? AND AGMT_NO=? AND CONT_NO=? "
							+ "AND COUNTERPARTY_CD=? AND FLAG=? AND CONTRACT_TYPE=? "
							+ "AND MODIFICATION_SEQ_NO = (SELECT MAX(MODIFICATION_SEQ_NO) FROM FMS_SUPPLY_ALLOC_REVISED B "
							+ "WHERE A.COMPANY_CD=B.COMPANY_CD AND A.AGMT_NO=B.AGMT_NO AND A.CONT_NO=B.CONT_NO "
							+ "AND A.COUNTERPARTY_CD=B.COUNTERPARTY_CD AND A.FLAG=B.FLAG AND A.CONTRACT_TYPE=B.CONTRACT_TYPE "
							+ "AND B.NEW_PRICE_EFF_DT <=TO_DATE(?,'DD/MM/YYYY'))";
					stmtement1=conn.prepareStatement(queryString1);
					stmtement1.setString(1, comp_cd);
					stmtement1.setString(2, agmt_no);
					stmtement1.setString(3, cont_no);
					stmtement1.setString(4, counterparty_cd);
					stmtement1.setString(5, "A");
					stmtement1.setString(6, contract_type);
					stmtement1.setString(7, date);
					resultset1=stmtement1.executeQuery();
					if(resultset1.next())
					{
						cont_price=resultset1.getString(1)==null?"":RateNumberFormat(resultset1.getDouble(1), price_unit);
					}
					resultset1.close();
					stmtement1.close();
					
					if(cont_price.equals(""))
					{
						cont_price=price;
					}
					
					double exchng_rate=getContExchangeRate(conn,comp_cd, counterparty_cd, agmt_no, cont_no, contract_type, date);
					double qty=0;
					double other_chrg=0;
					double gross_amt=0;
					double total_gross_amt=0;
					double tax_amt=0;
					
					String qty_info="Gas Date = "+date;
					queryString="SELECT B.PLANT_SEQ_NO,D.PLANT_SEQ_NO,(SELECT COUNT(*) FROM FMS_SUPPLY_CONT_MST A, FMS_SUPPLY_CONT_PLANT B, FMS_SUPPLY_CONT_BU D "
							+ "WHERE A.COMPANY_CD=? AND A.COUNTERPARTY_CD=? AND A.AGMT_NO=? AND A.CONT_NO=? AND A.CONTRACT_TYPE=? "
							+ "AND A.CONT_REV=(SELECT MAX(CONT_REV) FROM FMS_SUPPLY_CONT_MST B WHERE A.COMPANY_CD=B.COMPANY_CD AND A.COUNTERPARTY_CD=B.COUNTERPARTY_CD "
							+ "AND A.AGMT_NO=B.AGMT_NO AND A.AGMT_REV=B.AGMT_REV AND A.CONT_NO=B.CONT_NO AND A.CONTRACT_TYPE=B.CONTRACT_TYPE) "
							+ "AND A.COMPANY_CD=B.COMPANY_CD AND A.COUNTERPARTY_CD=B.COUNTERPARTY_CD AND A.AGMT_NO=B.AGMT_NO AND A.AGMT_REV=B.AGMT_REV "
							+ "AND A.CONT_NO=B.CONT_NO AND A.CONT_REV=B.CONT_REV AND A.CONTRACT_TYPE=B.CONTRACT_TYPE "
							+ "AND A.COMPANY_CD=D.COMPANY_CD AND A.COUNTERPARTY_CD=D.COUNTERPARTY_CD AND A.AGMT_NO=D.AGMT_NO AND A.AGMT_REV=D.AGMT_REV "
							+ "AND A.CONT_NO=D.CONT_NO AND A.CONT_REV=D.CONT_REV AND A.CONTRACT_TYPE=D.CONTRACT_TYPE) "
							+ "FROM FMS_SUPPLY_CONT_MST A, FMS_SUPPLY_CONT_PLANT B, FMS_SUPPLY_CONT_BU D  "
							+ "WHERE A.COMPANY_CD=? AND A.COUNTERPARTY_CD=? AND A.AGMT_NO=? AND A.CONT_NO=? AND A.CONTRACT_TYPE=? "
							+ "AND A.CONT_REV=(SELECT MAX(CONT_REV) FROM FMS_SUPPLY_CONT_MST B WHERE A.COMPANY_CD=B.COMPANY_CD AND A.COUNTERPARTY_CD=B.COUNTERPARTY_CD "
							+ "AND A.AGMT_NO=B.AGMT_NO AND A.AGMT_REV=B.AGMT_REV AND A.CONT_NO=B.CONT_NO AND A.CONTRACT_TYPE=B.CONTRACT_TYPE) "
							+ "AND A.COMPANY_CD=B.COMPANY_CD AND A.COUNTERPARTY_CD=B.COUNTERPARTY_CD AND A.AGMT_NO=B.AGMT_NO AND A.AGMT_REV=B.AGMT_REV "
							+ "AND A.CONT_NO=B.CONT_NO AND A.CONT_REV=B.CONT_REV AND A.CONTRACT_TYPE=B.CONTRACT_TYPE "
							+ "AND A.COMPANY_CD=D.COMPANY_CD AND A.COUNTERPARTY_CD=D.COUNTERPARTY_CD AND A.AGMT_NO=D.AGMT_NO AND A.AGMT_REV=D.AGMT_REV "
							+ "AND A.CONT_NO=D.CONT_NO AND A.CONT_REV=D.CONT_REV AND A.CONTRACT_TYPE=D.CONTRACT_TYPE ";
					stmtement=conn.prepareStatement(queryString);
					stmtement.setString(1, comp_cd);
					stmtement.setString(2, counterparty_cd);
					stmtement.setString(3, agmt_no);
					stmtement.setString(4, cont_no);
					stmtement.setString(5, contract_type);
					stmtement.setString(6, comp_cd);
					stmtement.setString(7, counterparty_cd);
					stmtement.setString(8, agmt_no);
					stmtement.setString(9, cont_no);
					stmtement.setString(10, contract_type);
					resultset=stmtement.executeQuery();
					while(resultset.next())
					{
						String plant_seq=resultset.getString(1)==null?"":resultset.getString(1);
						String bu_seq=resultset.getString(2)==null?"":resultset.getString(2);
						
						if(report_date.equals(date) && plant_seq.equals(sel_plant_seq) && bu_seq.equals(sel_bu_unit))
						{
							plant_seq="";
							bu_seq="";
						}
						
						
						//String plantAbbr=getCounterpartyPlantABBR(conn, counterparty_cd, comp_cd, plant_seq, "C");
						//String buAbbr=getCounterpartyPlantABBR(conn, comp_cd, comp_cd, bu_seq, "B");
						
						int total_combination=resultset.getInt(3);
						
						//HARSH20250326 AS DISCUSSED WITH JAYASRI MAM, IF 'U' THEN TAKE ONLY CONTRACT DCQ
						//HARSH20250407 AS DISCUSSED WITH VIJAY :
						//1)for (R) - calculate till sysdate -1, Allocation only be considered in logic, if allocation is null then default zero(0).
						//2)for (U) - From sysdate and onward, Allocation - Seller - Buyer - DCQ - 0 to be considered in logic.
						
						if(contract_type.equals("W") || contract_type.equals("E") || contract_type.equals("F"))
						{
							queryString1="SELECT COALESCE(ALLOCATION, SELLER_NOM, 0) AS RESULT, "
									+ "CASE "
										+ "WHEN ALLOCATION IS NOT NULL THEN 'ALLOCATION' "
										+ "WHEN SELLER_NOM IS NOT NULL THEN 'SELLER_NOM' "
									+ "ELSE 'NONE' END AS SOURCE "
									+ "FROM (SELECT "
											+ "(SELECT SUM(QTY_MMBTU) "
											+ "FROM FMS_DLNG_ALLOC_MST A "
											+ "WHERE CONT_NO=? AND AGMT_NO=? AND COMPANY_CD=? AND COUNTERPARTY_CD=? "
											+ "AND PLANT_SEQ=? AND CONTRACT_TYPE=? AND BU_SEQ=? AND GAS_DT=TO_DATE(?,'DD/MM/YYYY') "
											+ "AND NOM_REV_NO=(SELECT MAX(NOM_REV_NO) "
												+ "FROM FMS_DLNG_ALLOC_MST B "
												+ "WHERE B.CONT_NO=A.CONT_NO AND B.AGMT_NO=A.AGMT_NO AND B.COMPANY_CD=A.COMPANY_CD  "
												+ "AND B.COUNTERPARTY_CD=A.COUNTERPARTY_CD AND B.PLANT_SEQ=A.PLANT_SEQ AND B.CONTRACT_TYPE=A.CONTRACT_TYPE  "
												+ "AND B.BU_SEQ=A.BU_SEQ AND B.GAS_DT=A.GAS_DT "
												+ "AND B.TRUCK_TRANS_CD=A.TRUCK_TRANS_CD AND B.TRUCK_CD=A.TRUCK_CD AND B.FILL_STATION_CD=A.FILL_STATION_CD "
												+ "AND B.BAY_CD=A.BAY_CD AND B.SLOT_START_TIME=A.SLOT_START_TIME AND B.SLOT_END_TIME=A.SLOT_END_TIME)) AS ALLOCATION, "
											+ "(SELECT SUM(QTY_MMBTU) "
											+ "FROM FMS_DLNG_SELLER_NOM_DTL A "
											+ "WHERE CONT_NO=? AND AGMT_NO=? AND COMPANY_CD=? AND COUNTERPARTY_CD=? "
											+ "AND PLANT_SEQ=? AND CONTRACT_TYPE=? AND BU_SEQ=? AND GAS_DT=TO_DATE(?,'DD/MM/YYYY') "
											+ "AND NOM_REV_NO=(SELECT MAX(NOM_REV_NO) "
												+ "FROM FMS_DLNG_SELLER_NOM_DTL B "
												+ "WHERE B.CONT_NO=A.CONT_NO AND B.AGMT_NO=A.AGMT_NO AND B.COMPANY_CD=A.COMPANY_CD  "
												+ "AND B.COUNTERPARTY_CD=A.COUNTERPARTY_CD AND B.PLANT_SEQ=A.PLANT_SEQ AND B.CONTRACT_TYPE=A.CONTRACT_TYPE  "
												+ "AND B.BU_SEQ=A.BU_SEQ AND B.GAS_DT=A.GAS_DT))  AS SELLER_NOM "
									+ "FROM DUAL) ";
						}
						else
						{
							queryString1="SELECT COALESCE(ALLOCATION, SELLER_NOM, 0) AS RESULT, "
									+ "CASE "
										+ "WHEN ALLOCATION IS NOT NULL THEN 'ALLOCATION' "
										+ "WHEN SELLER_NOM IS NOT NULL THEN 'SELLER_NOM' "
									+ "ELSE 'NONE' END AS SOURCE "
									+ "FROM (SELECT "
											+ "(SELECT SUM(QTY_MMBTU) "
											+ "FROM FMS_DAILY_ALLOCATION_DTL A "
											+ "WHERE CONT_NO=? AND AGMT_NO=? AND COMPANY_CD=? AND COUNTERPARTY_CD=? "
											+ "AND PLANT_SEQ=? AND CONTRACT_TYPE=? AND BU_SEQ=? AND GAS_DT=TO_DATE(?,'DD/MM/YYYY') "
											+ "AND NOM_REV_NO=(SELECT MAX(NOM_REV_NO) "
												+ "FROM FMS_DAILY_ALLOCATION_DTL B "
												+ "WHERE B.CONT_NO=A.CONT_NO AND B.AGMT_NO=A.AGMT_NO AND B.COMPANY_CD=A.COMPANY_CD  "
												+ "AND B.COUNTERPARTY_CD=A.COUNTERPARTY_CD AND B.TRANSPORTER_CD=A.TRANSPORTER_CD  "
												+ "AND B.TRANS_SEQ=A.TRANS_SEQ AND B.PLANT_SEQ=A.PLANT_SEQ AND B.CONTRACT_TYPE=A.CONTRACT_TYPE  "
												+ "AND B.BU_SEQ=A.BU_SEQ AND B.GAS_DT=A.GAS_DT AND B.CARGO_NO=A.CARGO_NO)) AS ALLOCATION, "			
											+ "(SELECT SUM(QTY_MMBTU) "
											+ "FROM FMS_DAILY_SELLER_NOM A "
											+ "WHERE CONT_NO=? AND AGMT_NO=? AND COMPANY_CD=? AND COUNTERPARTY_CD=? "
											+ "AND PLANT_SEQ=? AND CONTRACT_TYPE=? AND BU_SEQ=? AND GAS_DT=TO_DATE(?,'DD/MM/YYYY') "
											+ "AND NOM_REV_NO=(SELECT MAX(NOM_REV_NO) "
												+ "FROM FMS_DAILY_SELLER_NOM B "
												+ "WHERE B.CONT_NO=A.CONT_NO AND B.AGMT_NO=A.AGMT_NO AND B.COMPANY_CD=A.COMPANY_CD  "
												+ "AND B.COUNTERPARTY_CD=A.COUNTERPARTY_CD AND B.TRANSPORTER_CD=A.TRANSPORTER_CD  "
												+ "AND B.TRANS_SEQ=A.TRANS_SEQ AND B.PLANT_SEQ=A.PLANT_SEQ AND B.CONTRACT_TYPE=A.CONTRACT_TYPE  "
												+ "AND B.BU_SEQ=A.BU_SEQ AND B.GAS_DT=A.GAS_DT AND B.CARGO_NO=A.CARGO_NO)) AS SELLER_NOM "
									+ "FROM DUAL) ";
						}
						stmtement1 = conn.prepareStatement(queryString1);
						stmtement1.setString(1, cont_no);
						stmtement1.setString(2, agmt_no);
						stmtement1.setString(3, comp_cd);
						stmtement1.setString(4, counterparty_cd);
						stmtement1.setString(5, plant_seq);
						stmtement1.setString(6, contract_type);
						stmtement1.setString(7, bu_seq);
						stmtement1.setString(8, date);
						stmtement1.setString(9, cont_no);
						stmtement1.setString(10, agmt_no);
						stmtement1.setString(11, comp_cd);
						stmtement1.setString(12, counterparty_cd);
						stmtement1.setString(13, plant_seq);
						stmtement1.setString(14, contract_type);
						stmtement1.setString(15, bu_seq);
						stmtement1.setString(16, date);
						resultset1=stmtement1.executeQuery();
						if(resultset1.next())
						{
							double temp_qty=resultset1.getDouble(1);
							qty+=temp_qty;
							
							String source = resultset1.getString(2)==null?"":resultset1.getString(2);
							
							double temp_gross_amt=temp_qty * Double.parseDouble(cont_price);
							if(price_unit.equals("2"))
							{
								temp_gross_amt=temp_gross_amt * exchng_rate;
							}
							
							double temp_other_chrg=0;
							String queryString6="SELECT B.CHARGE_ABBR,TO_CHAR(A.EFF_DT,'DD/MM/YYYY'),A.CHARGE_RATE "
									+ "FROM FMS_CHARGE_MST B LEFT JOIN FMS_SUPPLY_CONT_PLANT_CHRG A ON A.CHARGE_ABBR=B.CHARGE_ABBR "
									+ "WHERE A.COMPANY_CD=? AND A.COUNTERPARTY_CD=? AND A.CONT_NO=? "
									+ "AND A.AGMT_NO=? AND A.CONTRACT_TYPE=? AND A.PLANT_SEQ_NO=? AND A.CHARGE_RATE > 0 "
									+ "AND A.EFF_DT=(SELECT MAX(EFF_DT) FROM FMS_SUPPLY_CONT_PLANT_CHRG B WHERE A.COMPANY_CD=B.COMPANY_CD "
									+ "AND A.COUNTERPARTY_CD=B.COUNTERPARTY_CD AND A.CONT_NO=B.CONT_NO AND A.AGMT_NO=B.AGMT_NO AND A.AGMT_REV=B.AGMT_REV "
									+ "AND A.CONTRACT_TYPE=B.CONTRACT_TYPE AND A.PLANT_SEQ_NO=B.PLANT_SEQ_NO AND A.CHARGE_ABBR=B.CHARGE_ABBR "
									+ "AND B.EFF_DT<=TO_DATE(?,'DD/MM/YYYY'))";
							stmtement2=conn.prepareStatement(queryString6);
							stmtement2.setString(1, comp_cd);
							stmtement2.setString(2, counterparty_cd);
							stmtement2.setString(3, cont_no);
							stmtement2.setString(4, agmt_no);
							stmtement2.setString(5, contract_type);
							stmtement2.setString(6, plant_seq);
							stmtement2.setString(7, date);
							resultset2=stmtement2.executeQuery();
							while(resultset2.next())
							{
								double chrg=resultset2.getDouble(3);
								temp_other_chrg+=temp_qty*chrg;
							}
							resultset2.close();
							stmtement2.close();
								
							double temp_total_gross_amt=temp_gross_amt+temp_other_chrg;
							
							gross_amt+=temp_gross_amt;
							other_chrg+=temp_other_chrg;
							total_gross_amt+=temp_total_gross_amt;
							
							Vector temp = new Vector();
							temp=TaxCalc.TaxAmountCalculationWithInfo(conn, comp_cd, counterparty_cd, "C", plant_seq, bu_seq, date, nf.format(temp_total_gross_amt));
							double temp_tax_amt = Double.parseDouble(nf.format(Double.parseDouble(""+temp.elementAt(0))));
							
							tax_amt+=temp_tax_amt;
						}
						resultset1.close();
						stmtement1.close();
					}
					resultset.close();
					stmtement.close();
					
					double other_inv_amt=0;
					int other_inv_count=0;
					
					double tds_amt=0;
					int tds_count=0;
					double adv_adjust_amt=0;
					int adv_adjust_count=0;
					double hold_amt=0;
					int hold_count=0;
					double pay_received_amt=0;
					int pay_received_count=0;
					if(contract_type.equals("W") || contract_type.equals("E") || contract_type.equals("F"))
					{
						queryString3="SELECT SUM(NVL(B.PAY_RECV_AMT,0) - NVL(B.ADV_AMT,0)),SUM(B.ADV_AMT),COUNT(*) "
								+ "FROM FMS_DLNG_INVOICE_MST A, FMS_DLNG_INV_PAY_RECV_DTL B "
								+ "WHERE A.COMPANY_CD=? AND A.COUNTERPARTY_CD=? AND A.CONT_NO=? AND A.AGMT_NO=? AND A.CONTRACT_TYPE=? AND B.PAY_RECV_DT=TO_DATE(?,'DD/MM/YYYY') "
								+ "AND A.INV_FLAG NOT IN ('CR') "
								+ "AND A.COMPANY_CD=B.COMPANY_CD AND A.INVOICE_SEQ=B.INVOICE_SEQ AND A.BU_STATE_TIN=B.BU_STATE_TIN AND A.FINANCIAL_YEAR=B.FINANCIAL_YEAR ";
						stmtement3 = conn.prepareStatement(queryString3);
