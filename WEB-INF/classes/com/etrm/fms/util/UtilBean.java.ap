	public String getTransporterCT_Reference(Connection conn,String comp_cd, String trans_cd, String trans_plant_seq, String cont_type, String counterpty_cd, String plant_seq, String seq_no,String bu_unit) throws Exception
	{
		String function_nm="getTransporterCT_Reference()";
		String ct_ref="";
		try
		{
			if(conn!=null)
			{
				String query="SELECT A.CT_REF_NO "
						+ "FROM FMS_TRANSPORTER_CT_MST A "
						+ "WHERE A.COMPANY_CD=? AND A.ENTRY_TRANS_CD=? AND A.ENTRY_TRANS_PLANT=? AND A.CONTRACT_TYPE=? "
						+ "AND A.EXIT_COUNTERPARTY=? AND A.EXIT_PLANT_SEQ=? AND A.SEQ_NO=? AND BU_SEQ=? ";
				stmtement = conn.prepareStatement(query);
				stmtement.setString(1, comp_cd);
				stmtement.setString(2, trans_cd);
				stmtement.setString(3, trans_plant_seq);
				stmtement.setString(4, cont_type);
				stmtement.setString(5, counterpty_cd);
				stmtement.setString(6, plant_seq);
				stmtement.setString(7, seq_no);
				stmtement.setString(8, bu_unit);
				resultset = stmtement.executeQuery();
				if(resultset.next())
				{
					ct_ref = resultset.getString(1)==null?"":resultset.getString(1);
				}
				stmtement.close();
				resultset.close();
				
			}
		}
		catch(Exception e)
		{
			throw e;
		}
		return ct_ref;
	}
	
	public String getEntityContactPersonEmailList(Connection conn,String comp_cd,String counterparty_cd,String entity,String addr_flag, String notification_type, String type,String flag) throws Exception
	{
		String function_nm="getEntityContactPersonEmailList()";
		String list="";
		try
		{
			if(conn!=null && !notification_type.equals(""))
			{
				String query="SELECT EMAIL "
						+ "FROM FMS_ENTITY_CONTACT_MST A "
						+ "WHERE COMPANY_CD=? AND COUNTERPARTY_CD=? "
						+ "AND ENTITY=? AND ADDR_FLAG=? AND "+notification_type+"_FLAG=? "
						+ "AND ACTIVE_FLAG=? AND ADDR_IS_ACTIVE=? AND TYPE=? ";
				query+=flag.equals("N")?"AND (TO_"+notification_type+"=? OR TO_"+notification_type+" IS NULL)":"AND TO_"+notification_type+"=?  ";
				query+= "AND EFF_DT=(SELECT MAX(B.EFF_DT) FROM FMS_ENTITY_CONTACT_MST B WHERE A.COMPANY_CD=B.COMPANY_CD "
						+ "AND A.COUNTERPARTY_CD=B.COUNTERPARTY_CD AND A.ENTITY=B.ENTITY AND A.SEQ_NO=B.SEQ_NO AND A.TYPE=B.TYPE "
						+ "AND EFF_DT <= TO_DATE(TO_CHAR(SYSDATE,'DD/MM/YYYY'),'DD/MM/YYYY')) "
						+ "AND EMAIL IS NOT NULL";
				String temp_query=query;
				int cnt=0;
				stmtement=conn.prepareStatement(temp_query);
				stmtement.setString(++cnt, comp_cd);
				stmtement.setString(++cnt, counterparty_cd);
				stmtement.setString(++cnt, entity);
				stmtement.setString(++cnt, addr_flag);
				stmtement.setString(++cnt, "Y");
				stmtement.setString(++cnt, "Y");
				stmtement.setString(++cnt, "Y");
				stmtement.setString(++cnt, type);
				stmtement.setString(++cnt, flag);
				resultset=stmtement.executeQuery();
				while(resultset.next())
				{
					String email=resultset.getString(1)==null?"":resultset.getString(1);
					list+=list.equals("")?email:","+email;
				}
				resultset.close();
				stmtement.close();
			}
		}
		catch(Exception e)
		{
			throw e;
		}
		return list;
	}
	
	public String getEntityContactPersonCd(Connection conn,String comp_cd,String counterparty_cd,String entity,String addr_flag, String notification_type, String type,String flag) throws Exception
	{
		String function_nm="getEntityContactPersonCd()";
		String seq_no="";
		try
		{
			if(conn!=null && !notification_type.equals(""))
			{
				String query="SELECT SEQ_NO "
						+ "FROM FMS_ENTITY_CONTACT_MST A "
						+ "WHERE COMPANY_CD=? AND COUNTERPARTY_CD=? "
						+ "AND ENTITY=? AND ADDR_FLAG=? AND "+notification_type+"_FLAG=? "
						+ "AND ACTIVE_FLAG=? AND ADDR_IS_ACTIVE=? AND TYPE=? ";
				query+=flag.equals("N")?"AND (TO_"+notification_type+"=? OR TO_"+notification_type+" IS NULL)":"AND TO_"+notification_type+"=?  ";
				query+= "AND EFF_DT=(SELECT MAX(B.EFF_DT) FROM FMS_ENTITY_CONTACT_MST B WHERE A.COMPANY_CD=B.COMPANY_CD "
						+ "AND A.COUNTERPARTY_CD=B.COUNTERPARTY_CD AND A.ENTITY=B.ENTITY AND A.SEQ_NO=B.SEQ_NO AND A.TYPE=B.TYPE "
						+ "AND EFF_DT <= TO_DATE(TO_CHAR(SYSDATE,'DD/MM/YYYY'),'DD/MM/YYYY'))";
				String temp_query=query;
				int cnt=0;
				stmtement=conn.prepareStatement(temp_query);
				stmtement.setString(++cnt, comp_cd);
				stmtement.setString(++cnt, counterparty_cd);
				stmtement.setString(++cnt, entity);
				stmtement.setString(++cnt, addr_flag);
				stmtement.setString(++cnt, "Y");
				stmtement.setString(++cnt, "Y");
				stmtement.setString(++cnt, "Y");
				stmtement.setString(++cnt, type);
				stmtement.setString(++cnt, flag);
				resultset=stmtement.executeQuery();
				if(resultset.next())
				{
					seq_no=resultset.getString(1)==null?"":resultset.getString(1);
				}
				resultset.close();
				stmtement.close();
			}
		}
		catch(Exception e)
		{
			throw e;
		}
		return seq_no;
	}
	
	public String getSapDesc(Connection conn,String status_code,String status_type) throws Exception
	{
		String function_nm="getSapDesc()";
		String description="";
		try
		{
			if(conn!=null)
			{
				String query = "SELECT DECR FROM FMS_SAP_STATUS "
						+ "WHERE STATUS_TYPE=? AND STATUS_CODE =? " ;
				stmtement=conn.prepareStatement(query);
				stmtement.setString(1, status_type);
				stmtement.setString(2, status_code);
				resultset=stmtement.executeQuery();
				if(resultset.next())
				{ 
					description = resultset.getString(1)==null?"":resultset.getString(1);
				}
				else 
				{
					description="<font style=\"color:red\">Unknown "+status_type+" Status Code</font>";
				}
				resultset.close();
				stmtement.close();
				
			}
		}
		catch(Exception e)
		{
			throw e;
		}
		return description;
	}
	
	public String getState_TIN(Connection conn,String comp_cd,String counterparty_cd,String entity,String plant_seq) throws Exception
	{
		String function_nm="getState_TIN()";
		String state_code="";
		try
		{
			if(conn!=null)
			{
				String query="SELECT TIN "
						+ "FROM FMS_STATE_MST "
						+ "WHERE STATE_NM=(SELECT PLANT_STATE FROM FMS_COUNTERPARTY_PLANT_DTL A WHERE COMPANY_CD=? AND COUNTERPARTY_CD=? "
						+ "AND ENTITY=? AND SEQ_NO=? AND EFF_DT=(SELECT MAX(B.EFF_DT) FROM FMS_COUNTERPARTY_PLANT_DTL B "
						+ "WHERE A.COMPANY_CD=B.COMPANY_CD "
						+ "AND A.COUNTERPARTY_CD=B.COUNTERPARTY_CD AND A.ENTITY=B.ENTITY AND A.SEQ_NO=B.SEQ_NO "
						+ "AND B.EFF_DT<=TO_DATE(TO_CHAR(SYSDATE,'DD/MM/YYYY'),'DD/MM/YYYY')))";
				stmtement=conn.prepareStatement(query);
				stmtement.setString(1, comp_cd);
				stmtement.setString(2, counterparty_cd);
				stmtement.setString(3, entity);
				stmtement.setString(4, plant_seq);
				resultset=stmtement.executeQuery();
				if(resultset.next())
				{
					state_code=resultset.getString(1)==null?"":resultset.getString(1);
				}
				resultset.close();
				stmtement.close();
			}
		}
		catch(Exception e)
		{
			throw e;
		}
		return state_code;
	}
	
	public String ContStatusName(String status_flg)
	{
		String function_nm="ContStatusName()";
		String nm="";
		try
		{
			if(status_flg.equals("F"))
			{
				nm="New";
			}
			else if(status_flg.equals("P"))
			{
				nm="Pending Approval";
			}
			else if(status_flg.equals("Y"))
			{
				nm="Approved";
			}
			else if(status_flg.equals("N"))
			{
				nm="Not Approved";
			}
			else if(status_flg.equals("X"))
			{
				nm="Canceled";
			}
			else if(status_flg.equals("C"))
			{
				nm="Closed";
			}
			else if(status_flg.equals("R"))
			{
				nm="Re-Opened";
			}
			else if(status_flg.equals("T"))
			{
				nm="Terminated";
			}
			else if(status_flg.equals("A"))
			{
				nm="Active";
			}
			else if(status_flg.equals("")) // Only LTCORA using it, HM to cover
			{
				nm="Pending";
			}
		}
		catch(Exception e)
		{
			new SystemErrorLogger().InsertErrorLogger(db_src_file_name, function_nm, e);
		}
		return nm;
	}	
	
	public Double getAdvanceAmount(Connection conn,String comp_cd,String counterparty_cd, String agmt_no, String cont_no, String contract_type, String gx, String date) throws Exception
	{
		String function_nm="getAdvanceAmount()";
		double amt=0;
		try
		{
			if(conn!=null)
			{
				String queryString ="SELECT NVL(A.VALUE,0),A.CURRENCY,A.SEC_TYPE,A.SEC_REF_NO,TO_CHAR(A.RECEIPT_DT,'DD/MM/YYYY'),"
						+ "B.SHARE_PERCENT,A.CR_DR,NVL(A.TDS_AMT,0) "
						+ "FROM FMS_SECURITY_MST A,FMS_SECURITY_DEAL_MAP B "
						+ "WHERE A.COMPANY_CD=? AND A.COUNTERPARTY_CD=? AND A.GX=? "
						+ "AND B.AGMT_NO=? AND B.CONT_NO=? AND B.CONTRACT_TYPE=? "
						+ "AND SEC_TYPE IN ('ADV') AND STATUS IN ('O') "
						+ "AND RECEIPT_DT<=TO_DATE(?,'DD/MM/YYYY') "
						+ "AND A.COMPANY_CD=B.COMPANY_CD AND A.COUNTERPARTY_CD=B.COUNTERPARTY_CD AND A.SEQ_NO=B.SEQ_NO "
						+ "AND A.SEQ_REV_NO=B.SEQ_REV_NO AND A.GX=B.GX";
				stmtement = conn.prepareStatement(queryString);
				stmtement.setString(1, comp_cd);
				stmtement.setString(2, counterparty_cd);
				stmtement.setString(3, gx);
				stmtement.setString(4, agmt_no);
				stmtement.setString(5, cont_no);
				stmtement.setString(6, contract_type);
				stmtement.setString(7, date);
				resultset=stmtement.executeQuery();
				while(resultset.next())
				{
					double secuVal=resultset.getDouble(1);
					double tdsamt=resultset.getDouble(8);
					
					secuVal=secuVal+tdsamt;
					
					double oriSecuVal=secuVal;
					String currency=resultset.getString(2)==null?"":resultset.getString(2);
					String secType=resultset.getString(3)==null?"":resultset.getString(3);
					String secRef=resultset.getString(4)==null?"":resultset.getString(4);
					secRef=comp_cd+"-"+secRef;
					
					double split_percent=resultset.getDouble(6);
					String splitPercent=resultset.getString(6)==null?"":resultset.getString(6);
					String crdr=resultset.getString(7)==null?"":resultset.getString(7);
					
					if(crdr.equals("DR"))
					{
						secuVal*=-1;
					}
					
					if(!splitPercent.equals(""))
					{
						secuVal=(secuVal*split_percent)/100;
					}
					
					double amount=0;
					if(currency.equals("2"))
					{
						amount=secuVal*1;
					}
					else
					{
						amount=secuVal;
					}
					
					amt+=amount;				
				}
				resultset.close();
				stmtement.close();
				
				if(contract_type.equals("E") || contract_type.equals("F") || contract_type.equals("W"))
				{
					//DLNG INVOICE
					String queryString1="SELECT SUM(B.ADV_AMT) "
							+ "FROM FMS_DLNG_INVOICE_MST A, FMS_DLNG_INV_PAY_RECV_DTL B "
							+ "WHERE A.COMPANY_CD=? AND A.COUNTERPARTY_CD=? AND A.CONT_NO=? AND A.AGMT_NO=? AND A.CONTRACT_TYPE=? "
							+ "AND B.PAY_RECV_DT<=TO_DATE(?,'DD/MM/YYYY') "
							+ "AND A.COMPANY_CD=B.COMPANY_CD AND A.INVOICE_SEQ=B.INVOICE_SEQ AND A.BU_STATE_TIN=B.BU_STATE_TIN AND A.FINANCIAL_YEAR=B.FINANCIAL_YEAR ";
					stmtement = conn.prepareStatement(queryString1);
					stmtement.setString(1, comp_cd);
					stmtement.setString(2, counterparty_cd);
					stmtement.setString(3, cont_no);
					stmtement.setString(4, agmt_no);
					stmtement.setString(5, contract_type);
					stmtement.setString(6, date);
					resultset=stmtement.executeQuery();
					if(resultset.next())
					{
						amt-=resultset.getDouble(1);
					}
					resultset.close();
					stmtement.close();
					
					queryString1="SELECT SUM(A.HOLD_AMT) "
							+ "FROM FMS_DLNG_INVOICE_MST A "
							+ "WHERE A.COMPANY_CD=? AND A.COUNTERPARTY_CD=? AND A.CONT_NO=? AND A.AGMT_NO=? AND A.CONTRACT_TYPE=? "
							+ "AND A.INVOICE_DT<=TO_DATE(?,'DD/MM/YYYY')";
					stmtement = conn.prepareStatement(queryString1);
					stmtement.setString(1, comp_cd);
					stmtement.setString(2, counterparty_cd);
					stmtement.setString(3, cont_no);
					stmtement.setString(4, agmt_no);
					stmtement.setString(5, contract_type);
					stmtement.setString(6, date);
					resultset=stmtement.executeQuery();
					if(resultset.next())
					{
						amt-=resultset.getDouble(1);
					}
					resultset.close();
					stmtement.close();
					
					//HOLD RELEASE
					queryString1="SELECT SUM(A.HOLD_AMT) "
							+ "FROM FMS_DLNG_INVOICE_MST A, FMS_CFORM_MST C, FMS_CFORM_DTL D "
							+ "WHERE A.COMPANY_CD=? AND A.COUNTERPARTY_CD=? AND A.CONT_NO=? AND A.AGMT_NO=? AND A.CONTRACT_TYPE=? "
							+ "AND C.CFORM_DT<=TO_DATE(?,'DD/MM/YYYY') "
							//+ "AND A.COMPANY_CD=B.COMPANY_CD AND A.INVOICE_SEQ=B.INVOICE_SEQ AND A.BU_STATE_TIN=B.BU_STATE_TIN AND A.FINANCIAL_YEAR=B.FINANCIAL_YEAR "
							+ "AND C.COMPANY_CD=D.COMPANY_CD AND C.CFORM_CD=D.CFORM_CD AND D.INVOICE_NO=A.INVOICE_NO "
							+ "AND A.COMPANY_CD=C.COMPANY_CD ";
					stmtement = conn.prepareStatement(queryString1);
					stmtement.setString(1, comp_cd);
					stmtement.setString(2, counterparty_cd);
					stmtement.setString(3, cont_no);
					stmtement.setString(4, agmt_no);
					stmtement.setString(5, contract_type);
					stmtement.setString(6, date);
					resultset=stmtement.executeQuery();
					if(resultset.next())
					{
						amt+=resultset.getDouble(1);
					}
					resultset.close();
					stmtement.close();
					
					//FFLOW ADV AMT
					queryString1="SELECT SUM(B.ADV_AMT) "
							+ "FROM FMS_DLNG_FFLOW_INV_MST A, FMS_DLNG_FFLOW_PAY_RECV_DTL B "
							+ "WHERE A.COMPANY_CD=? AND A.COUNTERPARTY_CD=? AND A.CONT_NO=? AND A.AGMT_NO=? AND A.CONTRACT_TYPE=? "
							+ "AND B.PAY_RECV_DT=TO_DATE(?,'DD/MM/YYYY') AND A.INVOICE_TYPE IN ('DR','CDR','LP','T') "
							+ "AND A.COMPANY_CD=B.COMPANY_CD AND A.INVOICE_SEQ=B.INVOICE_SEQ AND A.BU_STATE_TIN=B.BU_STATE_TIN AND A.FINANCIAL_YEAR=B.FINANCIAL_YEAR AND A.INVOICE_TYPE=B.INVOICE_TYPE ";
					stmtement1 = conn.prepareStatement(queryString1);
