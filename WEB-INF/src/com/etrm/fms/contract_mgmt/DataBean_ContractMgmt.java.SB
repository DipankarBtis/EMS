					VTRANS_PLANT_WISE_EXIT_TOTAL_MMBTU.add(nf.format(trans_plant_wise_exit_total_mmbtu));
					VTRANS_PLANT_WISE_EXIT_TOTAL_SCM.add(nf.format(trans_plant_wise_exit_total_scm));
