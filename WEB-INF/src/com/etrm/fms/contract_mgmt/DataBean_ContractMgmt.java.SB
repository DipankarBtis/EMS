					+ "AND ENTITY=? AND ADDR_FLAG=? AND JT_FLAG=? "
					+ "AND ACTIVE_FLAG=? AND ADDR_IS_ACTIVE=? "
					+ "AND TYPE=? "//AND TO_INV='Y' "
