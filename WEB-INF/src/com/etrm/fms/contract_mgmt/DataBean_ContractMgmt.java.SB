							queryString+="AND A.COUNTERPARTY_CD=? AND A.AGMT_NO=? AND A.AGMT_REV=? AND A.CONT_NO=? AND A.CONT_REV=? AND A.CONTRACT_TYPE=? AND B.CARGO_NO=? ";
						}
