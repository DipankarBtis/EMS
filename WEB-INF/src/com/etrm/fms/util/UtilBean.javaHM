	public String getCounterpartyPlantTaxInfo(String comp_cd, String entity, String counterparty_cd, String plant_seq)
	{
		String function_nm="getCounterpartyPlantTaxInfo()";
		String tax_info="";
		try
		{
			if(init())
			{
			
				query = "SELECT A.STAT_NO, TO_CHAR(A.EFF_DT,'DD/MM/YYYY'), B.STAT_NM "
						+ "FROM FMS_COUNTERPARTY_PLANT_TAX A, FMS_GOVT_STAT_TAX B "
						+ "WHERE A.COUNTERPARTY_CD=? AND A.ENTITY=? "
						+ "AND A.PLANT_SEQ_NO=? AND A.COMPANY_CD=? "
						+ "AND A.STAT_CD=B.STAT_CD AND A.COMPANY_CD=B.COMPANY_CD AND A.STAT_NO IS NOT NULL";
				stmtement = conn.prepareStatement(query);
				stmtement.setString(1, counterparty_cd);
				stmtement.setString(2, entity);
				stmtement.setString(3, plant_seq);
				stmtement.setString(4, comp_cd);
				resultset = stmtement.executeQuery();
				while(resultset.next())
				{
					String no = resultset.getString(1)==null?"":resultset.getString(1);
					String nm = resultset.getString(3)==null?"":resultset.getString(3);
	
					if(tax_info.equals(""))
					{
						tax_info+="\n"+nm+" : "+no;
					}
					else
					{
						tax_info+="\n"+nm+" : "+no;
					}
				}
				stmtement.close();
				resultset.close();
				conn.close();
			}
		}
		catch(Exception e)
		{
			new SystemErrorLogger().InsertErrorLogger(db_src_file_name, function_nm, e);
		}
		
		return tax_info;
	}
	
	//TBD
	public String getCounterpartyBuPlantTaxInfo(String comp_cd, String entity, String counterparty_cd, String plant_seq)
	{
		String function_nm="getCounterpartyBuPlantTaxInfo()";
		String tax_info="";
		try
		{
			if(init())
			{	
				query = "SELECT A.STAT_NO, TO_CHAR(A.EFF_DT,'DD/MM/YYYY'), B.STAT_NM "
						+ "FROM FMS_COUNTERPARTY_BU_TAX A, FMS_GOVT_STAT_TAX B "
						+ "WHERE A.COUNTERPARTY_CD=? AND A.ENTITY=? "
						+ "AND A.PLANT_SEQ_NO=? AND A.COMPANY_CD=? "
						+ "AND A.STAT_CD=B.STAT_CD AND A.COMPANY_CD=B.COMPANY_CD AND A.STAT_NO IS NOT NULL";
				stmtement = conn.prepareStatement(query);
				stmtement.setString(1, counterparty_cd);
				stmtement.setString(2, entity);
				stmtement.setString(3, plant_seq);
				stmtement.setString(4, comp_cd);
				resultset = stmtement.executeQuery();
				while(resultset.next())
				{
					String no = resultset.getString(1)==null?"":resultset.getString(1);
					String nm = resultset.getString(3)==null?"":resultset.getString(3);
	
					if(tax_info.equals(""))
					{
						tax_info+="\n"+nm+" : "+no;
					}
					else
					{
						tax_info+="\n"+nm+" : "+no;
					}
				}
				stmtement.close();
				resultset.close();
				conn.close();
			}
		}
		catch(Exception e)
		{
			new SystemErrorLogger().InsertErrorLogger(db_src_file_name, function_nm, e);
		}
		
		return tax_info;
	}
	
	public double getContractMigrationOffSetQty(String comp_cd,String counterparty_cd,String agmt_no,String cont_no,String contract_type,String buy_sell)
	{
		String function_nm="getContractMigrationOffSetQty()";
		double qty=0;
		try
		{
			if(init())
			{
				query="SELECT SUM(QTY_MMBTU) "
		  				+ "FROM FMS_OFFSET_ALLOCATION_DTL "
		  				+ "WHERE CONT_NO=? AND AGMT_NO=? "
						+ "AND COMPANY_CD=? AND COUNTERPARTY_CD=? "
						+ "AND CONTRACT_TYPE=? "
						+ "AND BUY_SELL = ? ";
				stmtement=conn.prepareStatement(query);
				stmtement.setString(1, cont_no);
				stmtement.setString(2, agmt_no);
				stmtement.setString(3, comp_cd);
				stmtement.setString(4, counterparty_cd);
				stmtement.setString(5, contract_type);
				stmtement.setString(6, buy_sell);
				resultset=stmtement.executeQuery();
				if(resultset.next())
				{
					qty=resultset.getDouble(1);
				}
				resultset.close();
				stmtement.close();
				conn.close();
			}
		}
		catch(Exception e)
		{
			new SystemErrorLogger().InsertErrorLogger(db_src_file_name, function_nm, e);
		}
		return qty;
	}
	
