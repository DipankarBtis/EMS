	public String getTranspoterCustomerCode(String comp_cd, String transporter_cd,String customer_cd,String customer_plant_seq,String date)
	{
		String function_nm="getTranspoterCustomerCode()";
		String customer_code="";
    	try
    	{
    		if(init())
			{
    			query="SELECT CUSTOMER_CODE "
					+ "FROM FMS_TRANSPORTER_CUST_CD A "
					+ "WHERE COMPANY_CD=? AND TRANSPORTER_CD=? "
					+ "AND COUNTERPARTY_CD=? AND PLANT_SEQ=? AND STATUS='Y' "
					+ "AND EFF_DT=(SELECT MAX(EFF_DT) FROM FMS_TRANSPORTER_CUST_CD B WHERE A.COMPANY_CD=B.COMPANY_CD "
					+ "AND A.TRANSPORTER_CD=B.TRANSPORTER_CD AND A.COUNTERPARTY_CD=B.COUNTERPARTY_CD AND A.PLANT_SEQ=B.PLANT_SEQ "
					+ "AND EFF_DT<=TO_DATE(?,'DD/MM/YYYY') AND A.STATUS=B.STATUS)";
    			stmtement = conn.prepareStatement(query);
    			stmtement.setString(1, comp_cd);
    			stmtement.setString(2, transporter_cd);
    			stmtement.setString(3, customer_cd);
    			stmtement.setString(4, customer_plant_seq);
    			stmtement.setString(5, date);
				resultset = stmtement.executeQuery();
				if(resultset.next())
				{
					customer_code=resultset.getString(1)==null?"":resultset.getString(1);
				}
				stmtement.close();
				resultset.close();
				conn.close();
			}
    	}
    	catch(Exception e)
    	{
    		new SystemErrorLogger().InsertErrorLogger(db_src_file_name, function_nm, e);
    	}
    	return customer_code;
	}

