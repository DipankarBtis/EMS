					        	queryString="INSERT INTO FMS_INV_FILE_DTL(COMPANY_CD,BU_STATE_TIN,INVOICE_SEQ,FINANCIAL_YEAR,PDF_TYPE,"
					        			+ "FILE_NAME,ENT_BY,ENT_DT) "
