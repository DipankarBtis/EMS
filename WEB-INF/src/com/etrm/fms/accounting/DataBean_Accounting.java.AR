				    	        stmt3.setString(7, financial_year);
				    	        stmt3.setString(8, "X");
			    	        	stmt3.executeUpdate();
			    	        	
			    	        	stmt3.close();
			    	        }
			    	        else
			    	        {
			    	        	queryString="INSERT INTO FMS_FFLOW_INV_FILE_DTL(COMPANY_CD,BU_STATE_TIN,INVOICE_SEQ,FINANCIAL_YEAR,PDF_TYPE,"
			    	        			+ "FILE_NAME,ENT_BY,ENT_DT,INVOICE_TYPE) "
			    	        			+ "VALUES(?,?,?,?,?,"
			    	        			+ "?,?,SYSDATE,?)";
