					        	queryString="UPDATE FMS_INV_FILE_DTL SET FILE_NAME=?,MODIFY_BY=?,MODIFY_DT=SYSDATE "
					        			+ "WHERE COMPANY_CD=? AND BU_STATE_TIN=? "
