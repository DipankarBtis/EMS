							tax_amt_usd=0;
							inv_amt_usd=0;
							tcs_amt_usd=0;
							tds_amt_usd=0;
							adj_amt_usd=0;
							netpay_amt_usd=0;
							
							adj_sign_inr=adjSign;
							adj_sign_usd="";
