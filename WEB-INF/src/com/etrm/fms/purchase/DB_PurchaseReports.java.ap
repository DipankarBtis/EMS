				{
					VGROSS_AMT_USD.add("");
				}
				if(Double.doubleToRawLongBits(tax_amt_usd)!=Double.doubleToRawLongBits(0))
				{
					VTAX_AMT_USD.add(nf2.format(tax_amt_usd));
