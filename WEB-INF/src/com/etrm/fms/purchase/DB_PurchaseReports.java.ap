							}
						}
						
						String deal_no=utilBean.NewDealMappingId(comp_cd, trader_cd, agmt_no, agmt_rev, cont_no,cont_rev, cont_type, cargo_no);
						String month=dateUtil.getMonthName(inv_dt);
						
						String disp_remittance_no = remittance_no; 
