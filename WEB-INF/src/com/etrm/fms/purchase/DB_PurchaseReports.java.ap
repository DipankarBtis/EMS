				queryString+="UNION ALL ";
				queryString+="SELECT A.COUNTERPARTY_CD,A.AGMT_NO,A.AGMT_REV,A.CONT_NO,A.CONT_REV,A.CONTRACT_TYPE,A.BU_UNIT,A.INVOICE_SEQ,A.INVOICE_NO,  "
