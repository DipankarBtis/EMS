				queryString+= "AND (SELECT COUNT(*) FROM FMS_GX_TXN_SG_INV_MST B WHERE A.COMPANY_CD=B.COMPANY_CD AND A.COUNTERPARTY_CD=B.COUNTERPARTY_CD "
