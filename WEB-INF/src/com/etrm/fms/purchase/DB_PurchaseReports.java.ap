					queryString+="AND INV_FLAG IN ('UG','F') ";
				}
				else
				{
					queryString+="AND INV_FLAG IN ('P','F','CR','DR') ";
				}
				queryString+="UNION ALL ";
				
				queryString+="SELECT INVOICE_SEQ,INVOICE_REF,TO_CHAR(INVOICE_DT,'DD/MM/YYYY'),"
