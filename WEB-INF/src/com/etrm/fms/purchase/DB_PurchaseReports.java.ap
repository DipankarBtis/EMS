					+ "Y.ACT_BOE_QTY,(NVL(Y.BOE_FINAL_PRICE,0)-NVL(Y.BOE_PROVISIONAL_PRICE,0)),Y.BOE_FINAL_PRICE_UNIT,E.INVOICE_CUR_CD,E.EXCHNG_RATE_CD,E.EXCHNG_RATE_CAL,E.EXCHG_VAL,"
					+ "B.CARGO_NO,Y.BU_SEQ,Y.PLANT_SEQ,Y.BOE_NO,0,'F' "
