	public void revokePriceForAllDeal() {
		String function_nm = "revokePriceForAllDeal()";
		try {
		//	System.out.println("REVOKE: "+function_nm);
			CountPriceExistNo=0;
			msg="";
			for (int i = 0; i < VCOUNTERPARTY_ABBR.size(); i++) {
				
//				System.out.println(">>"+i);
				
				if (VBUY_SALE.elementAt(i).toString().equals("Sell") && chkUpdateFlag.split(":")[i].equals("Y")) {
					String chkAprvPrice = "SELECT A.MODIFICATION_SEQ_NO, A.FLAG, A.PUR_CONT, A.CARGO_NO, A.NEW_SALE_PRICE, TO_CHAR(A.NEW_PRICE_EFF_DT, 'DD/MM/YYYY'), A.ORI_SALE_PRICE FROM FMS_SUPPLY_ALLOC_REVISED A "
							+ " WHERE A.COMPANY_CD = ? AND A.COUNTERPARTY_CD = ? AND A.AGMT_NO = ? AND  A.AGMT_REV = ? AND A.CONT_NO = ? AND A.CONTRACT_TYPE = ? "
//							+ " AND A.PUR_CONT_NO = (SELECT B.PUR_CONT_NO FROM FMS_SUPPLY_PURCHASE_MAP_DTL B WHERE A.COMPANY_CD = B.COMPANY_CD AND A.COUNTERPARTY_CD = B.COUNTERPARTY_CD AND "
//							+ " A.AGMT_NO = B.AGMT_NO AND A.AGMT_REV = B.AGMT_REV AND A.CONT_NO = B.CONT_NO AND A.CONT_REV = B.CONT_REV AND A.CONTRACT_TYPE = B.CONTRACT_TYPE ) "
							+ " AND A.MODIFICATION_SEQ_NO = (SELECT MAX(C.MODIFICATION_SEQ_NO) FROM FMS_SUPPLY_ALLOC_REVISED C WHERE A.COMPANY_CD = C.COMPANY_CD AND A.COUNTERPARTY_CD = C.COUNTERPARTY_CD AND "
							+ " A.AGMT_NO = C.AGMT_NO AND A.AGMT_REV = C.AGMT_REV AND A.CONT_NO = C.CONT_NO AND A.CONT_REV = C.CONT_REV AND A.CONTRACT_TYPE = C.CONTRACT_TYPE ) ";
					stmt = conn.prepareStatement(chkAprvPrice);
					stmt.setString(1, comp_cd);
					stmt.setString(2, VCOUNTERPARTY_CD.elementAt(i).toString());
					stmt.setString(3, VAGMT_NO.elementAt(i).toString());
					stmt.setString(4, VAGMT_REV.elementAt(i).toString());
					stmt.setString(5, VCONT_NO.elementAt(i).toString());
//					stmt.setString(6, VCONT_REV.elementAt(i).toString());
					stmt.setString(6, VCONTRACT_TYPE.elementAt(i).toString());
					rset = stmt.executeQuery();
					
					if (rset.next()) {
						if (rset.getString(2).equals("A")) {
							String remark = "(" + rset.getString(5) + ") Approved Price dated " + rset.getString(6) + " (Revoked) " ;
							
							String updPrice = "UPDATE FMS_SUPPLY_ALLOC_REVISED SET FLAG = ?, APPROVE_BY = NULL, APPROVE_DT = NULL, REMARK = ? "
									+ " WHERE COMPANY_CD = ? AND COUNTERPARTY_CD = ? AND AGMT_NO = ? AND AGMT_REV = ? AND CONT_NO = ? AND CONTRACT_TYPE = ? AND MODIFICATION_SEQ_NO = ? "
									+ " AND PUR_CONT = ? AND CARGO_NO = ? ";
							stmt1 = conn.prepareStatement(updPrice);
							stmt1.setString(1, "R");
							stmt1.setString(2, remark);
							stmt1.setString(3, comp_cd);
							stmt1.setString(4, VCOUNTERPARTY_CD.elementAt(i).toString());
							stmt1.setString(5, VAGMT_NO.elementAt(i).toString());
							stmt1.setString(6, VAGMT_REV.elementAt(i).toString());
							stmt1.setString(7, VCONT_NO.elementAt(i).toString());
							stmt1.setString(8, VCONTRACT_TYPE.elementAt(i).toString());
							stmt1.setString(9, rset.getString(1));
							stmt1.setString(10, rset.getString(3));
							stmt1.setString(11, rset.getString(4));
							stmt1.executeUpdate();
							
							stmt1.close();
							
							updPrice = "UPDATE FMS_SUPPLY_CONT_MST SET PRICE_REQUEST_FLAG = ?, PRICE_APPROVE_FLAG = ?, RATE = ?  "
									+ ", FCC_FLAG=null, FCC_BY=null,FCC_DATE=null, CONT_STATUS='P' "
									+ " WHERE COMPANY_CD = ? AND COUNTERPARTY_CD = ? AND AGMT_NO = ? AND AGMT_REV = ? AND CONT_NO = ? AND CONT_REV = ? AND CONTRACT_TYPE = ? ";
							
							stmt1 = conn.prepareStatement(updPrice);
							stmt1.setString(1, "Y");
							stmt1.setString(2, "N");
							stmt1.setString(3, rset.getString(7));
							stmt1.setString(4, comp_cd);
							stmt1.setString(5, VCOUNTERPARTY_CD.elementAt(i).toString());
							stmt1.setString(6, VAGMT_NO.elementAt(i).toString());
							stmt1.setString(7, VAGMT_REV.elementAt(i).toString());
							stmt1.setString(8, VCONT_NO.elementAt(i).toString());
							stmt1.setString(9, VCONT_REV.elementAt(i).toString());
							stmt1.setString(10, VCONTRACT_TYPE.elementAt(i).toString());
							stmt1.executeUpdate();
						
							stmt1.close();
							
