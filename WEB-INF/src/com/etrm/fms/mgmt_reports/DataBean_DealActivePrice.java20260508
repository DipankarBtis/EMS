			//	System.out.println(i+")"+VBILL_FREQ.elementAt(i)+"VBILL_FREQ_DT"+VBILL_FREQ_DT.elementAt(i));
				NEW_PRICE_EFF_DT = "";
				if (VBUY_SALE.elementAt(i).toString().equals("Sell") && chkUpdateFlag.split(":")[i].equals("Y")) {
					msg +=VCOUNTERPARTY_ABBR.elementAt(i);
					String fetchSalesDeal = "SELECT NVL(PRICE_REQUEST_FLAG, 'N'), NVL(PRICE_APPROVE_FLAG, 'N'), CONT_NAME, CONT_REV+1 , RATE " //SB20260303 added RATE
							+ "FROM FMS_SUPPLY_CONT_MST "
							+ "WHERE COMPANY_CD = ? AND COUNTERPARTY_CD = ? AND AGMT_NO = ? AND AGMT_REV = ? AND CONT_NO = ? AND CONT_REV = ? AND CONTRACT_TYPE = ? ";
					stmt = conn.prepareStatement(fetchSalesDeal);
					stmt.setString(1, comp_cd);
					stmt.setString(2, VCOUNTERPARTY_CD.elementAt(i).toString());
					stmt.setString(3, VAGMT_NO.elementAt(i).toString());
					stmt.setString(4, VAGMT_REV.elementAt(i).toString());
					stmt.setString(5, VCONT_NO.elementAt(i).toString());
					stmt.setString(6, VCONT_REV.elementAt(i).toString());
					stmt.setString(7, VCONTRACT_TYPE.elementAt(i).toString());
					rset = stmt.executeQuery();
					appPrice="*";
					if (rset.next() && (rset.getString(1).equals("N"))) {
						
			//			System.out.println(rset.getString(3)+"PRICE_REQUEST_FLAG: "+rset.getString(1));
						String ContName = rset.getString(3)==null?"":rset.getString(3);
						String modSeq = "1";  String NEW_SALE_PRICE = "0";  String PriceExist="";
						String fetchLastPriceDate = "SELECT TO_CHAR(NEW_PRICE_EFF_DT,'DD/MM/YYYY'), NEW_SALE_PRICE FROM FMS_SUPPLY_ALLOC_REVISED A  "
								+ " WHERE A.COMPANY_CD = ? AND A.COUNTERPARTY_CD = ? AND A.AGMT_NO = ? AND A.AGMT_REV = ? AND A.CONT_NO = ? AND A.CONTRACT_TYPE = ? "
								+ "AND A.MODIFICATION_SEQ_NO = (SELECT MAX(B.MODIFICATION_SEQ_NO) FROM FMS_SUPPLY_ALLOC_REVISED B "
								+ "WHERE A.COMPANY_CD = B.COMPANY_CD AND A.COUNTERPARTY_CD = B.COUNTERPARTY_CD AND A.AGMT_NO = B.AGMT_NO AND A.AGMT_REV = B.AGMT_REV AND A.CONT_NO = B.CONT_NO AND A.CONTRACT_TYPE = B.CONTRACT_TYPE "
								+ "AND B.NEW_PRICE_EFF_DT<=TO_DATE(?,'DD/MM/YYYY') )";
					//	System.out.println(VCONTRACT_TYPE.elementAt(i)+":"+VCOUNTERPARTY_CD.elementAt(i)+"-"+VAGMT_NO.elementAt(i)+"-"+VAGMT_REV.elementAt(i)+"-"+VCONT_NO.elementAt(i)+"-"+PriceEffDate+":fetchLastPriceDate: "+fetchLastPriceDate);
						stmt2 = conn.prepareStatement(fetchLastPriceDate);
						stmt2.setString(1, comp_cd);
						stmt2.setString(2, VCOUNTERPARTY_CD.elementAt(i).toString());
						stmt2.setString(3, VAGMT_NO.elementAt(i).toString());
						stmt2.setString(4, VAGMT_REV.elementAt(i).toString());
						stmt2.setString(5, VCONT_NO.elementAt(i).toString());
						stmt2.setString(6, VCONTRACT_TYPE.elementAt(i).toString());
						stmt2.setString(7, ""+PriceEffDate);
						rset2 = stmt2.executeQuery();
						
