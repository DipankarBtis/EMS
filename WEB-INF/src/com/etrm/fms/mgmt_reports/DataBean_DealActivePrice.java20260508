	// SagarB20251229 Function to Fetch Physical Curve for Variable Pricing
	public void getPhysicalCurveMaster()
	{
		String function_nm="getPhysicalCurveMaster()";
		try
		{
			String queryString="SELECT DISTINCT CURVE_NM "
					+ "FROM FMS_FORWARD_PRICE_DTL "
					+ "WHERE UPPER(PHYS_FIN)=?";
			stmt = conn.prepareStatement(queryString);
			stmt.setString(1, "PHYSICAL");
			rset=stmt.executeQuery();
			while(rset.next())
			{
				VPHYSICAL_CURVE_MST.add(rset.getString(1)==null?"":rset.getString(1));
			}
			rset.close();
			stmt.close();
		}
		catch(Exception e)
		{
			new SystemErrorLogger().InsertErrorLogger(db_src_file_name, function_nm, e);
		}
	}
	
	// SagarB20251229 Function to Fetch Financial Curve for Variable Pricing
	public void getFinancialCurveMaster()
	{
		String function_nm="getFinancialCurveMaster()";
		try
		{
			String queryString="SELECT DISTINCT CURVE_NM "
					+ "FROM FMS_FORWARD_PRICE_DTL "
					+ "WHERE UPPER(PHYS_FIN)=? "
					+ "ORDER BY CURVE_NM ";
			stmt = conn.prepareStatement(queryString);
			stmt.setString(1, "FINANCIAL");
			rset=stmt.executeQuery();
			while(rset.next())
			{
				VFINANCIAL_CURVE_MST.add(rset.getString(1)==null?"":rset.getString(1));
			}
			rset.close();
			stmt.close();
		}
		catch(Exception e)
		{
			new SystemErrorLogger().InsertErrorLogger(db_src_file_name, function_nm, e);
		}
	}

	// SagarB20251229 Function to get Price Range Name for Variable Pricing
	public String getPriceRangeNm(String price_range, String price_st_dt, String price_end_dt)
	{
		String function_nm="getPriceRangeNm()";
		String nm="";
		try
		{
			if(price_range.equals("A"))
			{
				nm="Avg.";
			}
			else if(price_range.equals("F"))
			{
				nm="Final Settle Date";
			}
			if(price_range.startsWith("O"))
			{
				nm="Other Avg.("+price_range.substring(1,price_range.length())+")";
			}
			if(price_range.equals("D"))
			{
				nm="Avg. Settle Date("+price_st_dt+" - "+price_end_dt+")";
			}
		}
		catch(Exception e)
		{
			new SystemErrorLogger().InsertErrorLogger(db_src_file_name, function_nm, e);
		}
		return nm;
	}
	
	public String getBillingFreq(String compCd, String CParty, String agmtNo, String agmtRevNo, String contNo, String contRevNo, String contType, String rptDt)
	{
		/////////////////////Get the list of Billing Cycle////////////////////
		String function_nm="getBillingFreq()";
		String nm="";
		try
		{
		String BillFreq="F"; String PlantSeqNo="1";
		String PriceEffDate=rptDt;
		String tempStartDate[]=PriceEffDate.split("/");
		String GenDate=tempStartDate[0]; 
		String GenMth=tempStartDate[1]; 
		String GenYr=tempStartDate[2]; 
		String GenMthYr=GenMth+"/"+GenYr;
		PriceEffDate="01/"+GenMthYr;//SB20260101

		String queryBilling = "SELECT BILLING_FREQ, BILLING_FLAG, PLANT_SEQ_NO FROM FMS_SUPPLY_BILLING_DTL "
			+ "WHERE COMPANY_CD = ? AND COUNTERPARTY_CD = ? AND AGMT_NO = ? AND AGMT_REV = ? AND CONT_NO = ?  AND CONTRACT_TYPE = ? "//AND EFF_DT <= TO_DATE(?, 'DD/MM/YYYY') "
		//	+ "AND CONT_REV = ? "
			+"AND EFF_DT =(SELECT MAX(EFF_DT) FROM FMS_SUPPLY_BILLING_DTL "
			+"WHERE COMPANY_CD = ? AND COUNTERPARTY_CD = ? AND AGMT_NO = ? AND AGMT_REV = ? AND CONT_NO = ?  AND CONTRACT_TYPE = ? " 
			+"AND EFF_DT <= TO_DATE(?, 'DD/MM/YYYY')) "
			+ "ORDER BY EFF_DT DESC ";
	//	System.out.println(contType+contNo+":"+contRevNo+":"+queryBilling);
		stmt3 = conn.prepareStatement(queryBilling);		
		stmt3.setString(1, compCd);
		stmt3.setString(2, CParty);
		stmt3.setString(3, agmtNo);
		stmt3.setString(4, agmtRevNo);
		stmt3.setString(5, contNo);
		stmt3.setString(6, contType);
		stmt3.setString(7, compCd);
		stmt3.setString(8, CParty);
		stmt3.setString(9, agmtNo);
		stmt3.setString(10, agmtRevNo);
		stmt3.setString(11, contNo);
		stmt3.setString(12, contType);
		stmt3.setString(13, rptDt);
	//	stmt3.setString(8, contRevNo);
		rset3 = stmt3.executeQuery();	
		if (rset3.next()) {
			BillFreq = rset3.getString(1)==null?"F":rset3.getString(1); 
			PlantSeqNo= rset3.getString(3)==null?"1*":rset3.getString(3); 
		//	System.out.println(contType+contNo+":"+contRevNo+":11:"+BillFreq);
		}
		rset3.close();
		stmt3.close();//System.out.println(contType+contNo+":"+contRevNo+":22:"+BillFreq);
			if(BillFreq.equals("F"))
			{
				nm="Fortnightly";
				if(Integer.parseInt(GenDate)>15)
					PriceEffDate="16/"+GenMthYr;
			}
			else if(BillFreq.equals("W"))
			{
				nm="Weekly";
				if(Integer.parseInt(GenDate)>0 && Integer.parseInt(GenDate)<8)
					{PriceEffDate="01/"+GenMthYr;}
				else if(Integer.parseInt(GenDate)>7 && Integer.parseInt(GenDate)<15)
					{PriceEffDate="08/"+GenMthYr;}
				else if(Integer.parseInt(GenDate)>14 && Integer.parseInt(GenDate)<22)
					{PriceEffDate="15/"+GenMthYr;}
				else if(Integer.parseInt(GenDate)>21 && Integer.parseInt(GenDate)<29)
					{PriceEffDate="22/"+GenMthYr;}
				else if(Integer.parseInt(GenDate)>28)
					{PriceEffDate="29/"+GenMthYr;}
			}
			else if(BillFreq.startsWith("M"))
			{
				nm="Monthly";
			}
			else if(BillFreq.equals("D"))
			{
				nm="Daily";
				PriceEffDate=rpt_dt;
			}
			else
			{
				nm="NA";
			}
			nm="P"+PlantSeqNo+": "+nm;
	
				VBILL_FREQ.add(nm);
				VBILL_FREQ_DT.add(PriceEffDate);
				return PriceEffDate;
		}
		catch(Exception e)
		{
			new SystemErrorLogger().InsertErrorLogger(db_src_file_name, function_nm, e);
		}
		return nm;
	}
	public String getBillingFreqTrd(String compCd, String CParty, String agmtNo, String agmtRevNo, String contNo, String contRevNo, String contType, String rptDt)
	{
		/////////////////////Get the list of Billing Cycle////////////////////
		String function_nm="getBillingFreqTrd()";
		String nm="";
		try
		{
		String BillFreq="F"; String PlantSeqNo="";
		String PriceEffDate=rptDt;
		String tempStartDate[]=PriceEffDate.split("/");
		String GenDate=tempStartDate[0]; 
		String GenMth=tempStartDate[1]; 
		String GenYr=tempStartDate[2]; 
		String GenMthYr=GenMth+"/"+GenYr;
		PriceEffDate="01/"+GenMthYr;//SB20260101

		String queryBilling = "SELECT BILLING_FREQ, BILLING_FLAG, PLANT_SEQ_NO FROM FMS_TRADER_BILLING_DTL "
			+ "WHERE COMPANY_CD = ? AND COUNTERPARTY_CD = ? AND AGMT_NO = ? AND AGMT_REV = ? AND CONT_NO = ?  AND CONTRACT_TYPE = ? "//AND EFF_DT <= TO_DATE(?, 'DD/MM/YYYY') "
		//	+ "AND CONT_REV = ? "
			+"AND ENT_DT =(SELECT MAX(ENT_DT) FROM FMS_TRADER_BILLING_DTL "
			+"WHERE COMPANY_CD = ? AND COUNTERPARTY_CD = ? AND AGMT_NO = ? AND AGMT_REV = ? AND CONT_NO = ?  AND CONTRACT_TYPE = ? " 
			+"AND ENT_DT <= TO_DATE(?, 'DD/MM/YYYY')) "
			+ "ORDER BY ENT_DT DESC ";
	//	System.out.println(contType+contNo+":"+contRevNo+":"+queryBilling);
		stmt3 = conn.prepareStatement(queryBilling);		
		stmt3.setString(1, compCd);
		stmt3.setString(2, CParty);
		stmt3.setString(3, agmtNo);
		stmt3.setString(4, agmtRevNo);
		stmt3.setString(5, contNo);
		stmt3.setString(6, contType);
		stmt3.setString(7, compCd);
		stmt3.setString(8, CParty);
		stmt3.setString(9, agmtNo);
		stmt3.setString(10, agmtRevNo);
		stmt3.setString(11, contNo);
		stmt3.setString(12, contType);
		stmt3.setString(13, rptDt);
	//	stmt3.setString(8, contRevNo);
		rset3 = stmt3.executeQuery();	
		if (rset3.next()) {
			BillFreq = rset3.getString(1)==null?"F":rset3.getString(1); 
			PlantSeqNo= rset3.getString(3)==null?"1*":rset3.getString(3); 
		}
		rset3.close();
		stmt3.close();
			if(BillFreq.equals("F"))
			{
				nm="Fortnightly";
				if(Integer.parseInt(GenDate)>15)
					PriceEffDate="16/"+GenMthYr;
			}
			else if(BillFreq.equals("W"))
			{
				nm="Weekly";
				if(Integer.parseInt(GenDate)>0 && Integer.parseInt(GenDate)<8)
					{PriceEffDate="01/"+GenMthYr;}
				else if(Integer.parseInt(GenDate)>7 && Integer.parseInt(GenDate)<15)
					{PriceEffDate="08/"+GenMthYr;}
				else if(Integer.parseInt(GenDate)>14 && Integer.parseInt(GenDate)<22)
					{PriceEffDate="15/"+GenMthYr;}
				else if(Integer.parseInt(GenDate)>21 && Integer.parseInt(GenDate)<29)
					{PriceEffDate="22/"+GenMthYr;}
				else if(Integer.parseInt(GenDate)>28)
					{PriceEffDate="29/"+GenMthYr;}
			}
			else if(BillFreq.startsWith("M"))
			{
				nm="Monthly";
			}
			else if(BillFreq.equals("D"))
			{
				nm="Daily";
				PriceEffDate=rpt_dt;
			}
			else
			{
				nm="NA";
			}
			nm="P"+PlantSeqNo+": "+nm;
		
				VBILL_FREQ.add(nm);
				VBILL_FREQ_DT.add(PriceEffDate);
				return PriceEffDate;
			
		}
		catch(Exception e)
		{
			new SystemErrorLogger().InsertErrorLogger(db_src_file_name, function_nm, e);
		}
		return nm;
	}

	public void InsertEmailRecipientConfigForActiveDealPrice() 
	{
		String function_nm="InsertEmailRecipientConfigForActiveDealPrice()";
		try
		{
			int count=0;
			String queryString ="SELECT COUNT(MENU_NAME) " 
				 		+ "FROM FMS_EMAIL_SUPPORT_MST  "
				 		+ "WHERE MENU_NAME='Active Deal Price' ";
		//	System.out.println("FMS9_REPORT_SUPPORT_MST: "+queryString);
				stmt= conn.prepareStatement(queryString);
			rset = stmt.executeQuery();
			if(rset.next())
			{				
				count=rset.getInt(1);
			}
			rset1.close();
			stmt1.close();
			if(count==0)
			{
				queryString="INSERT INTO FMS_EMAIL_SUPPORT_MST (MODULE_NAME,MENU_NAME,REPORT_FREQ,GENERATION_TYPE,SUPPORT_FLAG,SEQ_NO) "
						+ "VALUES ('Mgmt Reports','Active Deal Price','NA','On-Event','Y','1')  ";
				System.out.println("FMS9_REPORT_SUPPORT_MST: "+queryString);
				stmt= conn.prepareStatement(queryString);
				stmt.executeUpdate();
				conn.commit();
				stmt.close();
				System.out.println("Active Deal Price: New entry created in FMS_EMAIL_SUPPORT_MST .............. ");
			}
			else
			{
				ToEmail = utilBean.getToMailReceipentList(conn,comp_cd,"Active Deal Price", "Mgmt Reports", "NA", "On-Event");
			//	ToEmail += utilBean.getCcMailReceipentList(conn,comp_cd,"Active Deal Price", "Mgmt Reports", "NA", "On-Event");
				System.out.println("Active Deal Price:: Exists in FMS_EMAIL_SUPPORT_MST .............. ");
			}
		}
		catch(Exception e)
		{
			new SystemErrorLogger().InsertErrorLogger(db_src_file_name, function_nm, e);

		}	
	}
