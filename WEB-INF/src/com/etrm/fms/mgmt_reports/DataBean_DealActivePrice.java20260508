	public void getExchangeRate() {
		String function_nm = "getExchangeRate()";
		
		try {
			
			String fetchExchngVal = "SELECT NVL(B.EXCHG_VAL, 0) FROM FMS_EXCHG_RATE_MST A, FMS_EXCHG_RATE_ENTRY B "
					+ " WHERE A.EXC_RATE_CD = B.EXCHG_RATE_CD AND A.EXC_RATE_NM = 'SHELL TREASURY RATE' ORDER BY EFF_DT DESC";
			stmt = conn.prepareStatement(fetchExchngVal);
			rset = stmt.executeQuery();
			
			if (rset.next()) {
				exchgVal = rset.getString(1);
			}
			rset.close();
			stmt.close();
			
		}
		catch (Exception e) {
			new SystemErrorLogger().InsertErrorLogger(db_src_file_name, function_nm, e);
		}
	}
	
	// SagarB20251202 Below Function Added For Active Deal Pricing
	public void getSalesActiveDeals() {
		String function_nm = "getSalesActiveDeals()";
		
		try {
			String AprvDate="", ApplDate="";
		String CounterPartyCd="";
			ContMthYr=""; 
			String query2 = "SELECT TO_CHAR(TO_DATE(?,'DD/MM/YYYY'),'MON-YYYY') FROM DUAL";//SB20230304
			stmt = conn.prepareStatement(query2);
			stmt.setString(1, rpt_dt);
			rset = stmt.executeQuery();
			if (rset.next()) {
				ContMthYr=rset.getString(1) == null ? "" : rset.getString(1);
			}
			rset.close();
			stmt.close();
			// Queries in loop
			String query = "SELECT PRICE_TYPE, PHYS_CURVE_NM FROM FMS_CONT_PRICE_DTL WHERE COMPANY_CD = ? AND CONTRACT_TYPE = ? AND MAPPING_ID = ? ";
			stmt = conn.prepareStatement(query);
			
			String queryApprove = "SELECT NEW_SALE_PRICE, NVL(TO_CHAR(NEW_PRICE_EFF_DT, 'DD/MM/YYYY'), 'NA') FROM FMS_SUPPLY_ALLOC_REVISED WHERE COMPANY_CD = ? AND COUNTERPARTY_CD = ? AND AGMT_NO = ? AND AGMT_REV = ? AND CONT_NO = ? AND CONTRACT_TYPE = ? AND FLAG = 'A' AND NEW_PRICE_EFF_DT <= TO_DATE(?, 'DD/MM/YYYY') ORDER BY NEW_PRICE_EFF_DT DESC, MODIFICATION_SEQ_NO DESC";
			stmt1 = conn.prepareStatement(queryApprove);
			
			String queryRequest = "SELECT NEW_SALE_PRICE, NVL(TO_CHAR(NEW_PRICE_EFF_DT, 'DD/MM/YYYY'), 'NA') FROM FMS_SUPPLY_ALLOC_REVISED WHERE COMPANY_CD = ? AND COUNTERPARTY_CD = ? AND AGMT_NO = ? AND AGMT_REV = ? AND CONT_NO = ? AND CONTRACT_TYPE = ? AND FLAG = 'R' AND NEW_PRICE_EFF_DT <= TO_DATE(?, 'DD/MM/YYYY') ORDER BY NEW_PRICE_EFF_DT DESC, MODIFICATION_SEQ_NO DESC";
			stmt2 = conn.prepareStatement(queryRequest);

			String query0 = "SELECT DISTINCT A.COUNTERPARTY_CD, B.COUNTERPARTY_ABBR, B.COUNTERPARTY_NM FROM FMS_SUPPLY_CONT_MST A, FMS_COUNTERPARTY_MST B "
					+ " WHERE A.COMPANY_CD = ? AND A.START_DT <= TO_DATE(?, 'DD/MM/YYYY') AND A.END_DT >= TO_DATE(?, 'DD/MM/YYYY') "
					+ " AND A.COUNTERPARTY_CD = B.COUNTERPARTY_CD "
					+ " ORDER BY B.COUNTERPARTY_ABBR ";
			
			stmt0 = conn.prepareStatement(query0);
			stmt0.setString(1, comp_cd);
			stmt0.setString(2, rpt_dt);
			stmt0.setString(3, rpt_dt);
			rset0 = stmt0.executeQuery();
			
			while (rset0.next()) {
				VMST_COUNTERPARTY_CD.add(rset0.getString(1) == null ? "" : rset0.getString(1));
				VMST_COUNTERPARTY_ABBR.add(rset0.getString(2) == null ? "" : rset0.getString(2));
				VMST_COUNTERPARTY_NM.add(rset0.getString(3) == null ? "" : rset0.getString(3));
			}
			rset0.close();
			stmt0.close();
			
			
			
			query0 = "SELECT B.COUNTERPARTY_ABBR, B.COUNTERPARTY_NM, A.AGMT_NO, A.AGMT_REV, A.CONT_NO, A.CONT_REV, NVL(A.CONTRACT_TYPE, '0'), "
					+ " A.CONT_REF_NO, TO_CHAR(A.SIGNING_DT, 'DD/MM/YYYY'), TO_CHAR(A.START_DT, 'DD/MM/YYYY'), TO_CHAR(A.END_DT, 'DD/MM/YYYY'), 'FIXED', RATE, RATE_UNIT, '-', 'RLNG_PHYS_INDIA', A.COUNTERPARTY_CD, A.CONT_STATUS, A.COUNTERPARTY_CD "
					+ " FROM FMS_SUPPLY_CONT_MST A, FMS_COUNTERPARTY_MST B "
					+ " WHERE A.COMPANY_CD = ? AND A.START_DT <= TO_DATE(?, 'DD/MM/YYYY') AND A.END_DT >= TO_DATE(?, 'DD/MM/YYYY') AND A.CONT_REV = (SELECT MAX(C.CONT_REV) FROM FMS_SUPPLY_CONT_MST C WHERE A.COMPANY_CD = C.COMPANY_CD AND A.COUNTERPARTY_CD = C.COUNTERPARTY_CD AND "
					+ " A.AGMT_NO = C.AGMT_NO AND A.AGMT_REV = C.AGMT_REV AND A.CONT_NO = C.CONT_NO AND A.CONTRACT_TYPE = C.CONTRACT_TYPE) "
					+ " AND A.COUNTERPARTY_CD = B.COUNTERPARTY_CD AND B.EFF_DT = (SELECT MAX(C.EFF_DT) FROM FMS_COUNTERPARTY_MST C WHERE B.COUNTERPARTY_CD = C.COUNTERPARTY_CD ) "
			//SB20260309		+ " AND A.CONT_STATUS !='X' "
			//SB20260407		+ " AND A.CONT_STATUS='Y' "; //SB20260309
			+ " AND A.CONT_STATUS IN ('Y', 'P') "; //SB20260407 //SB20260309
			if (counterparty_cd != null && !counterparty_cd.equals("0")) {
					query0 += " AND A.COUNTERPARTY_CD = ?";
			}
			query0 += " ORDER BY B.COUNTERPARTY_NM, B.COUNTERPARTY_ABBR ";
		//	System.out.println(rpt_dt+":"+query0);
			stmt0 = conn.prepareStatement(query0);
			stmt0.setString(1, comp_cd);
			stmt0.setString(2, rpt_dt);
			stmt0.setString(3, rpt_dt);		
			if (counterparty_cd != null && !counterparty_cd.equals("0")) {
				stmt0.setString(4, counterparty_cd);
			}		
			rset0 = stmt0.executeQuery();
			while (rset0.next()) {				
				// Assigning Variables 
				agmt_no = rset0.getString(3);
				agmt_rev = rset0.getString(4);
				cont_no = rset0.getString(5);
				cont_rev = rset0.getString(6);
				cont_type = rset0.getString(7);
				CounterPartyCd=rset0.getString(19);
				
				priceType = "Fixed";
				appPrice = "-";
				appDate = "-";
				finCurv = "-";
				physCurv = "-";
				ApplDate=getBillingFreq(comp_cd, rset0.getString(17), agmt_no, agmt_rev, cont_no, cont_rev, cont_type, rpt_dt);
				getContDtlFinBreakUp("Sell", rset0.getString(17) + "-" + agmt_no + "-" + cont_no); // New function for calculating applicable price
				
				String cont_status = rset0.getString(18);
				if (rset0.getString(18).equals("Y")) {
					cont_status = "Approved";
				}
				else if (rset0.getString(18).equals("C")) {
					cont_status = "Closed";
				}
				else if (rset0.getString(18).equals("P")) {
					cont_status = "Pending Approval";
				}
				else if (rset0.getString(18).equals("F")) {
					cont_status = "New";
				}
				else if (rset0.getString(18).equals("T")) {
					cont_status = "Terminated";
				}
				
				String deal_type = "-";
				if (rset0.getString(7).equals("F")) {
					deal_type = "DLNG-SN";
				}
				else if (rset0.getString(7).equals("E")) {
					deal_type = "DLNG-LOA";
				}
				else if (rset0.getString(7).equals("W")) {
					deal_type = "DLNG-IGX";
				}
				else if (rset0.getString(7).equals("S")) {
					deal_type = "RLNG-SN";
				}
				else if (rset0.getString(7).equals("L")) {
					deal_type = "RLNG-LOA";
				}
				else if (rset0.getString(7).equals("X")) {
					deal_type = "RLNG-IGX";
				}
				
				String dealMapId = utilBean.NewDealMappingId(comp_cd, CounterPartyCd, agmt_no, agmt_rev, cont_no, cont_rev, cont_type, "");

				// Below block is for deciding Approved Current Price
				rate_unit = rset0.getString(14) == null ? "-" : rset0.getString(14);
				String apprv_rate = rset0.getString(13) == null ? "" : rset0.getString(13);
				if (rate_unit.equals("1")) {
					// rate_unit = "Rs./MMBTU";
					rate_unit = "INR";
				}
				else {
					// rate_unit = "$/MMBTU";
					rate_unit = "USD";
				}
			
				stmt1.setString(1, comp_cd);
				stmt1.setString(2, rset0.getString(17));
				stmt1.setString(3, agmt_no);
				stmt1.setString(4, agmt_rev);
				stmt1.setString(5, cont_no);
//				stmt1.setString(6, cont_rev);
				stmt1.setString(6, cont_type);
				stmt1.setString(7, rpt_dt);
				rset1 = stmt1.executeQuery();
				
				if (rset1.next()) {
					if (!rset1.getString(2).equals("NA"))
						AprvDate=rset1.getString(2);
				}
				else
					AprvDate=rset0.getString(10);
				
			//	System.out.println(appPrice+"::==::"+apprv_rate+"####"+ApplDate+":"+VBILL_FREQ_DT);
				
				int NoDays=0;
				String queryString = "SELECT TO_DATE(?,'DD/MM/YYYY')-TO_DATE(?,'DD/MM/YYYY') FROM DUAL" ;//SB20230721: Removed +1 day
				//	System.out.println(rset1.getString(2)+" DUAL: LAST: "+queryString);
					stmt3 = conn.prepareStatement(queryString);
			    	stmt3.setString(1, AprvDate);
	       			stmt3.setString(2, ApplDate);//"01"+rpt_dt.substring(2));
		   			rset3 = stmt3.executeQuery();
					if(rset3.next()) {
						NoDays = rset3.getInt(1);  //For Physical
					}
					rset3.close();
					stmt3.close();
		//	if(appPrice.equals(apprv_rate) && NoDays==0)
			if(!appPrice.equals("") && !appPrice.equals("-"))
			{
				//SB20260309 if(Double.parseDouble(appPrice)==Double.parseDouble(apprv_rate) && NoDays<=0)
				if(BigDecimal.valueOf(Double.parseDouble(appPrice)).compareTo(BigDecimal.valueOf(Double.parseDouble(apprv_rate)))==0 && NoDays<=0)
					VPriceAppl.add("Y");
				else
					VPriceAppl.add("N");
			}
			else
				VPriceAppl.add("N");
			appPrice=appPrice+" "+rate_unit;
			//////////////////^^^^^^^^^^^^^//////////////////////
			apprv_rate = apprv_rate + " " + rate_unit;// + " <br> (" + AprvDate + ")";
				// Below block is for deciding Awaiting For Approval Price
				String req_rate = "";
				
				stmt2.setString(1, comp_cd);
				stmt2.setString(2, rset0.getString(17));
				stmt2.setString(3, agmt_no);
				stmt2.setString(4, agmt_rev);
				stmt2.setString(5, cont_no);
//				stmt2.setString(6, cont_rev);
				stmt2.setString(6, cont_type);
				stmt2.setString(7, rpt_dt);
				rset2 = stmt2.executeQuery();
				
				if (rset2.next()) {
					req_rate = rset2.getString(1) + " " + rate_unit ;
					if (!rset2.getString(2).equals("NA")) {
						req_rate += " <br> [" + rset2.getString(2) + "]";
					}
				}
			
				if (physCurv.equals("-") && (cont_type.equals("E") || cont_type.equals("F") || cont_type.equals("W"))) //For DLNG Deals
				{
					physCurv = "LNG_PHYS_INDIA";
				}
				else if (physCurv.equals("-")) //For All Sales Deal S/L/X
					physCurv = "RLNG_PHYS_INDIA";
				// Assigning Vectors
				VCOUNTERPARTY_CD.add(rset0.getString(17));
				VCOUNTERPARTY_ABBR.add(rset0.getString(1));
				VCOUNTERPARTY_NM.add(rset0.getString(2));
				VDEAL_NUMBER.add(dealMapId);
				VDEAL_TYPE.add(deal_type);
				VDEAL_REF.add(rset0.getString(8));
				VTRADE_DT.add(rset0.getString(9));
				VCONT_PERIOD.add(rset0.getString(10) + " - " + rset0.getString(11));
				VBUY_SALE.add("Sell");	
				VPRICE_TYPE.add(priceType);
				VAPPROVED_RATE.add(apprv_rate);
				VAPPROVED_DATE.add(AprvDate);
				VAWAITING_RATE.add(req_rate);
				//SB20260101	VAPPLICABLE_RATE.add(appPrice + "<br> [" + appDate + "]");
				if(!appPrice.equals("-") && !appPrice.equals("") && !appDate.equals(""))
				{
					VAPPLICABLE_RATE.add(appPrice);//SB20260101
					VRATE_DT_RANGE.add("[" + appDate + "]");//SB20260101
					VRATE_EFF_DT.add("("+ContMthYr+")");//SB20260101
				}
				else
				{
					VAPPLICABLE_RATE.add("");//SB20260101
					VRATE_DT_RANGE.add("");//SB20260101
					VRATE_EFF_DT.add("");//SB20260101
				}
				
				VFIN_CURV.add(finCurv);
				VPHY_CURV.add(physCurv);
				VAGMT_NO.add(agmt_no);
				VAGMT_REV.add(agmt_rev);
				VCONT_NO.add(cont_no);
				VCONT_REV.add(cont_rev);
				VCONTRACT_TYPE.add(cont_type);
				VCONT_STATUS.add(cont_status);
				VCARGO_NO.add("");
			}
			rset0.close();
			stmt0.close();
	
			rset1.close();
			stmt1.close();
			
			rset2.close();
			stmt2.close();
		}
		catch(Exception e)
		{
			new SystemErrorLogger().InsertErrorLogger(db_src_file_name, function_nm, e);
		}
		
	}
	
	
	// SagarB20251215 Below Function Added For Active Deal Pricing: Purchase Deals (Domestic NG, IGX, In Tank)
	public void getPurActiveDeals() {
		String function_nm = "getPurActiveDeals()";		
		try {
			String AprvDate="", ApplDate="";
			// Queries in loop
			String query = "SELECT PRICE_TYPE, PHYS_CURVE_NM FROM FMS_CONT_PRICE_DTL WHERE COMPANY_CD = ? AND CONTRACT_TYPE = ? AND MAPPING_ID = ? ";
			stmt = conn.prepareStatement(query);
			
			String queryApprove = "SELECT NEW_PRICE, NVL(TO_CHAR(EFF_DT, 'DD/MM/YYYY'), 'NA') FROM FMS_TRADER_CONT_PRICE_DTL WHERE COMPANY_CD = ? AND COUNTERPARTY_CD = ? AND AGMT_NO = ? AND AGMT_REV = ? AND CONT_NO = ? AND CONT_REV = ? AND CONTRACT_TYPE = ? AND FLAG = 'Y' AND EFF_DT <= TO_DATE(?, 'DD/MM/YYYY') ORDER BY EFF_DT DESC, SEQ_NO DESC";
			stmt1 = conn.prepareStatement(queryApprove);
			
			String queryRequest = "SELECT NEW_PRICE, NVL(TO_CHAR(EFF_DT, 'DD/MM/YYYY'), 'NA') FROM FMS_TRADER_CONT_PRICE_DTL WHERE COMPANY_CD = ? AND COUNTERPARTY_CD = ? AND AGMT_NO = ? AND AGMT_REV = ? AND CONT_NO = ? AND CONT_REV = ? AND CONTRACT_TYPE = ? AND FLAG = 'R' AND EFF_DT <= TO_DATE(?, 'DD/MM/YYYY') ORDER BY EFF_DT DESC, SEQ_NO DESC";
			stmt2 = conn.prepareStatement(queryRequest);
			
			String query0 = "SELECT DISTINCT A.COUNTERPARTY_CD, B.COUNTERPARTY_ABBR, B.COUNTERPARTY_NM FROM FMS_TRADER_CONT_MST A, FMS_COUNTERPARTY_MST B "
					+ " WHERE A.COMPANY_CD = ? AND A.START_DT <= TO_DATE(?, 'DD/MM/YYYY') AND A.END_DT >= TO_DATE(?, 'DD/MM/YYYY') "
					+ " AND A.COUNTERPARTY_CD = B.COUNTERPARTY_CD "
					+ " ORDER BY B.COUNTERPARTY_ABBR ";
			
			stmt0 = conn.prepareStatement(query0);
			stmt0.setString(1, comp_cd);
			stmt0.setString(2, rpt_dt);
			stmt0.setString(3, rpt_dt);
			rset0 = stmt0.executeQuery();
			
			while (rset0.next() && rset0.getString(1) != null && !VMST_COUNTERPARTY_CD.contains(rset0.getString(1))) {
				VMST_COUNTERPARTY_CD.add(rset0.getString(1) == null ? "" : rset0.getString(1));
				VMST_COUNTERPARTY_ABBR.add(rset0.getString(2) == null ? "" : rset0.getString(2));
				VMST_COUNTERPARTY_NM.add(rset0.getString(3) == null ? "" : rset0.getString(3));
			}
			rset0.close();
			stmt0.close();
			
			
			query0 = "SELECT B.COUNTERPARTY_ABBR, B.COUNTERPARTY_NM, A.AGMT_NO, A.AGMT_REV, A.CONT_NO, A.CONT_REV, NVL(A.CONTRACT_TYPE, '0'), "
					+ " A.CONT_REF_NO, TO_CHAR(A.SIGNING_DT, 'DD/MM/YYYY'), TO_CHAR(A.START_DT, 'DD/MM/YYYY'), TO_CHAR(A.END_DT, 'DD/MM/YYYY'), 'FIXED', RATE, RATE_UNIT, '-', 'RLNG_PHYS_INDIA', A.COUNTERPARTY_CD, A.CONT_STATUS "
					+ " FROM FMS_TRADER_CONT_MST A, FMS_COUNTERPARTY_MST B "
					+ " WHERE A.COMPANY_CD = ? AND A.START_DT <= TO_DATE(?, 'DD/MM/YYYY') AND A.END_DT >= TO_DATE(?, 'DD/MM/YYYY') "
					+ " AND A.COUNTERPARTY_CD = B.COUNTERPARTY_CD AND A.CONT_REV = (SELECT MAX(C.CONT_REV) FROM FMS_TRADER_CONT_MST C WHERE A.COMPANY_CD = C.COMPANY_CD AND A.COUNTERPARTY_CD = C.COUNTERPARTY_CD AND "
					+ " A.CONT_NO = C.CONT_NO AND A.CONTRACT_TYPE = C.CONTRACT_TYPE) "
					+ " AND B.EFF_DT = (SELECT MAX(C.EFF_DT) FROM FMS_COUNTERPARTY_MST C WHERE B.COUNTERPARTY_CD = C.COUNTERPARTY_CD )"
					+ " AND A.CONT_STATUS='Y' ";
			if (counterparty_cd != null && !counterparty_cd.equals("0")) {
					query0 += " AND A.COUNTERPARTY_CD = ?";
			}
			query0 += " ORDER BY COUNTERPARTY_ABBR ";
		//	System.out.println(rpt_dt+":"+query0);
			stmt0 = conn.prepareStatement(query0);
			stmt0.setString(1, comp_cd);
			stmt0.setString(2, rpt_dt);
			stmt0.setString(3, rpt_dt);
			
			if (counterparty_cd != null && !counterparty_cd.equals("0")) {
				stmt0.setString(4, counterparty_cd);
			}
			
			rset0 = stmt0.executeQuery();
			while (rset0.next()) {
				
				// Assigning Variables 
				agmt_no = rset0.getString(3);
				agmt_rev = rset0.getString(4);
				cont_no = rset0.getString(5);
				cont_rev = rset0.getString(6);
				cont_type = rset0.getString(7);
				
				priceType = "Fixed";
				appPrice = "-";
				appDate = "-";
				finCurv = "-";
				physCurv = "-";
				AprvDate="";
				 
				ApplDate=getBillingFreqTrd(comp_cd, rset0.getString(17), agmt_no, agmt_rev, cont_no, cont_rev, cont_type, rpt_dt);
				getContDtlFinBreakUp("Buy", rset0.getString(17) + "-" + agmt_no + "-" + cont_no); // New function for calculating applicable price
				
				String cont_status = rset0.getString(18);
				if (rset0.getString(18).equals("Y")) {
					cont_status = "Approved";
				}
				else if (rset0.getString(18).equals("C")) {
					cont_status = "Closed";
				}
				else if (rset0.getString(18).equals("P")) {
					cont_status = "Pending Approval";
				}
				else if (rset0.getString(18).equals("F")) {
					cont_status = "New+";
				}
				else if (rset0.getString(18).equals("T")) {
					cont_status = "Terminated";
				}
				else if (rset0.getString(18).equals("X")) {
					cont_status = "Cancelled";
				}
				
				String deal_type = "-";
				if (rset0.getString(7).equals("D")) {
					deal_type = "Domestic NG";
				}
				else if (rset0.getString(7).equals("I")) {
					deal_type = "IGX";
				}
				else if (rset0.getString(7).equals("T")) {
					deal_type = "In Tank LNG/RLNG";
				}
				
				String dealMapId = utilBean.NewDealMappingId(comp_cd, counterparty_cd, agmt_no, agmt_rev, cont_no, cont_rev, cont_type, "");

				// Below block is for deciding Approved Current Price
				rate_unit = rset0.getString(14) == null ? "2" : rset0.getString(14);
				String apprv_rate = rset0.getString(13) == null ? "-" : rset0.getString(13);
				apprv_rate = nf4.format(rset0.getDouble(13));
				if (rate_unit.equals("1")) {
					//rate_unit = "Rs./MMBTU";
					rate_unit = "INR";
				}
				else {
					//rate_unit = "$/MMBTU";
					rate_unit = "USD";
				}
			
		//sb		apprv_rate = apprv_rate + " " + rate_unit + " <br> [" + rset0.getString(10) + "]";

				stmt1.setString(1, comp_cd);
				stmt1.setString(2, rset0.getString(17));
				stmt1.setString(3, agmt_no);
				stmt1.setString(4, agmt_rev);
				stmt1.setString(5, cont_no);
				stmt1.setString(6, cont_rev);
				stmt1.setString(7, cont_type);
				stmt1.setString(8, rpt_dt);
				rset1 = stmt1.executeQuery();
				
				if (rset1.next()) {
				/*	apprv_rate = rset1.getString(1) + " " + rate_unit ;
					if (!rset1.getString(2).equals("NA")) {
						apprv_rate += " <br> [" + rset1.getString(2) + "]";
					}*/
					if (!rset1.getString(2).equals("NA"))
						AprvDate=rset1.getString(2);
				}
				else
					AprvDate=rset0.getString(10);
			//	System.out.println(appPrice+"::==::"+apprv_rate);
				
				int NoDays=0;
				String queryString = "SELECT TO_DATE(?,'DD/MM/YYYY')-TO_DATE(?,'DD/MM/YYYY') FROM DUAL" ;//SB20230721: Removed +1 day
				//	System.out.println(AprvDate+":"+ApplDate+":DUAL: LAST:"+queryString);
					stmt3 = conn.prepareStatement(queryString);
			    	stmt3.setString(1, AprvDate);
	       			stmt3.setString(2, ApplDate);//"01"+rpt_dt.substring(2));
		   			rset3 = stmt3.executeQuery();
					if(rset3.next()) {
						NoDays = rset3.getInt(1);  //For Physical
					}
					rset3.close();
					stmt3.close();
				//	System.out.println(NoDays+":::"+AprvDate+":"+ApplDate+":appPrice: apprv_rate:"+appPrice+"::"+apprv_rate);
		//	if(appPrice.equals(apprv_rate) && NoDays==0)
					if(!appPrice.equals("") && !appPrice.equals("-"))
					{
					//SB20260309	if(Double.parseDouble(appPrice)==Double.parseDouble(apprv_rate) && NoDays<=0)
						if(BigDecimal.valueOf(Double.parseDouble(appPrice)).compareTo(BigDecimal.valueOf(Double.parseDouble(apprv_rate)))==0 && NoDays<=0)
							VPriceAppl.add("Y");
						else
							VPriceAppl.add("N");
					}
					else
						VPriceAppl.add("N");
			
			appPrice=appPrice+" "+rate_unit;
			//////////////////^^^^^^^^^^^^^//////////////////////
			apprv_rate = apprv_rate + " " + rate_unit;// + " <br> (" + AprvDate + ")";
				// Below block is for deciding Awaiting For Approval Price
				String req_rate = "";
				
				stmt2.setString(1, comp_cd);
				stmt2.setString(2, rset0.getString(17));
				stmt2.setString(3, agmt_no);
				stmt2.setString(4, agmt_rev);
				stmt2.setString(5, cont_no);
				stmt2.setString(6, cont_rev);
				stmt2.setString(7, cont_type);
				stmt2.setString(8, rpt_dt);
				rset2 = stmt2.executeQuery();
				
				if (rset2.next()) {
					req_rate = rset2.getString(1) + " " + rate_unit ;
					if (!rset2.getString(2).equals("NA")) {
						req_rate += " <br> [" + rset2.getString(2) + "]";
					}
				}
				
				if (physCurv.equals("-") && (cont_type.equals("D") || cont_type.equals("I") || cont_type.equals("T"))) {
					physCurv = "RLNG_PHYS_INDIA";
				}
				// Assigning Vectors
				VCOUNTERPARTY_CD.add(rset0.getString(17));
				VCOUNTERPARTY_ABBR.add(rset0.getString(1));
				VCOUNTERPARTY_NM.add(rset0.getString(2));
				VDEAL_NUMBER.add(dealMapId);
				VDEAL_TYPE.add(deal_type);
				VDEAL_REF.add(rset0.getString(8));
				VTRADE_DT.add(rset0.getString(9));
				VCONT_PERIOD.add(rset0.getString(10) + " - " + rset0.getString(11));
				VBUY_SALE.add("Buy");	
				VPRICE_TYPE.add(priceType);
				VAPPROVED_RATE.add(apprv_rate);
				VAPPROVED_DATE.add(AprvDate);
				VAWAITING_RATE.add(req_rate);
				if(!appPrice.equals("-") && !appPrice.equals("") && !appDate.equals(""))
				{
					VAPPLICABLE_RATE.add(appPrice);//SB20260101
					VRATE_DT_RANGE.add("[" + appDate + "]");//SB20260101
					VRATE_EFF_DT.add("("+ContMthYr+")");//SB20260101
				}
				else
				{
					VAPPLICABLE_RATE.add("");//SB20260101
					VRATE_DT_RANGE.add("");//SB20260101
					VRATE_EFF_DT.add("");//SB20260101
				}
				
				VFIN_CURV.add(finCurv);
				VPHY_CURV.add(physCurv);
				VAGMT_NO.add(agmt_no);
				VAGMT_REV.add(agmt_rev);
				VCONT_NO.add(cont_no);
				VCONT_REV.add(cont_rev);
				VCONTRACT_TYPE.add(cont_type);
				VCONT_STATUS.add(cont_status);
				VCARGO_NO.add("");				
			}
			rset0.close();
			stmt0.close();
	
			rset1.close();
			stmt1.close();
			
			rset2.close();
			stmt2.close();
		}
		catch(Exception e)
		{
			new SystemErrorLogger().InsertErrorLogger(db_src_file_name, function_nm, e);
		}
		
	}
			
	// SagarB20251215 Below Function Added For Active Deal Pricing: Purchase Deals (Domestic NG, IGX, In Tank)
	public void getPurLngActiveDeals() {
		String function_nm = "getPurLngActiveDeals()";
		
		try {
			String AprvDate="", ApplDate="";
			// Queries in loop
			String query = "SELECT PRICE_TYPE, PHYS_CURVE_NM FROM FMS_CONT_PRICE_DTL WHERE COMPANY_CD = ? AND CONTRACT_TYPE = ? AND MAPPING_ID = ? ";
			stmt = conn.prepareStatement(query);
			
			String queryApprove = "SELECT NEW_PRICE, NVL(TO_CHAR(EFF_DT, 'DD/MM/YYYY'), 'NA') FROM FMS_TRADER_CONT_PRICE_DTL WHERE COMPANY_CD = ? AND COUNTERPARTY_CD = ? AND AGMT_NO = ? AND AGMT_REV = ? AND CONT_NO = ? AND CONT_REV = ? AND CONTRACT_TYPE = ? AND FLAG = 'Y' AND EFF_DT <= TO_DATE(?, 'DD/MM/YYYY') ORDER BY EFF_DT DESC, SEQ_NO DESC";
			stmt1 = conn.prepareStatement(queryApprove);
			
			String queryRequest = "SELECT NEW_PRICE, NVL(TO_CHAR(EFF_DT, 'DD/MM/YYYY'), 'NA') FROM FMS_TRADER_CONT_PRICE_DTL WHERE COMPANY_CD = ? AND COUNTERPARTY_CD = ? AND AGMT_NO = ? AND AGMT_REV = ? AND CONT_NO = ? AND CONT_REV = ? AND CONTRACT_TYPE = ? AND FLAG = 'R' AND EFF_DT <= TO_DATE(?, 'DD/MM/YYYY') ORDER BY EFF_DT DESC, SEQ_NO DESC";
			stmt2 = conn.prepareStatement(queryRequest);
			
			
			String query0 = "SELECT DISTINCT A.COUNTERPARTY_CD, B.COUNTERPARTY_ABBR, B.COUNTERPARTY_NM FROM FMS_TRADER_CARGO_MST A, FMS_COUNTERPARTY_MST B "
					+ " WHERE A.COMPANY_CD = ? AND A.START_DT <= TO_DATE(?, 'DD/MM/YYYY') AND A.END_DT >= TO_DATE(?, 'DD/MM/YYYY') "
					+ " AND A.COUNTERPARTY_CD = B.COUNTERPARTY_CD ";
			
			stmt0 = conn.prepareStatement(query0);
			stmt0.setString(1, comp_cd);
			stmt0.setString(2, rpt_dt);
			stmt0.setString(3, rpt_dt);
			rset0 = stmt0.executeQuery();
			
			while (rset0.next() && rset0.getString(1) != null && !VMST_COUNTERPARTY_CD.contains(rset0.getString(1))) {
				VMST_COUNTERPARTY_CD.add(rset0.getString(1) == null ? "" : rset0.getString(1));
				VMST_COUNTERPARTY_ABBR.add(rset0.getString(2) == null ? "" : rset0.getString(2));
				VMST_COUNTERPARTY_NM.add(rset0.getString(3) == null ? "" : rset0.getString(3));
			}
			rset0.close();
			stmt0.close();
			
			
			query0 = "SELECT B.COUNTERPARTY_ABBR, B.COUNTERPARTY_NM, A.AGMT_NO, A.AGMT_REV, A.CONT_NO, A.CONT_REV, NVL(A.CONTRACT_TYPE, '0'), "
					+ " A.CARGO_REF, TO_CHAR(D.SIGNING_DT, 'DD/MM/YYYY'), TO_CHAR(A.START_DT, 'DD/MM/YYYY'), TO_CHAR(A.END_DT, 'DD/MM/YYYY'), 'FIXED', A.RATE, A.RATE_UNIT, '-', 'RLNG_PHYS_INDIA', A.COUNTERPARTY_CD, A.CARGO_STATUS, A.CARGO_NO "
					+ " FROM FMS_TRADER_CARGO_MST A, FMS_COUNTERPARTY_MST B, FMS_TRADER_CN_MST D "
					+ " WHERE A.COMPANY_CD = ? AND A.START_DT <= TO_DATE(?, 'DD/MM/YYYY') AND A.END_DT >= TO_DATE(?, 'DD/MM/YYYY') "
					+ " AND A.COUNTERPARTY_CD = B.COUNTERPARTY_CD AND A.CONT_REV = (SELECT MAX(C.CONT_REV) FROM FMS_TRADER_CARGO_MST C WHERE A.COMPANY_CD = C.COMPANY_CD AND A.COUNTERPARTY_CD = C.COUNTERPARTY_CD AND "
					+ " A.CONT_NO = C.CONT_NO AND A.CONTRACT_TYPE = C.CONTRACT_TYPE)  "
					+ " AND A.COMPANY_CD = D.COMPANY_CD AND A.COUNTERPARTY_CD = D.COUNTERPARTY_CD AND A.AGMT_NO = D.AGMT_NO AND A.AGMT_REV = D.AGMT_REV AND A.CONT_NO = D.CONT_NO AND A.CONT_REV = D.CONT_REV "
					+ " AND A.AGMT_TYPE = D.AGMT_TYPE AND A.CONTRACT_TYPE = D.CONTRACT_TYPE "
					+ " AND B.EFF_DT = (SELECT MAX(C.EFF_DT) FROM FMS_COUNTERPARTY_MST C WHERE B.COUNTERPARTY_CD = C.COUNTERPARTY_CD )";
			if (counterparty_cd != null && !counterparty_cd.equals("0")) {
					query0 += " AND A.COUNTERPARTY_CD = ?";
			}
			
			stmt0 = conn.prepareStatement(query0);
			stmt0.setString(1, comp_cd);
			stmt0.setString(2, rpt_dt);
			stmt0.setString(3, rpt_dt);
			
			if (counterparty_cd != null && !counterparty_cd.equals("0")) {
				stmt0.setString(4, counterparty_cd);
			}
			
			rset0 = stmt0.executeQuery();
			while (rset0.next()) {
				
				// Assigning Variables 
				agmt_no = rset0.getString(3);
				agmt_rev = rset0.getString(4);
				cont_no = rset0.getString(5);
				cont_rev = rset0.getString(6);
				cont_type = rset0.getString(7);

				String cargo_no = rset0.getString(19);
				
				priceType = "Fixed";
				appPrice = "-";
				appDate = "-";
				finCurv = "-";
				physCurv = "-";
				AprvDate="";
				ApplDate=getBillingFreq(comp_cd, rset0.getString(17), agmt_no, agmt_rev, cont_no, cont_rev, cont_type, rpt_dt);
				getContDtlFinBreakUp("Buy", rset0.getString(17) + "-" + agmt_no + "-" + cont_no + "-" + cargo_no); // New function for calculating applicable price
				
				String cont_status = rset0.getString(18);
				if (rset0.getString(18).equals("Y")) {
					cont_status = "Confirmed";
				}
				else if (rset0.getString(18).equals("N")) {
					cont_status = "Not-Confirmed";
				}
				
				String deal_type = "LNG";
				
				String dealMapId = utilBean.NewDealMappingId(comp_cd, counterparty_cd, agmt_no, agmt_rev, cont_no, cont_rev, cont_type, cargo_no);

				// Below block is for deciding Approved Current Price
				rate_unit = rset0.getString(14) == null ? "-" : rset0.getString(14);
				String apprv_rate = rset0.getString(13) == null ? "-" : rset0.getString(13);
				if (rate_unit.equals("1")) {
				//	rate_unit = "Rs./MMBTU";
					rate_unit = "INR";
				}
				else {
					//rate_unit = "$/MMBTU";
					rate_unit = "USD";
				}
				
				int NoDays=0;
				String queryString = "SELECT TO_DATE(?,'DD/MM/YYYY')-TO_DATE(?,'DD/MM/YYYY') FROM DUAL" ;//SB20230721: Removed +1 day
					//System.out.println(AprvDate+":DUAL: LAST:"+queryString);
					stmt3 = conn.prepareStatement(queryString);
			    	stmt3.setString(1, AprvDate);
	       			stmt3.setString(2, ApplDate);//"01"+rpt_dt.substring(2));
		   			rset3 = stmt3.executeQuery();
					if(rset3.next()) {
						NoDays = rset3.getInt(1);  //For Physical
					}
					rset3.close();
					stmt3.close();
		//	if(appPrice.equals(apprv_rate) && NoDays==0)
			if(!appPrice.equals("") && !appPrice.equals("-"))
			{
			//SB20260309	if(Double.parseDouble(appPrice)==Double.parseDouble(apprv_rate) && NoDays<=0)
				if(BigDecimal.valueOf(Double.parseDouble(appPrice)).compareTo(BigDecimal.valueOf(Double.parseDouble(apprv_rate)))==0 && NoDays<=0)
					VPriceAppl.add("Y");
				else
					VPriceAppl.add("N");
			}
			else
				VPriceAppl.add("N");
			appPrice=appPrice+" "+rate_unit;
			//////////////////^^^^^^^^^^^^^//////////////////////
				apprv_rate = apprv_rate + " " + rate_unit;// + " <br> [" + rset0.getString(10) + "]";
				
				stmt1.setString(1, comp_cd);
				stmt1.setString(2, rset0.getString(17));
				stmt1.setString(3, agmt_no);
				stmt1.setString(4, agmt_rev);
				stmt1.setString(5, cont_no);
				stmt1.setString(6, cont_rev);
				stmt1.setString(7, cont_type);
				stmt1.setString(8, rpt_dt);
				rset1 = stmt1.executeQuery();
				if (rset1.next()) {
						if (!rset1.getString(2).equals("NA"))
							AprvDate=rset1.getString(2);
					}
					else
						AprvDate=rset0.getString(10);
				
				// Below block is for deciding Awaiting For Approval Price
				String req_rate = "";
				
				stmt2.setString(1, comp_cd);
				stmt2.setString(2, rset0.getString(17));
				stmt2.setString(3, agmt_no);
				stmt2.setString(4, agmt_rev);
				stmt2.setString(5, cont_no);
				stmt2.setString(6, cont_rev);
				stmt2.setString(7, cont_type);
				stmt2.setString(8, rpt_dt);
				rset2 = stmt2.executeQuery();
				
				if (rset2.next()) {
					req_rate = rset2.getString(1) + " " + rate_unit ;
					if (!rset2.getString(2).equals("NA")) {
						req_rate += " <br> [" + rset2.getString(2) + "]";
					}
				}
				
				
				// Assigning Vectors
				VCOUNTERPARTY_CD.add(rset0.getString(17));
				VCOUNTERPARTY_ABBR.add(rset0.getString(1));
				VCOUNTERPARTY_NM.add(rset0.getString(2));
				VDEAL_NUMBER.add(dealMapId);
				VDEAL_TYPE.add(deal_type);
				VDEAL_REF.add(rset0.getString(8));
				VTRADE_DT.add(rset0.getString(9));
				VCONT_PERIOD.add(rset0.getString(10) + " - " + rset0.getString(11));
				VBUY_SALE.add("Buy");	
				VPRICE_TYPE.add(priceType);
				VAPPROVED_RATE.add(apprv_rate);
				VAPPROVED_DATE.add(AprvDate);
				VAWAITING_RATE.add(req_rate);
				//SB20260101	VAPPLICABLE_RATE.add(appPrice + "<br> [" + appDate + "]");
				if(!appPrice.equals("-") && !appPrice.equals("") && !appDate.equals(""))
				{
					VAPPLICABLE_RATE.add(appPrice);//SB20260101
					VRATE_DT_RANGE.add("[" + appDate + "]");//SB20260101
					VRATE_EFF_DT.add("("+ContMthYr+")");//SB20260101
				}
				else
				{
					VAPPLICABLE_RATE.add("");//SB20260101
					VRATE_DT_RANGE.add("");//SB20260101
					VRATE_EFF_DT.add("");//SB20260101
				}
				
				VFIN_CURV.add(finCurv);
				VPHY_CURV.add(physCurv);
				VAGMT_NO.add(agmt_no);
				VAGMT_REV.add(agmt_rev);
				VCONT_NO.add(cont_no);
				VCONT_REV.add(cont_rev);
				VCONTRACT_TYPE.add(cont_type);
				VCONT_STATUS.add(cont_status);
				VCARGO_NO.add(cargo_no);
				
			//	VBILL_FREQ.add("*");
			}
			rset0.close();
			stmt0.close();
			
			rset1.close();
			stmt1.close();
			
			rset2.close();
			stmt2.close();
			
		}
		catch(Exception e)
		{
			new SystemErrorLogger().InsertErrorLogger(db_src_file_name, function_nm, e);
		}
		
	}
		
	// SagarB20251206 Function to show latest available pricing data in the header of Active Deal Pricing page
	public void getCurrentAvailableCurvePrice() {
		String function_nm = "getCurrentAvailableCurvePrice()";
		
		try {
			//////////////////SB20251215/////////////////////////////////
		String ZemaPriceEntryDt=""; String LastPriceEntryDateTimeAprvBy="";//SB20251215
		String queryString = "SELECT TO_CHAR(MAX(ENT_DT), 'DD/MM/YYYY'), TO_CHAR(MAX(CURVE_DT), 'DD/MM/YYYY'), TO_CHAR(MAX(MODIFY_DT), 'dd/mm/yyyy hh24:mi:ss'), TO_CHAR(MAX(ENT_DT), 'dd/mm/yyyy hh24:mi:ss') "
				+ "FROM FMS_SPOT_PRICE_DTL "
				+ "WHERE CURVE_TYPE='Spot' AND " 
				//+ "TO_DATE(TO_DATE(ENT_DT,'DD/MM/YYYY'),'DD-MON-YY') <=TO_DATE(?, 'DD/MM/YYYY') ";
			//	+ "TO_DATE(ENT_DT,'DD-MON-YY') <=TO_DATE(?, 'DD/MM/YYYY') ";
				+ "ENT_DT <=TO_DATE(?, 'DD/MM/YYYY') ";
		stmt = conn.prepareStatement(queryString);
	//	System.out.println(rpt_dt+":"+queryString);
		stmt.setString(1, rpt_dt);
		rset = stmt.executeQuery();			
		if (rset.next()) {
			lastCurveEntDt = rset.getString(2); //SB: MAx/Last Spot Price Entered Date
			LastPriceEntryDateTimeAprvBy = rset.getString(4)==null?"":rset.getString(4);
			if(LastPriceEntryDateTimeAprvBy.equals(""))
				LastPriceEntryDateTime = lastCurveEntDt; //incase of manual entry in table
		}
		LastPriceEntryDateTime=""+LastPriceEntryDateTimeAprvBy+"";//System.out.println(lastCurveEntDt+":"+LastPriceEntryDateTime);
		rset.close();
		stmt.close();
			queryString = "SELECT DISTINCT(CURVE_NM) FROM FMS_CONT_PRICE_DTL "
					+ "WHERE COMPANY_CD = ? AND FROM_DT <= TO_DATE(?, 'DD/MM/YYYY') AND TO_DT >= TO_DATE(?, 'DD/MM/YYYY') AND CURVE_NM IS NOT NULL AND PRICE_TYPE='M' ";
			stmt = conn.prepareStatement(queryString);
			stmt.setString(1, comp_cd);
			stmt.setString(2, rpt_dt);
			stmt.setString(3, rpt_dt);			
			rset = stmt.executeQuery();			
			while (rset.next()) {				
				VApplicableCurves.add(rset.getString(1));
			}
			rset.close();
			stmt.close();
			queryString = "SELECT DISTINCT(CURVE_NM) FROM FMS_CONT_PRICE_MIN_DTL "
					+ "WHERE COMPANY_CD = ? AND FROM_DT <= TO_DATE(?, 'DD/MM/YYYY') AND TO_DT >= TO_DATE(?, 'DD/MM/YYYY') AND CURVE_NM IS NOT NULL "
					+ "AND CURVE_NM NOT IN (SELECT DISTINCT CURVE_NM FROM FMS_CONT_PRICE_DTL " 
					+ "WHERE COMPANY_CD = ? "
					+ "AND FROM_DT<=TO_DATE(?,'DD/MM/YYYY') AND TO_DT>=TO_DATE(?,'DD/MM/YYYY') AND CURVE_NM IS NOT NULL)"; 
			stmt = conn.prepareStatement(queryString);
			stmt.setString(1, comp_cd);
			stmt.setString(2, rpt_dt);
			stmt.setString(3, rpt_dt);
			stmt.setString(4, comp_cd);
			stmt.setString(5, rpt_dt);
			stmt.setString(6, rpt_dt);			
			rset = stmt.executeQuery();		
			while (rset.next()) {				
				VApplicableCurves.add(rset.getString(1));
			}
			rset.close();
			stmt.close();
			VApplicableCurves.add("ICE_WIM");
			// Fetching Applicable Curves and its prices for the given date			
			String curveSpotSQL = "SELECT TO_CHAR(CURVE_DT, 'DD-MON-YYYY'), COMMODITY_TYPE, CURVE_UNIT, SETTLE_PRICE FROM FMS_SPOT_PRICE_DTL "
				//	+ "WHERE ENT_DT = TO_DATE(?, 'DD/MM/YYYY') AND PHYS_FIN = ? "
					+ "WHERE CURVE_DT = TO_DATE(?, 'DD/MM/YYYY') AND ACTUAL_CURVE = ? "; //SB20260217
		//	System.out.println(rpt_dt+":"+curveSpotSQL);
			stmt1 = conn.prepareStatement(curveSpotSQL);

			String curveForwardSQL = "SELECT TO_CHAR(CURVE_DT, 'DD-MON-YYYY'), COMMODITY_TYPE, CURVE_UNIT, SETTLE_PRICE, TO_CHAR(ENT_DT, 'dd/mm/yyyy hh24:mi:ss') FROM FMS_FORWARD_PRICE_DTL "
					+ "WHERE CURVE_DT = TO_DATE(?, 'DD/MM/YYYY') "
					+ "AND TO_DATE(REPORT_DT,'DD/MM/YYYY')=(SELECT TO_DATE(MAX(REPORT_DT),'DD/MM/YYYY') "
					+ "FROM FMS_FORWARD_PRICE_DTL WHERE CURVE_DT=TO_DATE(?,'DD/MM/YYYY') AND CURVE_TYPE='Forward' AND "
					+ "ENT_DT<=TO_DATE(?,'DD/MM/YYYY') AND CURVE_NM=?) AND CURVE_NM = ? "
					+ "ORDER BY ENT_DT DESC ";
			stmt2 = conn.prepareStatement(curveForwardSQL);
		//	System.out.println(rpt_dt+":"+curveSpotSQL);
			for (int i=0; i<VApplicableCurves.size(); i++)	
			{
				// Below block is fetching data for SPOT PRICES
				//if (!rset.getString(1).equalsIgnoreCase("PPAC")) {
				if (!VApplicableCurves.elementAt(i).equals("PPAC")) {
					stmt1.setString(1, lastCurveEntDt);
					stmt1.setString(2, ""+VApplicableCurves.elementAt(i));//rset.getString(1));
					rset1 = stmt1.executeQuery();
					
					if (rset1.next()) {
						VApplicableSpotPrice.add(nf4.format(rset1.getDouble(4)));
						VApplicableSpotUnit.add(rset1.getString(3));
						VApplicableCommodityType.add(rset1.getString(2));
						VApplicableSpotFwdRegdDt.add(""+LastPriceEntryDateTime);
					}
					else {
						VApplicableSpotPrice.add("NA");
						VApplicableSpotUnit.add("NA");
						VApplicableCommodityType.add("NA");
						VApplicableSpotFwdRegdDt.add("NA");
					}
					
				}
				else if (VApplicableCurves.elementAt(i).equals("PPAC")) {
					stmt2.setString(1, "01"+rpt_dt.substring(2));
					stmt2.setString(2, "01"+rpt_dt.substring(2));//sb
					stmt2.setString(3, rpt_dt);
					stmt2.setString(4, ""+VApplicableCurves.elementAt(i));//sb //rset.getString(1));
					stmt2.setString(5, ""+VApplicableCurves.elementAt(i));//sb
					rset2 = stmt2.executeQuery();
				
					if (rset2.next()) {
						VApplicableSpotPrice.add(nf4.format(rset2.getDouble(4)));
						VApplicableSpotUnit.add(rset2.getString(3));
						VApplicableCommodityType.add(rset2.getString(2));
						VApplicableSpotFwdRegdDt.add(rset2.getString(5));
					}
					else {
						VApplicableSpotPrice.add("NA");
						VApplicableSpotUnit.add("NA");
						VApplicableCommodityType.add("NA");
						VApplicableSpotFwdRegdDt.add("NA");
					}
				}
			}
			rset1.close();
			stmt1.close();
			
			rset2.close();
			stmt2.close();
			
		
			// Below Block is for fetching Contract Month Settle Price
			String SettleStartDt=""; String SettleEndDt=""; String SettleDt="";
			
			String curveSettleDtSQL = "SELECT TO_CHAR(SETTLE_DT, 'DD/MM/YYYY'), TO_CHAR(SETTLE_START_DT, 'DD/MM/YYYY'), TO_CHAR(SETTLE_END_DT, 'DD/MM/YYYY') FROM FMS_CURVE_SETTLE_CALND "
									+ "WHERE CONT_MONTH = TO_DATE(?, 'DD/MM/YYYY') AND CURVE_NM = ? ";
		//	System.out.println(rpt_dt+":"+curveSettleDtSQL);
			stmt = conn.prepareStatement(curveSettleDtSQL);
			
			String curveSpotSettleSQL = "SELECT AVG(SETTLE_PRICE) FROM FMS_SPOT_PRICE_DTL "
									  + "WHERE SETTLE_PRICE > 0 AND CURVE_DT >= TO_DATE(?, 'DD/MM/YYYY') AND CURVE_DT <= TO_DATE(?, 'DD/MM/YYYY') "
								//	  + "AND PHYS_FIN = ? ";
									  + "AND ACTUAL_CURVE = ? "; //SB20260217
		//	System.out.println(rpt_dt+":"+curveSpotSettleSQL);
			stmt1 = conn.prepareStatement(curveSpotSettleSQL);
			
//			String curveForwardSettleSQL = "SELECT SETTLE_PRICE FROM FMS_FORWARD_PRICE_DTL "
//										 + "WHERE CURVE_DT = TO_DATE(?, 'DD/MM/YYYY') AND ENT_DT <= TO_DATE(?, 'DD/MM/YYYY') AND CURVE_NM = ? ORDER BY ENT_DT DESC ";
			String curveForwardSettleSQL = "SELECT (SETTLE_PRICE) FROM FMS_FORWARD_PRICE_DTL " + 
				//	"WHERE CURVE_DT >= TO_DATE(?, 'DD/MM/YYYY') AND CURVE_DT <= TO_DATE(?, 'DD/MM/YYYY') AND CURVE_NM = ? " + 
					"WHERE CURVE_DT = TO_DATE(?, 'DD/MM/YYYY') AND CURVE_NM = ? " + 
					"AND TO_DATE(REPORT_DT,'DD/MM/YYYY')=(SELECT TO_DATE(MAX(REPORT_DT),'DD/MM/YYYY') FROM FMS_FORWARD_PRICE_DTL " + 
					" WHERE CURVE_TYPE='Forward' AND ENT_DT<=TO_DATE(?,'DD/MM/YYYY') " + 
					"AND CURVE_NM=? ) " + 
					"ORDER BY CURVE_DT DESC";
		//	System.out.println(rpt_dt+":"+curveForwardSettleSQL);
			stmt2 = conn.prepareStatement(curveForwardSettleSQL);
			
			for (int i = 0; i < VApplicableCurves.size(); i++) {

				// Fetching Settlement Date
				stmt.setString(1, "01"+rpt_dt.substring(2));
				stmt.setString(2, VApplicableCurves.elementAt(i).toString());
				rset = stmt.executeQuery();
				
				if (rset.next()) {
					SettleDt = rset.getString(1);
					SettleStartDt = rset.getString(2);
					SettleEndDt = rset.getString(3);
				}
				else {
					SettleDt = rpt_dt;
					SettleStartDt = rpt_dt;
					SettleEndDt = rpt_dt;
				}
			//	System.out.println(rpt_dt+":"+SettleDt+":"+SettleStartDt+":"+SettleEndDt+":"+VApplicableCurves.elementAt(i));
				if (!VApplicableCurves.elementAt(i).toString().equals("PPAC")) {
					stmt1.setString(1, SettleStartDt);
					stmt1.setString(2, SettleDt);
					stmt1.setString(3, VApplicableCurves.elementAt(i).toString());
					rset1 = stmt1.executeQuery();
					
					if (rset1.next()) {
						VCurveContMthSettlePrice.add(nf4.format(rset1.getDouble(1))+"");
						VCurveContMthSettlePeriod.add(SettleStartDt+" - "+SettleDt);
					}
					else {
						VCurveContMthSettlePrice.add("-");
						VCurveContMthSettlePeriod.add(" - ");
					}
					
				}
				else if(VApplicableCurves.elementAt(i).equals("PPAC")) {
				//	System.out.println(SettleStartDt+":"+SettleDt+":"+rpt_dt+":"+VApplicableCurves.elementAt(i)+":FORWARD-AvgPRICE:"+curveForwardSettleSQL);
					/*stmt2.setString(1, SettleStartDt);
					stmt2.setString(2, SettleDt);
					stmt2.setString(3, VApplicableCurves.elementAt(i).toString());
					stmt2.setString(4, rpt_dt);
					stmt2.setString(5, VApplicableCurves.elementAt(i).toString());*/
				//	stmt2.setString(1, SettleStartDt);
					stmt2.setString(1,  "01"+rpt_dt.substring(2));
					stmt2.setString(2, VApplicableCurves.elementAt(i).toString());
					stmt2.setString(3, rpt_dt);
					stmt2.setString(4, VApplicableCurves.elementAt(i).toString());
					rset2 = stmt2.executeQuery();
					
					if(rset2.next()) {
						VCurveContMthSettlePrice.add(rset2.getString(1));
						VCurveContMthSettlePeriod.add(SettleStartDt+" - "+SettleDt);
					}
					else {
						VCurveContMthSettlePrice.add("-");
						VCurveContMthSettlePeriod.add(" - ");
					}
				}
				
			}
			//System.out.println(VCurveContMthSettlePrice.size()+":FORWARD-AvgPRICE:"+VCurveContMthSettlePrice);
			rset.close();
			stmt.close();
			
			rset1.close();
			stmt1.close();
			
			rset2.close();
			stmt2.close();
			
		}
		catch(Exception e)
		{
			new SystemErrorLogger().InsertErrorLogger(db_src_file_name, function_nm, e);
		}
		
	}
	
	// SagarB20251208 Below function is used to Get Variable Pricing BreakUp And Applicable Price
	public void getContDtlFinBreakUp(String buy_sell, String map_id) {
		String function_nm="getContDtlFinBreakUp()";
		try
		{
		//	System.out.println(buy_sell+":"+map_id+":ACTION: "+function_nm);
			String PriceDeci=""; String FinalPriceDeci=""; 	double PremDiscRate=0; //SB20241111
			String PriceFormula="", DealName="", DealDerivative="", ContMthYr2=""; String queryString=""; 	int NoMth=3; int StartingPrevMth=1; int NoMth_FinCurve=3; //SB20251215
			String FinCurve="", Slope="", Constant="", PriceRange="", RemarksMultiLeg="", RemarksMinMaxMultiLeg="";
			String fetchVarPrice = "SELECT SEQ_NO, TO_CHAR(FROM_DT, 'DD/MM/YYYY'), TO_CHAR(TO_DT, 'DD/MM/YYYY'), PRICE_TYPE, NVL(PHYS_CURVE_NM, 'RLNG_PHYS_INDIA'), CURVE_NM, NVL(SLOPE, 1), NVL(CONST, 0), RATE, "
					+ " RATE_UNIT, REMARKS, PRICE_RANGE, TO_CHAR(PRICE_START_DT, 'DD/MM/YYYY'), TO_CHAR(PRICE_END_DT, 'DD/MM/YYYY'), FORMULA "
					+ ",PRICE_DECI, FINAL_PRICE_DECI, PREM_DISC_RATE " //SB20251229
					+ " FROM FMS_CONT_PRICE_DTL "
					+ " WHERE COMPANY_CD = ? AND MAPPING_ID = ? AND CONTRACT_TYPE = ? AND FROM_DT <= TO_DATE(?, 'DD/MM/YYYY') AND TO_DT >= TO_DATE(?, 'DD/MM/YYYY') ";
			stmt3 = conn.prepareStatement(fetchVarPrice);
			stmt3.setString(1, comp_cd);
			stmt3.setString(2, map_id);
			stmt3.setString(3, cont_type);
			stmt3.setString(4, rpt_dt);
			stmt3.setString(5, rpt_dt);
			rset3 = stmt3.executeQuery();
			if (rset3.next()) {
				physCurv = rset3.getString(5);
				FinCurve = rset3.getString(6)==null?"":rset3.getString(6);
				Slope = rset3.getString(7)==null?"":rset3.getString(7);
				Constant = rset3.getString(8)==null?"":rset3.getString(8);
				PriceRange = rset3.getString(12)==null?"":rset3.getString(12);
				from_dt = rset3.getString(13);
				to_dt = rset3.getString(14);
				PriceFormula=rset3.getString(15)==null?"":rset3.getString(15); //SB20251215;
				PriceDeci=rset3.getString(16)==null?"4":rset3.getString(16);
				FinalPriceDeci=rset3.getString(17)==null?"4":rset3.getString(17);
				PremDiscRate=rset3.getDouble(18);
				
				if (rset3.getString(4).equals("F")) //Price_Type=Fixed
				{
					appPrice = rset3.getString(9);
					appDate = rset3.getString(2);
				//sb	finCurv = "-";
					finCurv = ""; //SB20260101
					priceType = "Fixed";
				}
				else //Price_Type=Float(Curve)
				{
					appPrice = rset3.getString(9);
					priceType = "Float";
					if (PriceFormula.equals("")) {	
						finCurv = rset3.getString(6);
						getCalcSingleCurve(finCurv, Slope, Constant, PriceRange, rpt_dt, PriceDeci,FinalPriceDeci,PremDiscRate );
					}
					else if (PriceFormula.contains("MULTI")) {	/// MULTI-LEG
						finCurv = rset3.getString(6) + " " + rset3.getString(15).split("@")[0] + "("+rset3.getString(15).split("@")[1] + "," + rset3.getString(15).split("@")[2] + "," + rset3.getString(15).split("@")[3] + ")";
						
						String temp_appPrice = "0";
						
							String fetchDate = "";
							int counter = 0;
							
							if (PriceFormula.split("@")[1].equalsIgnoreCase("Settled")) {
								fetchDate = "SELECT TO_CHAR(ADD_MONTHS(TO_DATE(?, 'DD/MM/YYYY'), - ?), 'DD/MM/YYYY') FROM DUAL";
							}
							else {
								fetchDate = "SELECT TO_CHAR(ADD_MONTHS(TO_DATE(?, 'DD/MM/YYYY'), + ?), 'DD/MM/YYYY') FROM DUAL"; 
							}
							stmt6 = conn.prepareStatement(fetchDate);
							
						for (int i = Integer.parseInt(PriceFormula.split("@")[2]); i <= Integer.parseInt(PriceFormula.split("@")[3]); i++) {
							
							stmt6.setString(1, "01"+rpt_dt.substring(2));
							stmt6.setInt(2, i);
							rset6 = stmt6.executeQuery();
							if (rset6.next()) {
								getCalcSingleCurve(FinCurve, Slope, Constant, PriceRange, rset6.getString(1), PriceDeci,FinalPriceDeci,PremDiscRate );
								//System.out.println(appPrice+"::appPrice::");
								if(!appPrice.equals("") && !appPrice.equals("-"))
									temp_appPrice = nf4.format(Double.parseDouble(temp_appPrice) + Double.parseDouble(appPrice.split(" ")[0]));
							}
							counter++;
							
						}
						rset6.close();
						stmt6.close();
						appPrice = nf4.format(Double.parseDouble(temp_appPrice) / counter);//System.out.println(appPrice+"::Final-appPrice::");
					}
					else if (PriceFormula.contains("MIN") || PriceFormula.contains("MAX")) //MIN/MAX or MIN_ADV
					{
					finCurv = PriceFormula.split("@")[0] + " of [" + PriceFormula.split("@")[1] + ", " + PriceFormula.split("@")[2] + "]";

						String temp_appPrice = "0";
						String fetchVarPriceDtl = "SELECT CURVE_NM, SLOPE, CONST, PRICE_RANGE, TO_CHAR(PRICE_START_DT, 'DD/MM/YYYY'), TO_CHAR(PRICE_END_DT, 'DD/MM/YYYY'), REMARKS, "
								+ "PRICE_DECI, PREM_DISC_RATE, FORMULA " //SB20251229
								+ "FROM FMS_CONT_PRICE_MIN_DTL "
								+ " WHERE COMPANY_CD = ? AND MAPPING_ID = ? AND CONTRACT_TYPE = ? AND SEQ_NO = ? ";
						stmt6 = conn.prepareStatement(fetchVarPriceDtl);
						stmt6.setString(1, comp_cd);
						stmt6.setString(2, map_id);
						stmt6.setString(3, cont_type);
						stmt6.setString(4, rset3.getString(1));
						rset6 = stmt6.executeQuery();
						while (rset6.next()) {
							FinCurve = rset6.getString(1)==null?"":rset6.getString(1);
							Slope = rset6.getString(2)==null?"":rset6.getString(2);
							Constant = rset6.getString(3)==null?"":rset6.getString(3);
							PriceRange = rset6.getString(4)==null?"":rset6.getString(4);
							from_dt = rset6.getString(5)==null?"":rset6.getString(5);
							to_dt = rset6.getString(6)==null?"":rset6.getString(6);
							RemarksMultiLeg=rset6.getString(7)==null?"":rset6.getString(7);
							PriceDeci=rset6.getString(8)==null?"4":rset6.getString(8);
							PremDiscRate=rset6.getDouble(9);
							RemarksMinMaxMultiLeg=rset6.getString(10)==null?"":rset6.getString(10);//System.out.println(RemarksMinMaxMultiLeg+"::RemarksMinMaxMultiLeg::");
							if(RemarksMinMaxMultiLeg.equals("")) //No MULTI_LEG
								getCalcSingleCurve(FinCurve, Slope, Constant, PriceRange, rpt_dt, PriceDeci,FinalPriceDeci,PremDiscRate );
							else if(RemarksMinMaxMultiLeg.contains("MULTI_LEG")) //No MULTI_LEG
							{
								////////////////MULTI-LEG under MIN/MAX/////////////////////////
								String fetchDate = "";
								int counter = 0;	
								if (RemarksMinMaxMultiLeg.split("@")[1].equalsIgnoreCase("Settled"))
									fetchDate = "SELECT TO_CHAR(ADD_MONTHS(TO_DATE(?, 'DD/MM/YYYY'), - ?), 'DD/MM/YYYY') FROM DUAL";
								else
									fetchDate = "SELECT TO_CHAR(ADD_MONTHS(TO_DATE(?, 'DD/MM/YYYY'), + ?), 'DD/MM/YYYY') FROM DUAL"; 
								stmt7 = conn.prepareStatement(fetchDate);		
								for (int i = Integer.parseInt(RemarksMinMaxMultiLeg.split("@")[2]); i <= Integer.parseInt(RemarksMinMaxMultiLeg.split("@")[3]); i++) {	
									stmt7.setString(1, "01"+rpt_dt.substring(2));
									stmt7.setInt(2, i);
									rset7 = stmt7.executeQuery();
									if (rset7.next()) {
										getCalcSingleCurve(FinCurve, Slope, Constant, PriceRange, rset7.getString(1), PriceDeci,FinalPriceDeci,PremDiscRate );
										//System.out.println(appPrice+"::appPrice::");
										if(!appPrice.equals("") && !appPrice.equals("-"))
											temp_appPrice = nf4.format(Double.parseDouble(temp_appPrice) + Double.parseDouble(appPrice.split(" ")[0]));
									}
									counter++;							
								}
								rset7.close();
								stmt7.close();
								appPrice = nf4.format(Double.parseDouble(temp_appPrice) / counter);//System.out.println(appPrice+"::Final-appPrice::"+counter+":"+temp_appPrice);
								temp_appPrice=appPrice; //Last Data based on MIN/MAX in temp_appPrice
								////////////////^^^^MULTI_LEG////////////////////////////////////////////
							}
							if (!appPrice.equals("-") && (temp_appPrice.equals("0") || (PriceFormula.contains("MIN") && Double.parseDouble(temp_appPrice) > Double.parseDouble(appPrice.split(" ")[0])) || (PriceFormula.contains("MAX") && Double.parseDouble(temp_appPrice) < Double.parseDouble(appPrice.split(" ")[0])))) 
							{
								temp_appPrice=appPrice; //Last Data based on MIN/MAX in temp_appPrice
							}
						}
						appPrice=temp_appPrice; //Final Price based on MIN/MAX
						rset6.close();
						stmt6.close();	
					}
					else {/*	// MIN/MAX
						finCurv = rset3.getString(15).split("@")[0] + " of [" + rset3.getString(15).split("@")[1] + ", " + rset3.getString(15).split("@")[2] + "]";

						String temp_appPrice = "0";
						String fetchVarPriceDtl = "SELECT CURVE_NM, SLOPE, CONST, PRICE_RANGE, TO_CHAR(PRICE_START_DT, 'DD/MM/YYYY'), TO_CHAR(PRICE_END_DT, 'DD/MM/YYYY'), REMARKS, "
								+ "PRICE_DECI, PREM_DISC_RATE " //SB20251229
								+ "FROM FMS_CONT_PRICE_MIN_DTL "
								+ " WHERE COMPANY_CD = ? AND MAPPING_ID = ? AND CONTRACT_TYPE = ? AND SEQ_NO = ? ";
						stmt6 = conn.prepareStatement(fetchVarPriceDtl);
						stmt6.setString(1, comp_cd);
						stmt6.setString(2, map_id);
						stmt6.setString(3, cont_type);
						stmt6.setString(4, rset3.getString(1));
						rset6 = stmt6.executeQuery();
						while (rset6.next()) {
							FinCurve = rset6.getString(1)==null?"":rset6.getString(1);
							Slope = rset6.getString(2)==null?"":rset6.getString(2);
							Constant = rset6.getString(3)==null?"":rset6.getString(3);
							PriceRange = rset6.getString(4)==null?"":rset6.getString(4);
							from_dt = rset6.getString(5)==null?"":rset6.getString(5);
							to_dt = rset6.getString(6)==null?"":rset6.getString(6);
							RemarksMultiLeg=rset6.getString(7)==null?"":rset6.getString(7);
							PriceDeci=rset6.getString(8)==null?"4":rset6.getString(8);
							PremDiscRate=rset6.getDouble(9);
							
							getCalcSingleCurve(FinCurve, Slope, Constant, PriceRange, rpt_dt, PriceDeci,FinalPriceDeci,PremDiscRate );
						//	System.out.println(Slope+":"+PremDiscRate+":"+map_id+"::::::"+appPrice+":"+FinCurve+"::TempPrice:"+temp_appPrice);
							if (!appPrice.equals("-") && (temp_appPrice.equals("0") || (rset3.getString(15).contains("MIN") && Double.parseDouble(temp_appPrice) > Double.parseDouble(appPrice.split(" ")[0])) || (rset3.getString(15).contains("MAX") && Double.parseDouble(temp_appPrice) < Double.parseDouble(appPrice.split(" ")[0])))) {
							//	temp_appPrice = ""+(Double.parseDouble(appPrice.split(" ")[0]));
								temp_appPrice=appPrice; //Last Data based on MIN/MAX in temp_appPrice
							}
						}
						appPrice=temp_appPrice; //Final Price based on MIN/MAX
						rset6.close();
						stmt6.close();				
					*/}					
				}			
				rate_unit = rset3.getString(10) == null ? "2" : rset3.getString(10);
				if (rate_unit.equals("1")) {
				//	rate_unit = "Rs./MMBTU";
					rate_unit = "INR";
				}
				else {
				//	rate_unit = "$/MMBTU";
					rate_unit = "USD";
				}
				
			}
			else //SB20260101 Not Defined in Variable Pricing Table : FMS_CONT_PRICE_DTL
			{
				appPrice = "";
				appDate = "";
			}
			rset3.close();
			stmt3.close();
		}
		catch(Exception e)
		{
			new SystemErrorLogger().InsertErrorLogger(db_src_file_name, function_nm, e);
		}
		
	}
	
	
	public void getCalcSingleCurve(String fin_curve, String slope, String constant, String price_flag, String report_dt, String PriceDeci, String FinalPriceDeci, double PremDiscRate) {
		String function_nm = "getCalcSingleCurve()";
		try {
			//System.out.println(price_flag+":ACTION: "+function_nm);
			priceType = "Float";
			appPrice = "";
			double appPrice2 =0;
			
			String fetchAppPrice = "", appPriceUnit = "USD";
			String fetchSettleCalnd = "SELECT TO_CHAR(SETTLE_START_DT, 'DD/MM/YYYY'), TO_CHAR(SETTLE_DT, 'DD/MM/YYYY') FROM FMS_CURVE_SETTLE_CALND "
					+ " WHERE CURVE_NM = ? AND CONT_MONTH = TO_DATE(?, 'DD/MM/YYYY') ";
			
			stmt4 = conn.prepareStatement(fetchSettleCalnd);
			stmt4.setString(1, fin_curve);
			stmt4.setString(2, "01"+report_dt.substring(2));
			rset4 = stmt4.executeQuery();
			
			if (rset4.next()) {
				String settle_start_dt = rset4.getString(1);
				String settle_dt = rset4.getString(2);
				
				if (fin_curve.equals("PPAC")) {
					fetchAppPrice = "SELECT SETTLE_PRICE, CURVE_UNIT FROM FMS_FORWARD_PRICE_DTL "
					+ " WHERE CURVE_DT = TO_DATE(?, 'DD/MM/YYYY') AND CURVE_NM = ? AND "
					+ "TO_DATE(REPORT_DT,'DD-MON-YY') = (SELECT TO_DATE(TO_DATE(MAX(REPORT_DT),'DD/MM/YYYY'),'DD-MON-YY') FROM FMS_FORWARD_PRICE_DTL " + 
					" WHERE CURVE_TYPE='Forward' AND ENT_DT<=TO_DATE(?,'DD/MM/YYYY') " + 
					" AND CURVE_NM=? ) ";
				//	+ "<= TO_DATE(?, 'DD/MM/YYYY') AND CURVE_NM = ? ORDER BY REPORT_DT DESC";
				//	System.out.println(settle_start_dt+":"+settle_dt+":PPAC: "+fetchAppPrice);
			stmt5 = conn.prepareStatement(fetchAppPrice);
			stmt5.setString(1, "01"+report_dt.substring(2));
			stmt5.setString(2, fin_curve);
			stmt5.setString(3, report_dt);
			stmt5.setString(4, fin_curve);
			
			/* fetchAppPrice = "SELECT AVG(SETTLE_PRICE) FROM FMS_FORWARD_PRICE_DTL " + 
						"WHERE CURVE_DT >= TO_DATE(?, 'DD/MM/YYYY') AND CURVE_DT <= TO_DATE(?, 'DD/MM/YYYY') AND CURVE_NM = ? " + 
						"AND TO_DATE(REPORT_DT,'DD/MM/YYYY')=(SELECT TO_DATE(MAX(REPORT_DT),'DD/MM/YYYY') FROM FMS_FORWARD_PRICE_DTL " + 
						" WHERE CURVE_TYPE='Forward' AND ENT_DT<=TO_DATE(?,'DD/MM/YYYY') " + 
						"AND CURVE_NM=? ) " + 
						"ORDER BY CURVE_DT DESC";
				 	stmt5 = conn.prepareStatement(fetchAppPrice);
					stmt5.setString(1, rset4.getString(1));
					stmt5.setString(2, rset4.getString(2));
					stmt5.setString(3, fin_curve);
					stmt5.setString(4, report_dt);
					stmt5.setString(5, fin_curve);*/
					rset5 = stmt5.executeQuery();
					
					if (rset5.next()) {
						appPrice = nf4.format(rset5.getDouble(1));//System.out.println(report_dt+":appPrice: "+appPrice);
//						appPriceUnit =  rset5.getString(2);
						appDate = settle_start_dt+"-"+settle_dt; //SB20260101
						appPrice2=rset5.getDouble(1);//SB20251229
						appPrice2=PriceDecimalPoint(PremDiscRate, PriceDeci, appPrice2);//SB20251229
						//System.out.println(report_dt+":appPrice2: "+appPrice2);
						appPrice=""+appPrice2;//SB20251229
					}
					else
						appPrice="0";//SB20251229
					rset5.close();
					stmt5.close();
				//	System.out.println(report_dt+":appPrice: "+appPrice);
				}	
				else {
					if (price_flag.equals("A")) {	/// Average 
						fetchAppPrice = "SELECT AVG(SETTLE_PRICE), CURVE_UNIT FROM FMS_SPOT_PRICE_DTL "
								+ "WHERE CURVE_DT >= TO_DATE(?, 'DD/MM/YYYY') AND CURVE_DT <= TO_DATE(?, 'DD/MM/YYYY') AND (PHYS_FIN = ? OR ACTUAL_CURVE=? ) "
								+ "GROUP BY CURVE_UNIT ";
						stmt5 = conn.prepareStatement(fetchAppPrice);
						stmt5.setString(1, settle_start_dt);
						stmt5.setString(2, settle_dt);
						stmt5.setString(3, fin_curve);
						stmt5.setString(4, fin_curve);
						rset5 = stmt5.executeQuery();
						
						if (rset5.next()) {
							appPrice = nf4.format(rset5.getDouble(1));
							appPriceUnit =  rset5.getString(2);
//							appDate = settle_start_dt;
							appDate = settle_start_dt+"-"+settle_dt; //SB20260101
							appPrice2=rset5.getDouble(1);//SB20251229
							appPrice2=PriceDecimalPoint(PremDiscRate, PriceDeci, appPrice2);//SB20251229
							appPrice=""+appPrice2;//SB20251229						
						}
						else
							appPrice="0";//SB20251229
						stmt5.close();
						rset5.close();
					}
					else if (price_flag.equals("F")) {	/// Final Settle Date
						fetchSettleCalnd = "SELECT SETTLE_PRICE, CURVE_UNIT FROM FMS_SPOT_PRICE_DTL "
								+ "WHERE CURVE_DT = TO_DATE(?, 'DD/MM/YYYY') "
							//	+ "AND PHYS_FIN = ? ";
						 + "AND ACTUAL_CURVE = ? "; //SB20260217
						stmt5 = conn.prepareStatement(fetchSettleCalnd);
						stmt5.setString(1, settle_dt);
						stmt5.setString(2, fin_curve);
						rset5 = stmt5.executeQuery();
						
						if (rset5.next()) {
							appPrice = nf4.format(rset5.getDouble(1));
							appPriceUnit =  rset5.getString(2);
//							appDate = settle_start_dt;
							appDate = settle_start_dt+"-"+settle_dt; //SB20260101
							appPrice2=rset5.getDouble(1);//SB20251229
							appPrice2=PriceDecimalPoint(PremDiscRate, PriceDeci, appPrice2);//SB20251229
							appPrice=""+appPrice2;//SB20251229
						}
						else
							appPrice="0";//SB20251229
						stmt5.close();
						rset5.close();
					}
					else if(price_flag.contains("O")) {	/// Other Average
						fetchSettleCalnd = "SELECT AVG(SETTLE_PRICE), CURVE_UNIT FROM FMS_SPOT_PRICE_DTL "
								+ "WHERE CURVE_DT >= (TO_DATE(?, 'DD/MM/YYYY')-?) AND CURVE_DT <= TO_DATE(?, 'DD/MM/YYYY') "
							//	+ "AND PHYS_FIN = ? "
								 + "AND ACTUAL_CURVE = ? " //SB20260217
								+ " GROUP BY CURVE_UNIT";
						stmt5 = conn.prepareStatement(fetchSettleCalnd);
						stmt5.setString(1, settle_dt);
						stmt5.setString(2, price_flag.substring(1));
						stmt5.setString(3, settle_dt);
						stmt5.setString(4, fin_curve);
						rset5 = stmt5.executeQuery();
						
						if (rset5.next()) {
							appPrice = nf4.format(rset5.getDouble(1));
						//	appPriceUnit =  rset5.getString(2);
//							appDate = settle_start_dt;
							appDate = settle_start_dt+"-"+settle_dt; //SB20260101
							appPrice2=rset5.getDouble(1);//SB20251229
							appPrice2=PriceDecimalPoint(PremDiscRate, PriceDeci, appPrice2);//SB20251229
							appPrice=""+appPrice2;//SB20251229
						}
						else
							appPrice="0";//SB20251229
						rset5.close();
						stmt5.close();
					}
					else if (price_flag.contains("D")) {	/// Average Settle Date
						fetchSettleCalnd = "SELECT AVG(SETTLE_PRICE), CURVE_UNIT FROM FMS_SPOT_PRICE_DTL "
								+ "WHERE CURVE_DT >= TO_DATE(?, 'DD/MM/YYYY') AND CURVE_DT <= TO_DATE(?, 'DD/MM/YYYY') "
							//	+ "AND PHYS_FIN = ? "
								 + "AND ACTUAL_CURVE = ? " //SB20260217
								+ " GROUP BY CURVE_UNIT";
						stmt5 = conn.prepareStatement(fetchSettleCalnd);
						stmt5.setString(1, from_dt);
						stmt5.setString(2, to_dt);
						stmt5.setString(3, fin_curve);
						rset5 = stmt5.executeQuery();
						
						if (rset5.next()) {
							appPrice = nf4.format(rset5.getDouble(1));
							appPriceUnit =  rset5.getString(2);
//							appDate = from_dt;
					//sb		appDate = to_dt;
							appDate = from_dt+"-"+to_dt; //SB20260101
							appPrice2=rset5.getDouble(1);//SB20251229
							appPrice2=PriceDecimalPoint(PremDiscRate, PriceDeci, appPrice2);//SB20251229
							appPrice=""+appPrice2;//SB20251229
						}
						else
							appPrice="0";//SB20251229
						rset5.close();
						stmt5.close();
					}
				}
				
				// In-Case of no pricing found.
				if (!appPrice.equals("")) {	//System.out.println(appPrice+":appPrice:"+slope+"+"+constant+":"+fin_curve);
				//SB20251229	appPrice = nf4.format(Double.parseDouble(appPrice) * Double.parseDouble(slope) + Double.parseDouble(constant));
				//SB20251229	appPrice = appPrice + " " + appPriceUnit;
					appPrice2 = (Double.parseDouble(appPrice) * Double.parseDouble(slope) + Double.parseDouble(constant));
					appPrice2=PriceDecimalPointFinal(FinalPriceDeci, appPrice2);//SB20241111
				//	appPrice = appPrice2 + " " + appPriceUnit;
					appPrice = appPrice2+"";// + " USD";
				}
				else {
					appPrice = "-";
					appDate = "-";
				}
			//	System.out.println(appPrice+":appPrice2: "+appPrice2);
		//		System.out.println(rset4.getString(1)+"=="+rset4.getString(2)+"=="+fin_curve);
		//		System.out.println(agmt_no+"=="+agmt_rev+"=="+cont_no+"=="+cont_rev+"=="+cont_type+"=="+price_flag);
			}
			
			rset4.close();
			stmt4.close();
			
			
		}
		catch(Exception e) {
			new SystemErrorLogger().InsertErrorLogger(db_src_file_name, function_nm, e);
		}
	}
	
	
	public void reqPriceForAllDeal(String to_date ) {
		String function_nm = "reqPriceForSalesDeal()";
		try {
			System.out.println("REQUEST for Price Change Started >>>>>>>>"+function_nm);
			String PriceEffDate=to_date;
			String tempStartDate[]=PriceEffDate.split("/");
			String GenMth=tempStartDate[1]; 
			String GenYr=tempStartDate[2]; 
			String GenMthYr=GenMth+"/"+GenYr;
			PriceEffDate="01/"+GenMthYr;//SB20260101
			
			String NEW_PRICE_EFF_DT = ""; msg="";
			CountPriceExistNo=0;
			int NoDays=0;
