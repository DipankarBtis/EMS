						}
						else {
							msg += VCONT_NO.elementAt(i)+" Price("+rset.getString(6)+") (NA Approval): ";
							msg_type = "E";
						}
					}
					else {
						msg += VCONT_NO.elementAt(i)+" Price Not Approved: ";
