						msg_type = "E";
					}
					
					rset.close();
					stmt.close();
				}
				else if (VBUY_SALE.elementAt(i).toString().equals("Buy") && !VDEAL_TYPE.elementAt(i).toString().equals("LNG") && chkUpdateFlag.split(":")[i].equals("Y")) {
					String chkAprvPrice = "SELECT A.SEQ_NO, A.FLAG, A.NEW_PRICE, TO_CHAR(A.EFF_DT, 'DD/MM/YYYY'), OLD_PRICE FROM FMS_TRADER_CONT_PRICE_DTL A "
							+ " WHERE A.COMPANY_CD = ? AND A.COUNTERPARTY_CD = ? AND A.CONT_NO = ? AND A.CONT_REV = ? AND A.CONTRACT_TYPE = ? "
							+ " AND A.SEQ_NO = (SELECT MAX(B.SEQ_NO) FROM FMS_TRADER_CONT_PRICE_DTL B WHERE A.COMPANY_CD = B.COMPANY_CD AND A.COUNTERPARTY_CD = B.COUNTERPARTY_CD AND "
							+ " A.CONT_NO = B.CONT_NO AND A.CONT_REV = B.CONT_REV AND A.CONTRACT_TYPE = B.CONTRACT_TYPE ) ";
					stmt = conn.prepareStatement(chkAprvPrice);
					stmt.setString(1, comp_cd);
					stmt.setString(2, VCOUNTERPARTY_CD.elementAt(i).toString());
					stmt.setString(3, VCONT_NO.elementAt(i).toString());
					stmt.setString(4, VCONT_REV.elementAt(i).toString());
					stmt.setString(5, VCONTRACT_TYPE.elementAt(i).toString());
					rset = stmt.executeQuery();
					
					if (rset.next()) {
						if (rset.getString(2).equals("Y")) {

							String updPrice = "UPDATE FMS_TRADER_CONT_PRICE_DTL SET FLAG = ?, MODIFIY_BY = ?, MODIFIY_DT = SYSDATE, APPROVE_BY = ?, APPROVE_DT = SYSDATE "
									+ " WHERE COMPANY_CD = ? AND  COUNTERPARTY_CD = ? AND AGMT_NO = ? AND AGMT_REV = ? AND CONT_NO = ? AND CONT_REV = ? AND CONTRACT_TYPE = ? AND SEQ_NO =? ";

							stmt1 = conn.prepareStatement(updPrice);
							stmt1.setString(1, "R");
							stmt1.setString(2, empCD);
							stmt1.setString(3, empCD);
							stmt1.setString(4, comp_cd);
							stmt1.setString(5, VCOUNTERPARTY_CD.elementAt(i).toString());
							stmt1.setString(6, VAGMT_NO.elementAt(i).toString());
							stmt1.setString(7, VAGMT_REV.elementAt(i).toString());
							stmt1.setString(8, VCONT_NO.elementAt(i).toString());
							stmt1.setString(9, VCONT_REV.elementAt(i).toString());
							stmt1.setString(10, VCONTRACT_TYPE.elementAt(i).toString());
							stmt1.setString(11, rset.getString(1));
							stmt1.executeUpdate();
							
							stmt1.close();
							
							updPrice = "UPDATE FMS_TRADER_CONT_MST A SET A.RATE = ? "
									+ " WHERE A.COMPANY_CD = ? AND  A.COUNTERPARTY_CD = ? AND A.AGMT_NO = ? AND A.AGMT_REV = ? AND A.CONT_NO = ? AND A.CONTRACT_TYPE = ? "
									+ " AND A.CONT_REV = (SELECT MAX(B.CONT_REV) FROM FMS_TRADER_CONT_MST B WHERE A.COMPANY_CD = B.COMPANY_CD AND A.COUNTERPARTY_CD = B.COUNTERPARTY_CD AND A.AGMT_NO = B.AGMT_NO "
									+ " AND A.AGMT_REV = B.AGMT_REV AND A.CONT_NO = B.CONT_NO AND A.CONTRACT_TYPE = B.CONTRACT_TYPE )";

							stmt1 = conn.prepareStatement(updPrice);
							stmt1.setString(1, rset.getString(5));
							stmt1.setString(2, comp_cd);
							stmt1.setString(3, VCOUNTERPARTY_CD.elementAt(i).toString());
							stmt1.setString(4, VAGMT_NO.elementAt(i).toString());
							stmt1.setString(5, VAGMT_REV.elementAt(i).toString());
							stmt1.setString(6, VCONT_NO.elementAt(i).toString());
							stmt1.setString(7, VCONTRACT_TYPE.elementAt(i).toString());
							stmt1.executeUpdate();
							
							stmt1.close();

							msg += VCONT_NO.elementAt(i)+" Price("+rset.getString(4)+") Revoked: "+rset.getString(5);
							msg_type = "S";
							conn.commit();
							CountPriceExistNo++;
						}
						else {
							msg += VCONT_NO.elementAt(i)+" Not Revoked: ";
							msg_type = "E";
						}
					}
					else {
						msg += VCONT_NO.elementAt(i)+" Approved Price NA.";
						msg_type = "E";
					}
					
					rset.close();
					stmt.close();
				}
			}
			msg="("+CountPriceExistNo+" "+action+")  "+msg;
		}
		catch(Exception e) {
			msg = "Failed to Revoke Price.";
			msg_type = "E";
			new SystemErrorLogger().InsertErrorLogger(db_src_file_name, function_nm, e);
		}
	}
	
