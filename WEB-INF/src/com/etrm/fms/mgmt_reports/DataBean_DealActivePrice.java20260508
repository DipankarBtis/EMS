	public double PriceDecimalPoint(Double PremDiscRate, String PriceDeci, Double avgCommodityValue)
	{
		String function_nm = "PriceDecimalPoint()";
		double price=0;
		try
		{
			 ///////////////////////SB20240530: Price Decimal Point formating/////////////////////
			//	System.out.println(PriceDeci+":AVG(Forward): avgCommodityValue: "+Min_Eff_avgCommodityValue);
				if(PriceDeci.equals("0"))
					avgCommodityValue=Double.parseDouble(nf.format(avgCommodityValue+PremDiscRate));
				else if(PriceDeci.equals("1"))
					avgCommodityValue=Double.parseDouble(nf1.format(avgCommodityValue+PremDiscRate));
				else if(PriceDeci.equals("2"))
					avgCommodityValue=Double.parseDouble(nf2.format(avgCommodityValue+PremDiscRate));
				else if(PriceDeci.equals("3"))
					avgCommodityValue=Double.parseDouble(nf3.format(avgCommodityValue+PremDiscRate));
				else if(PriceDeci.equals("4"))
					avgCommodityValue=Double.parseDouble(nf4.format(avgCommodityValue+PremDiscRate));
				else
					avgCommodityValue=Double.parseDouble(nf4.format(avgCommodityValue+PremDiscRate));
				///////////////////////^^SB20240530: Price Decimal Point formating////////////////////
		}
		catch(Exception e)
		{
			new SystemErrorLogger().InsertErrorLogger(db_src_file_name, function_nm, e);
		}		
		return avgCommodityValue;
	}
	
	public double PriceDecimalPointFinal(String FinalPriceDeci, Double Eff_avgCommodityValue)
	{
		String function_nm = "PriceDecimalPointFinal()";
		double price=0;
		try
		{
			 ///////////////////////SB20240530: Price Decimal Point formating/////////////////////
			//	System.out.println(PriceDeci+":AVG(Forward): avgCommodityValue: "+Min_Eff_avgCommodityValue);
				if(FinalPriceDeci.equals("0"))
					Eff_avgCommodityValue=Double.parseDouble(nf.format(Eff_avgCommodityValue));
				else if(FinalPriceDeci.equals("1"))
					Eff_avgCommodityValue=Double.parseDouble(nf1.format(Eff_avgCommodityValue));
				else if(FinalPriceDeci.equals("2"))
					Eff_avgCommodityValue=Double.parseDouble(nf2.format(Eff_avgCommodityValue));
				else if(FinalPriceDeci.equals("3"))
					Eff_avgCommodityValue=Double.parseDouble(nf3.format(Eff_avgCommodityValue));
				else if(FinalPriceDeci.equals("4"))
					Eff_avgCommodityValue=Double.parseDouble(nf4.format(Eff_avgCommodityValue));
				else
					Eff_avgCommodityValue=Double.parseDouble(nf4.format(Eff_avgCommodityValue));
				///////////////////////^^SB20240530: Price Decimal Point formating////////////////////
		}
		catch(Exception e)
		{
			new SystemErrorLogger().InsertErrorLogger(db_src_file_name, function_nm, e);
		}		
		return Eff_avgCommodityValue;
	}
	

	// SagarB20251229 Function to Insert Columns (if not exists)
	
	// SagarB20251229 Function to fetch Variable Price
	public void getVariablePriceConfigDtl()
	{
		String function_nm="getVariablePriceConfigDtl()";
		try
		{
			counterparty_abbr=utilBean.getCounterpartyABBR(conn,counterparty_cd);
			display_map_id=utilBean.NewDealMappingId(comp_cd, counterparty_cd, agmt_no, agmt_rev, cont_no, cont_rev, cont_type, cargo_no);
			String sysdate = utilDate.getSysdate();
			
			String queryString="SELECT TO_CHAR(FROM_DT,'DD/MM/YYYY'),TO_CHAR(TO_DT,'DD/MM/YYYY'),RATE,RATE_UNIT,PRICE_TYPE,PHYS_CURVE_NM,"
					+ "SLOPE,CONST,REMARKS,SEQ_NO,CURVE_NM,PRICE_RANGE,TO_CHAR(PRICE_START_DT,'DD/MM/YYYY'),TO_CHAR(PRICE_END_DT,'DD/MM/YYYY'),"
					+ "CURVE_LOGIC,FORMULA "
					+ ", NVL(PRICE_DECI, ''), NVL(FINAL_PRICE_DECI, ''), NVL(PREM_DISC_RATE, '') "
					+ "FROM FMS_CONT_PRICE_DTL "
					+ "WHERE COMPANY_CD=? AND CONTRACT_TYPE=? "
					+ "AND MAPPING_ID=? "
					+ "ORDER BY FROM_DT";
		//	System.out.println(display_map_id+"::::"+comp_cd+":"+cont_type+":"+mapping_id+":InVarPrice: "+queryString);
			stmt = conn.prepareStatement(queryString);
			stmt.setString(1, comp_cd);
			stmt.setString(2, cont_type);
			stmt.setString(3, mapping_id);
			rset=stmt.executeQuery();
			while(rset.next())
			{
				String st_dt = rset.getString(1)==null?"":rset.getString(1);
				String end_dt = rset.getString(2)==null?"":rset.getString(2);
				
				VSTART_DT.add(st_dt);
				VEND_DT.add(end_dt);
				VPRICE_RATE.add(rset.getString(3)==null?"":rset.getString(3));
				String price_rate_unit=rset.getString(4)==null?"":rset.getString(4);
				VPRICE_RATE_UNIT.add(price_rate_unit);
				VPRICE_RATE_UNIT_NM.add(utilBean.getRateUnitNm(conn,price_rate_unit));
				String price_type = rset.getString(5)==null?"":rset.getString(5);
				VPRICE_TYPE.add(price_type);
				VPHY_CURV.add(rset.getString(6)==null?"":rset.getString(6));
				VREMARK.add(rset.getString(9)==null?"":rset.getString(9));
				String seq_no=rset.getString(10)==null?"":rset.getString(10);
				VSEQ_NO.add(rset.getString(10)==null?"":rset.getString(10));
				String price_range = rset.getString(12)==null?"A":rset.getString(12);
				String price_start_dt = rset.getString(13)==null?"":rset.getString(13);
				String price_end_dt = rset.getString(14)==null?"":rset.getString(14);
				
				VPRICE_START_DT.add(price_start_dt);
				VPRICE_END_DT.add(price_end_dt);
				
				int isExpired = utilDate.getDays(end_dt, sysdate);
				
				if(isExpired<0)
				{
					VIS_RADIO_ENABLE.add("N");
				}
				else
				{
					VIS_RADIO_ENABLE.add("Y");
				}
				
				String formula=rset.getString(16)==null?"":rset.getString(16);
				String curve_logic=rset.getString(15)==null?"":rset.getString(15);
				VCURVE_LOGIC.add(curve_logic);
				VFORMULA.add(formula);
				
				// SagarB20260212
//				if(curve_logic.equals("MIN") || curve_logic.equals("MAX") || curve_logic.equals("AVG"))
				if(curve_logic.equals("MIN") || curve_logic.equals("MAX") || curve_logic.equals("AVG") || curve_logic.equals("MIN_ADV"))
				{
					String slop_1="",cont_1="",cur_nm_1="",priceRange_1="",priceRangeNm_1="",date_1="";
					String slop="",cont="",cur_nm="",priceRange="",priceRangeNm="",priceStDt="",priceEndDt="";
					String  formula_1 = "", temp_formula = "";	// SagarB20260212
					String PriceDeci="",PriceDisAdj="", PriceDeci2="", PriceDisAdj2=""; int RowCount=0;
					String queryString1="SELECT CURVE_NM,SLOPE,CONST,PRICE_RANGE,TO_CHAR(PRICE_START_DT,'DD/MM/YYYY'),TO_CHAR(PRICE_END_DT,'DD/MM/YYYY') "
							+ ", NVL(PRICE_DECI, ''), NVL(PREM_DISC_RATE, ''),"
							+ " FORMULA "		// SagarB20260212
							+ "FROM FMS_CONT_PRICE_MIN_DTL "
							+ "WHERE COMPANY_CD=? AND CONTRACT_TYPE=? "
							+ "AND MAPPING_ID=? AND SEQ_NO=?";
					stmt1 = conn.prepareStatement(queryString1);
					stmt1.setString(1, comp_cd);
					stmt1.setString(2, cont_type);
					stmt1.setString(3, mapping_id);
					stmt1.setString(4, seq_no);
					rset1=stmt1.executeQuery();
					while(rset1.next())
					{
						cur_nm = rset1.getString(1)==null?"":rset1.getString(1);
						slop = rset1.getString(2)==null?"":rset1.getString(2);
						cont = rset1.getString(3)==null?"":rset1.getString(3);
						priceRange=rset1.getString(4)==null?"A":rset1.getString(4);
						priceStDt=rset1.getString(5)==null?"":rset1.getString(5); 
						priceEndDt=rset1.getString(6)==null?"":rset1.getString(6);
						PriceDeci=(rset1.getString(7)==null?"":rset1.getString(7));
						PriceDisAdj=(rset1.getString(8)==null?"":rset1.getString(8));

						temp_formula=rset1.getString(9)==null?"":rset1.getString(9);	// SagarB20260212
						
						priceRangeNm=getPriceRangeNm(priceRange,priceStDt,priceEndDt);
						
						if(slop_1.equals(""))
						{
							slop_1=slop;
						}
						else
						{
							slop_1+="<br>"+slop;
						}
						if(cont_1.equals(""))
						{
							cont_1=cont;
						}
						else
						{
							cont_1+="<br>"+cont;
						}
						if(cur_nm_1.equals(""))
						{
							cur_nm_1 = cur_nm;
						}
						else
						{
							cur_nm_1 += "<br>"+cur_nm;
						}
						if(priceRange_1.equals(""))
						{
							priceRange_1=priceRange;
						}
						else
						{
							priceRange_1+="<br>"+priceRange;
						}
						if(priceRangeNm_1.equals(""))
						{
							priceRangeNm_1=priceRangeNm;
						}
						else
						{
							priceRangeNm_1+="<br>"+priceRangeNm;
						}
						if(date_1.equals(""))
						{
							date_1=priceStDt+"-"+priceEndDt;
						}
						else
						{
							date_1+="<br>"+priceStDt+"-"+priceEndDt;
						}
						if(RowCount==0)
						{
							PriceDeci2=PriceDeci;
							PriceDisAdj2=PriceDisAdj;
						}
						else
						{
							PriceDeci2+="<br>"+PriceDeci;
							PriceDisAdj2+="<br>"+PriceDisAdj;
						}
						
						// SagarB20260212
						if(formula_1.equals(""))
						{
							formula_1=temp_formula.equals("")?" ":temp_formula;
						}
						else
						{
							formula_1+="<br>"+(temp_formula.equals("")?" ":temp_formula);
						}
						RowCount++;
					}
					VSLOPE.add(slop_1);
					VCONSTANT.add(cont_1);
					VCURVE_NM.add(cur_nm_1);
					VPRICE_RANGE.add(priceRange_1);
					VPRICE_RANGE_NM.add(priceRangeNm_1);
					VMIN_PRICE_ST_END_DT.add(date_1);
					VPRICE_DECI.add(PriceDeci2);
					VFINAL_PRICE_DECI.add(rset.getString(18)==null?"":rset.getString(18));
					VPREM_DISC_RATE.add(PriceDisAdj2);
					VMIN_FORMULA.add(formula_1);	// SagarB20260212
					
					rset1.close();
					stmt1.close();
				}
				else
				{
					VSLOPE.add(rset.getString(7)==null?"1":rset.getDouble(7));
					VCONSTANT.add(rset.getString(8)==null?"0":rset.getDouble(8));
					VCURVE_NM.add(rset.getString(11)==null?"":rset.getString(11));
					VPRICE_RANGE.add(price_range);
					if(price_type.equals("M"))
					{
						VPRICE_RANGE_NM.add(getPriceRangeNm(price_range,price_start_dt,price_end_dt));
					}
					else
					{
						VPRICE_RANGE_NM.add("");
					}
					VMIN_PRICE_ST_END_DT.add("");
					VPRICE_DECI.add(rset.getString(17)==null?"":rset.getString(17));
					VFINAL_PRICE_DECI.add(rset.getString(18)==null?"":rset.getString(18));
					VPREM_DISC_RATE.add(rset.getString(19)==null?"":rset.getString(19));
					VMIN_FORMULA.add("");	// SagarB20260212
				}			
			}
			rset.close();
			stmt.close();
			
			/*SB20260309	int NoDays=0, TotalDealDays=0;
				
				queryString = "SELECT TO_DATE(?,'DD/MM/YYYY')-TO_DATE(?,'DD/MM/YYYY') FROM DUAL" ;//SB20230721: Removed +1 day
				//	System.out.println(rset1.getString(2)+" DUAL: LAST: "+queryString);
					stmt3 = conn.prepareStatement(queryString);
			
				for(int i=0; i<VSTART_DT.size(); i++)
				{		
					NoDays=0;
				    	stmt3.setString(1, ""+VEND_DT.elementAt(i));
					stmt3.setString(2, ""+VSTART_DT.elementAt(i));//"01"+rpt_dt.substring(2));
					rset3 = stmt3.executeQuery();
						if(rset3.next()) {
							NoDays = rset3.getInt(1);
							TotalDealDays+=NoDays;
						}
					VPriceNoDays.add(NoDays+" Days");
				}
				rset3.close();
				stmt3.close();*/
		}
		catch(Exception e)
		{
			new SystemErrorLogger().InsertErrorLogger(db_src_file_name, function_nm, e);
		}
