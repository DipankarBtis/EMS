							NEW_PRICE_EFF_DT = rset2.getString(1) == null ? "" : rset2.getString(1);
							NEW_SALE_PRICE = rset2.getString(2) == null ? "0" : rset2.getString(2);
						//	System.out.println(NEW_SALE_PRICE+":IF:NEW_SALE_PRICE/NEW_PRICE_EFF_DT:"+NEW_PRICE_EFF_DT);
						}
						else //SB20260303
							NEW_SALE_PRICE = rset.getString(5) == null ? "0" : rset.getString(5); //SB20260303
						rset2.close();
						stmt2.close();
					//	System.out.println(NEW_SALE_PRICE+":NEW_SALE_PRICE/NEW_PRICE_EFF_DT:"+NEW_PRICE_EFF_DT);
						String[] tempContName=ContName.split("REV");
						//ContName=ContName.split("REV")[0]+"REV"+ContName.split("REV")[1]+"REV"+rset.getString(4);//SB20260101
						if(tempContName.length>1)
							ContName=tempContName[0]+"REV"+tempContName[1]+"REV"+rset.getString(4);//SB20260101
						if(VCONTRACT_TYPE.elementAt(i).equals("X"))
							ContName=tempContName[0]+"REV"+rset.getString(4);//SB20260101
						
						//ContName=ContName.substring(0, ContName.length()-1)+modSeq;//SB20260101
					//	System.out.println("modSeq: "+modSeq);
						String purCont = "0", cargo_no = "0", alloc_qty = "0", costPrice = "", salePrice = "";
						String oriMargin = "", newMargin = "";
						String oriAvgMargin = "0", newAvgMargin = "0";
						String oriTotMargin = "", newTotMargin = "";
						
						String fetchPurCont = "SELECT PUR_CONT_NO, CARGO_NO, ALLOC_QTY, COST_PRICE, SALE_PRICE, MARGIN, TOTAL_MARGIN, AVG_MARGIN, CP_UNIT, RATE_UNIT FROM FMS_SUPPLY_PURCHASE_MAP_DTL A "
								+ " WHERE A.COMPANY_CD = ? AND A.COUNTERPARTY_CD = ? AND A.AGMT_NO = ? AND A.AGMT_REV = ? AND A.CONT_NO = ? AND A.CONTRACT_TYPE = ? "
								+ " AND A.CONT_REV = (SELECT MAX(B.CONT_REV) FROM FMS_SUPPLY_PURCHASE_MAP_DTL B WHERE A.PUR_CONT_NO = B.PUR_CONT_NO "
								+ " AND A.COMPANY_CD = B.COMPANY_CD AND A.COUNTERPARTY_CD = B.COUNTERPARTY_CD AND A.AGMT_NO = B.AGMT_NO AND A.CONT_NO = B.CONT_NO )";

						stmt2 = conn.prepareStatement(fetchPurCont);
						stmt2.setString(1, comp_cd);
						stmt2.setString(2, VCOUNTERPARTY_CD.elementAt(i).toString());
						stmt2.setString(3, VAGMT_NO.elementAt(i).toString());
						stmt2.setString(4, VAGMT_REV.elementAt(i).toString());
						stmt2.setString(5, VCONT_NO.elementAt(i).toString());
						stmt2.setString(6, VCONTRACT_TYPE.elementAt(i).toString());
						rset2 = stmt2.executeQuery();
						
						if (rset2.next()) {
							purCont = rset2.getString(1);
							cargo_no = rset2.getString(2);
							alloc_qty = rset2.getString(3);
							costPrice = rset2.getString(4);
							salePrice = rset2.getString(5);
							oriMargin = rset2.getString(6);
//							oriAvgMargin = rset2.getString(8);
							oriTotMargin = rset2.getString(7);
							
							if (rset2.getString(9).equals("1")) {
								costPrice = nf4.format(rset2.getDouble(4) / Double.parseDouble(exchgVal));  
							}
							if (rset2.getString(10).equals("1")) {
								salePrice = nf4.format(rset2.getDouble(5) / Double.parseDouble(exchgVal));  
							}
						}
						rset2.close();
						stmt2.close();
						
					//	System.out.println("costPrice: "+costPrice);		
						appPrice = "0";
						if (!VAPPLICABLE_RATE.elementAt(i).toString().contains("-")) {
							appPrice = VAPPLICABLE_RATE.elementAt(i).toString().split(" ")[0];
						}
						if(appPrice.equals(""))
							appPrice = "0";
						if(costPrice.equals(""))//SB20260309
							costPrice = "0"; //SB20260309
						PriceEffDate=""+VBILL_FREQ_DT.elementAt(i);
				//		System.out.println(VAPPLICABLE_RATE.elementAt(i).toString()+" :Applicable Price: "+appPrice);
				//		System.out.println(PriceEffDate+":Applicable Date: "+appDate+":"+NEW_SALE_PRICE);
						// Calculating new margins
						newMargin = nf4.format(Double.parseDouble(appPrice) - Double.parseDouble(costPrice));
						newTotMargin = nf4.format(Double.parseDouble(alloc_qty) * Double.parseDouble(newMargin));
		
						appDate=PriceEffDate;//SB20260101
						remark = appPrice + " " + PriceEffDate + " (New Price Requested)";//SB20260101
					//	if(NEW_SALE_PRICE.equals(appPrice))
					//SB20260309	if(Double.parseDouble(NEW_SALE_PRICE)==Double.parseDouble(appPrice))
						if(BigDecimal.valueOf(Double.parseDouble(NEW_SALE_PRICE)).compareTo(BigDecimal.valueOf(Double.parseDouble(appPrice)))==0)
							PriceExist="Y";
						else
							PriceExist="N";
					//	System.out.println(PriceExist+":appPrice: "+appPrice+":"+NEW_SALE_PRICE);
						if (!PriceExist.equals("Y") && !appPrice.equals("0") && !appPrice.equals("")) 
						{
							String insertSalesRequest = "INSERT INTO FMS_SUPPLY_CONT_MST(COMPANY_CD,COUNTERPARTY_CD,AGMT_NO,AGMT_REV,CONT_NO,CONT_REV,CONTRACT_TYPE,"
									+ "CONT_NAME,CONT_REF_NO,TRADE_REF_NO,SIGNING_DT,SIGNING_TIME,START_DT,END_DT,AGMT_BASE,AGMT_TYPE,TCQ,DCQ,VARIABLE_DCQ,QUANTITY_UNIT,"
									+ "RATE,RATE_UNIT,VARIABLE_RATE,POST_MARGIN,TRANSPORTATION_CHARGE,BUYER_NOM_FLAG,BUYER_MONTH_NOM,BUYER_WEEK_NOM,BUYER_DAILY_NOM,"
									+ "SELLER_NOM_FLAG,SELLER_MONTH_NOM,SELLER_WEEK_NOM,SELLER_DAILY_NOM,DAY_DEF_FLAG,DAY_START_TIME,DAY_END_TIME,MDCQ_FLAG,MDCQ_PERCENTAGE,FCC_FLAG,FCC_BY,FCC_DATE,"
									+ "REMARK,RENEWAL_DT,ENT_DT,ENT_BY,MODIFY_DT,MODIFY_BY,CONT_STATUS,IS_ALLOCATED,DDA_DT,DDA_TIME,BUYER_FORNGT_NOM,SELLER_FORNGT_NOM,TXN_CHARGE,BUYER_NOM_CUTOFF,TXN_UNIT,"
									+ "TCQ_SIGN,TCQ_REQUEST_FLAG,TCQ_REQUEST_CLOSE,TCQ_REQUEST_QTY,PRICE_REQUEST_FLAG,PRICE_APPROVE_FLAG,CHANGE_DATE_REQ,MEASUREMENT,MEASUREMENT_CLAUSE,MEAS_STANDARD,"
									+ "MEAS_TEMPERATURE,PRESSURE_MIN_BAR,PRESSURE_MAX_BAR,OFF_SPEC_GAS,OFF_SPEC_GAS_CLAUSE,SPEC_GAS_ENERGY_BASE,SPEC_GAS_MIN_ENERGY,SPEC_GAS_MAX_ENERGY,LIABILITY,LIABILITY_CLAUSE,"
									+ "BILLING_FLAG,BILLING_CLAUSE,TERMINATE_FLAG,TERMINATE_CLAUSE,TERMINATE_PLANED,TERMINATE_FORCE,SF_GEN_DT,CLOSURE_REQUEST_FLAG,CLOSE_EFF_DT,CLOSURE_ALLOC_QTY,"
									+ "CLOSURE_REMARK,ADV_ADJUST,CHANGE_DATE_APPROVE,CHANGE_START_DT,CHANGE_END_DT) "
