	private String PriceMailBody2(String company_cd) throws Exception
	{
		String function_nm="PriceMailBody2()";
		String mailBody="";
		try
		{
		String CompanyName="";
			String highlight_aprv="#00cc00";
			String highlight_request="yellow";
			String highlight_reje="red";
			String mail_subject="Price Change ";
			int count=0, NoCount=0;
			String tempchkUpdateFlag[]=chkUpdateFlag.split(":");
			String ReqAprRate="", ReqAprDate="", ReqAprBackColor="";
			String context=utilBean.getAutomationKeyDetail(conn, "ENV_CONTEXT");
			if(!context.contains("EMS"))
				context="EMS "+context;
			mail_subject=context+" Price Change ";
			mailBody="<html>";
		
			if(action.equals("request"))
				{
					mailBody+="<font style='background:"+highlight_request+"' color='black'>Auto Price Change for "+VRATE_EFF_DT.elementAt(0)+"</font><br>"
						+ "<span style='font-size:"+CommonVariable.mail_font_size+";font-family:"+CommonVariable.mail_font_family+";'>Execution Date: "+rpt_dt+"</span><br>";
					mailBody+= "<span style='font-size:"+CommonVariable.mail_font_size+";font-family:"+CommonVariable.mail_font_family+";'>Following CounterParty Contract Prices have been Requested: ";
					mail_subject+="(Requested): ";
				}
			else if(action.equals("approve"))
				{
					mailBody+="<font style='background:"+highlight_aprv+"' color='white'>Auto Price Change for "+VRATE_EFF_DT.elementAt(0)+"</font><br>"
						+ "<span style='font-size:"+CommonVariable.mail_font_size+";font-family:"+CommonVariable.mail_font_family+";'>Execution Date: "+rpt_dt+"</span><br>";
					mailBody+= "<span style='font-size:"+CommonVariable.mail_font_size+";font-family:"+CommonVariable.mail_font_family+";'>Following CounterParty Contract Prices have been Approved: ";
					mail_subject+="(Approved): ";
				}
			if((action.equals("request") || action.equals("approve")))
			{
				if(company_cd.equals("1")) CompanyName="SEMTIPL";
				else if(company_cd.equals("2")) CompanyName="SEIPL";
				
					mailBody+="<table bordercolor='black' style='font-size:"+CommonVariable.mail_font_size+";font-family:"+CommonVariable.mail_font_family+";padding:2px;' border='1' cellpadding='0' cellspacing='0'>";
					mailBody+= "<tr style='background:lightgrey'>"
							+ "<td align='center'><b>Sr#</b></td>"
							+ "<td><b>&nbsp;"+CompanyName+": Legal Entity</b>&nbsp;</td>"
							+ "<td align='center'><b>&nbsp;Contract# (Ref#)</b>&nbsp;</td>"
							+ "<td align='center'><b>&nbsp;Deal Duration</b>&nbsp;</td>"
							+ "<td align='center'><b>&nbsp;Deal Type</b>&nbsp;</td>"
							+ "<td align='center'><b>&nbsp;Old Price</b></td>"
							+ "<td align='center'><b>&nbsp;New Price</b></td>"
							+ "</tr>";
				//	System.out.println(VAPPLICABLE_RATE.size()+":VAPPLICABLE_RATE: "+VAPPLICABLE_RATE);
				//	System.out.println(VAWAITING_RATE.size()+":VAWAITING_RATE: "+VAWAITING_RATE);
				for (int i=0; i<VCOUNTERPARTY_ABBR.size(); i++)	
				{ 
					ReqAprRate="";	//System.out.println(tempchkUpdateFlag[i]+":Active Deal Price: "+VPriceAppl.elementAt(i));
					if(action.equals("request")) { ReqAprRate=""+VAPPLICABLE_RATE.elementAt(i); ReqAprDate=""+VBILL_FREQ_DT.elementAt(i);ReqAprBackColor=highlight_request; }
					else if(action.equals("approve")) { ReqAprRate=""+VAWAITING_RATE.elementAt(i); ReqAprBackColor=highlight_aprv; }
					
					if(tempchkUpdateFlag.length>1 && !VPriceAppl.elementAt(i).equals("Y"))
					{
				//	if (!VPriceAppl.elementAt(i).equals("Y")) 
					//if((action.equals("request") || action.equals("approve") && !VAWAITING_RATE.elementAt(i).equals("")) && tempchkUpdateFlag[i].equals("Y"))
						if(!ReqAprRate.equals("") && tempchkUpdateFlag[i].equals("Y"))
						{
							count++;
							mail_subject+=VCOUNTERPARTY_ABBR.elementAt(i)+":"+VDEAL_NUMBER.elementAt(i)+"~";
							mailBody+=""
							+ "<tr>"
							+ "<td>&nbsp;"+count+"&nbsp;</td>"
							+ "<td>&nbsp;"+VCOUNTERPARTY_ABBR.elementAt(i)+"-"+VCOUNTERPARTY_NM.elementAt(i)+"&nbsp;</td>"
							+ "<td>&nbsp;"+VDEAL_NUMBER.elementAt(i)+" ("+VDEAL_REF.elementAt(i)+")&nbsp;</td>"
							+ "<td>&nbsp;"+VCONT_PERIOD.elementAt(i)+"&nbsp;</td>"
							+ "<td>&nbsp;"+VBUY_SALE.elementAt(i)+" ("+VDEAL_TYPE.elementAt(i)+")&nbsp;</td>"
							+ "<td style='background:D9D9F3';>&nbsp;"+VAPPROVED_RATE.elementAt(i)+"&nbsp;"+VAPPROVED_DATE.elementAt(i)+"</td>"
							+ "<td style='background:"+ReqAprBackColor+"';>&nbsp;"+ReqAprRate+"&nbsp;"+ReqAprDate+"</td>"
							+ "</tr>";					
						}
						else
						{
							NoCount++;
						}
					}
			}
			mailBody+= "<tr style='background:lightgrey'><td align='right' colspan=7><b>&nbsp;</b></td></tr>";
			mailBody+= 	"</table>"
					+ "<br><br><br><font style='font-size:"+CommonVariable.mail_font_size+";font-family:"+CommonVariable.mail_font_family+";'>Please maintain confidentiality."
					+ "<br><b>NOTE:</b><i> System Generated Notification - Please do not Reply.</i>"
					+ "</html>";
			} //EoF if((action.equals("request") || action.equals("approve")))
			String to_mail_list="";
			String cc_mail_list="";
			
			if((action.equals("request") || action.equals("approve")))
			{
				to_mail_list = utilBean.getToMailReceipentList(conn,comp_cd,"Active Deal Price", "Mgmt Reports", "NA", "On-Event");
				cc_mail_list = utilBean.getCcMailReceipentList(conn,comp_cd,"Active Deal Price", "Mgmt Reports", "NA", "On-Event");
			}
			System.out.println(action+":Email Delivered, No of Contract: "+CountPriceExistNo);
			if((action.equals("request") || action.equals("approve")) && (!to_mail_list.equals("") && CountPriceExistNo>0))
			{
				mailDelv.sendMail(comp_cd,to_mail_list, mail_subject, mailBody, "", cc_mail_list, "");
				System.out.println(action+":Email Delivered To: "+to_mail_list+":CC::"+cc_mail_list);
			}
		}
		catch(Exception e)
		{
			new SystemErrorLogger().InsertErrorLogger(db_src_file_name, function_nm, e);
		}
		
		return mailBody;
	}
