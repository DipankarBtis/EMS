									VTEMP_SLOT_START_TIME.add(rset4.getString(5)==null?"":rset4.getString(5));
									VTEMP_SLOT_END_TIME.add(rset4.getString(6)==null?"":rset4.getString(6));
									VTEMP_ARRIVAL_DT.add(rset4.getString(7)==null?"":rset4.getString(7));
									VTEMP_ARRIVAL_TIME.add(rset4.getString(8)==null?"":rset4.getString(8));
									VTEMP_NEXT_AVAIL_HRS.add(rset4.getString(9)==null?"":rset4.getString(9));
									VTEMP_REMARK.add(rset4.getString(10)==null?"":rset4.getString(10));
									
									String fill_station_cd = rset4.getString(3)==null?"":rset4.getString(3);
									String bay_cd = rset4.getString(4)==null?"":rset4.getString(4);
									String slot_start_time = rset4.getString(5)==null?"":rset4.getString(5);
									String slot_end_time = rset4.getString(6)==null?"":rset4.getString(6);
									
									String map_id=fill_station_cd+"-"+bay_cd+"-"+slot_start_time+"-"+slot_end_time;
						  			
									double truck_allocated_qty =getTruckAllocatedQty(countpty_cd,cont, agmt, cont_type, gas_dt, fill_station_cd, bay_cd,
											slot_start_time, slot_end_time,transCd, truck_cd);
									
									VTEMP_TRUCK_ALLOCATED_QTY.add(truck_allocated_qty);
									
						  			int isInvoiceSubmitted=isInvoiceSubmitted(countpty_cd, cont, agmt, plant_seq, cont_type, bu_plant_seq, weekofdt,truck_cd,transCd,map_id, false);
									if(isInvoiceSubmitted>0)
									{
										VTEMP_NOM_BLOCK.add("Y");
									}
									else
									{
										int isTruckAllocated=isTruckAllocated(countpty_cd, cont, agmt, plant_seq, cont_type, bu_plant_seq, weekofdt,truck_cd,transCd,fill_station_cd, bay_cd, slot_start_time, slot_end_time);
										if(isTruckAllocated>0)
										{
											total_buyerNom = total_buyerNom - truck_allocated_qty;
											
											VTEMP_NOM_BLOCK.add("A");
										}
										else
										{
											VTEMP_NOM_BLOCK.add("N");
										}
									}
								}
								rset4.close();
								stmt4.close();
							}
							rset6.close();
							stmt6.close();
							
							rowspan = indexOut;
						}
						rset1.close();
						stmt1.close();
					}
					rset3.close();
					stmt3.close();
					
					VCONT_BUYER_NOM.add(nf.format(total_buyerNom));
					
					VMST_TRUCK_TRANS_CD.add(VTEMP_MST_TRUCK_TRANS_CD);
					VMST_TRUCK_CD.add(VTEMP_MST_TRUCK_CD);
					VMST_TRUCK_REG_NUM.add(VTEMP_MST_TRUCK_REG_NUM);
					
					FillStationData data = getFillStContWise(companyCd,countpty_cd,agmt,cont,cont_type,agmt_rev,cont_rev);
					
					VMST_FILLST_CD.add(data.fillStationCodes);
					VMST_FILLST_NM.add(data.fillStationNames);
					VMST_FILLST_ABBR.add(data.fillStationAbbrs);
					
					VTOTAL_TRUCK_TRANS_CD.add(VTEMP_TRUCK_TRANS_CD);
					VTOTAL_TRUCK_CD.add(VTEMP_TRUCK_CD);
					VTOTAL_TRUCK_REG_NUM.add(VTEMP_TRUCK_REG_NUM);
					VTOTAL_TRUCK_VOL_M3.add(VTEMP_TRUCK_VOL_M3);
					VTOTAL_TRUCK_VOL_MT.add(VTEMP_TRUCK_VOL_MT);
					VTOTAL_TRUCK_LOAD_CAP.add(VTEMP_TRUCK_LOAD_CAP);
					VTOTAL_QTY_MMBTU.add(VTEMP_QTY_MMBTU);
					VTOTAL_QTY_MT.add(VTEMP_QTY_MT);
					VTOTAL_FILL_STATION_CD.add(VTEMP_FILL_STATION_CD);
					VTOTAL_BAY_CD.add(VTEMP_BAY_CD);
					VTOTAL_SLOT_START_TIME.add(VTEMP_SLOT_START_TIME);
					VTOTAL_SLOT_END_TIME.add(VTEMP_SLOT_END_TIME);
					VTOTAL_ARRIVAL_DT.add(VTEMP_ARRIVAL_DT);
					VTOTAL_ARRIVAL_TIME.add(VTEMP_ARRIVAL_TIME);
					VTOTAL_NEXT_AVAIL_HRS.add(VTEMP_NEXT_AVAIL_HRS);
					VTOTAL_REMARK.add(VTEMP_REMARK);
					VTOTAL_AVAIL_DT.add(VTEMP_TRUCK_AVAIL_DT);
					VTOTAL_NOM_BLOCK.add(VTEMP_NOM_BLOCK);
					VTOTAL_TRUCK_ALLOCATED_QTY.add(VTEMP_TRUCK_ALLOCATED_QTY);
					
					if(index1>0)
					{
						VTRUCK_LINKED.add("Y");
					}
					else
					{
						VTRUCK_LINKED.add("N");
					}

					//GET SELLER NOMINATION DATA FOR THE CONTRACT WISE
					queryString2="SELECT NOM_REV_NO,GEN_TIME,BASE,GCV,NCV,SUM(QTY_MMBTU),SUM(QTY_MT),TO_CHAR(GEN_DT,'DD/MM/YYYY') "
							+ "FROM FMS_DLNG_SELLER_NOM_DTL A "
							+ "WHERE CONT_NO=? AND AGMT_NO=? "
							+ "AND COMPANY_CD=? AND COUNTERPARTY_CD=? "
							+ "AND PLANT_SEQ=? AND CONTRACT_TYPE=? AND BU_SEQ=? "
							+ "AND GAS_DT=TO_DATE(?,'DD/MM/YYYY') AND CARGO_NO=? "
							+ "AND NOM_REV_NO=(SELECT MAX(NOM_REV_NO) FROM FMS_DLNG_SELLER_NOM_DTL B "
							+ "WHERE B.CONT_NO=A.CONT_NO AND B.AGMT_NO=A.AGMT_NO "
							+ "AND B.COMPANY_CD=A.COMPANY_CD AND B.COUNTERPARTY_CD=A.COUNTERPARTY_CD "
							+ "AND B.BU_SEQ=A.BU_SEQ "
							+ "AND B.PLANT_SEQ=A.PLANT_SEQ AND B.CONTRACT_TYPE=A.CONTRACT_TYPE "
							+ "AND B.GAS_DT=A.GAS_DT AND B.CARGO_NO=A.CARGO_NO) "
							+ "GROUP BY NOM_REV_NO,GEN_TIME,BASE,GCV,NCV,GEN_DT ";
					stmt2 = conn.prepareStatement(queryString2);
					stmt2.setString(1, cont);
					stmt2.setString(2, agmt);
					stmt2.setString(3, companyCd);
					stmt2.setString(4, countpty_cd);
					stmt2.setString(5, plant_seq);
					stmt2.setString(6, cont_type);
					stmt2.setString(7, bu_plant_seq);
					stmt2.setString(8, weekofdt);
					stmt2.setString(9, cargo_no);
					rset2=stmt2.executeQuery();
					if(rset2.next())
					{
						VNOM_REV_NO.add(rset2.getString(1)==null?"":rset2.getString(1));
						VGEN_TIME.add(rset2.getString(2)==null?"":rset2.getString(2));
						VBASE.add(rset2.getString(3)==null?"":rset2.getString(3));
						VGCV.add(rset2.getString(4)==null?"9802.80":rset2.getString(4));
						VNCV.add(rset2.getString(5)==null?"8831.35":rset2.getString(5));
						VQTY_MMBTU.add(nf.format(rset2.getDouble(6)));
						VQTY_MT.add(nf.format(rset2.getDouble(7)));
						
						String base = rset2.getString(3)==null?"":rset2.getString(3);
						double mmbtu = rset2.getDouble(6);
						double mt = rset2.getDouble(7);
						double gcv = rset2.getDouble(4);
						double ncv = rset2.getDouble(5);
						double multiplying_factor = 0.252*1000000;
						
						double scm =0.00;
						
						if(base.equals("GCV"))
						{
							scm = (mmbtu * multiplying_factor)/(gcv*1);
						}
						else
						{
							scm = (mmbtu * multiplying_factor)/(ncv*1.11);
						}
						
						VQTY_SCM.add(nf.format(Math.ceil(scm)));
						
						VGEN_DT.add(rset2.getString(8)==null?"":rset2.getString(8));
						
						VNOM_COLOR.add("#99ffcc");	
						
						/*submitted_count++;
						trans_plant_wise_total_mmbtu += rset2.getDouble(6);
						trans_plant_wise_total_scm += rset2.getDouble(7);*/
						
						VBUYER_NOM_REV_NO.add(nom_rev_no);
						VBUYER_NOM.add(nf.format(buyer_nom_mmbtu));
					}
					else
					{
						//GET BUYER NOMINATION DATA FOR THE CONTRACT WISE
						VNOM_REV_NO.add("");
						VBASE.add(buyer_base);
						VGCV.add(buyer_gcv);
						VNCV.add(buyer_ncv);
						VQTY_MMBTU.add(nf.format(buyer_nom_mmbtu));
						VQTY_SCM.add(nf.format(buyer_nom_scm));
						VQTY_MT.add(nf.format(buyer_nom_mt));
						VGEN_DT.add(buyer_gen_dt);
						
						VBUYER_NOM_REV_NO.add(nom_rev_no);
						VBUYER_NOM.add(nf.format(buyer_nom_mmbtu));
						
						String split[] = dateTime.split(" ");
						VGEN_TIME.add(split[1]);
						VNOM_COLOR.add("");
					}
					rset2.close();
					stmt2.close();
					
					index1=0;
					
					VINDEX1.add(index1);
				}
				
				if(periodic_i>0)
				{
					VGAS_INDEX.add(gas_index);
					VROWSPAN.add(rowspan);
				}
				
				String total_mmbtu_color="green";
				VTOTAL_MMBTU_COLOR.add(total_mmbtu_color);
				
				rset.close();
				stmt.close();
			}
			entry_range+=total_entry;
			VENTRY_RANGE.add(entry_range);
		}
		catch(Exception e)
		{
			new SystemErrorLogger().InsertErrorLogger(db_src_file_name, function_nm, e);
		}
	}

	public void getDailyAllocation() 
	{
		String function_nm="getDailyAllocation()";
		try
		{
			dateTime = dateUtil.getSysdateWithTime24hr();

			String queryString_temp="SELECT DISTINCT A.COMPANY_CD,A.COUNTERPARTY_CD "
					+ "FROM FMS_SUPPLY_CONT_MST A,"
						+ "FMS_SUPPLY_CONT_PLANT B, "
						+ "FMS_SUPPLY_CONT_BU D, "
						+ "FMS_DLNG_SELLER_NOM_DTL E "
					+ "WHERE A.COMPANY_CD=? AND A.BUYER_NOM_FLAG=? AND A.FCC_FLAG=? AND A.IS_ALLOCATED=? "
					+ "AND A.START_DT<=TO_DATE(?,'DD/MM/YYYY') AND A.END_DT>=TO_DATE(?,'DD/MM/YYYY') "
					+ "AND A.CONTRACT_TYPE IN ('F','E','W') "
					+ "AND A.CONT_REV=(SELECT MAX(CONT_REV) FROM FMS_SUPPLY_CONT_MST B WHERE A.COMPANY_CD=B.COMPANY_CD AND A.COUNTERPARTY_CD=B.COUNTERPARTY_CD "
					+ "AND A.AGMT_NO=B.AGMT_NO AND A.AGMT_REV=B.AGMT_REV AND A.CONT_NO=B.CONT_NO AND A.CONTRACT_TYPE=B.CONTRACT_TYPE) "
					+ ""
					+ "AND A.COMPANY_CD=B.COMPANY_CD AND A.COUNTERPARTY_CD=B.COUNTERPARTY_CD AND A.AGMT_NO=B.AGMT_NO AND A.AGMT_REV=B.AGMT_REV "
					+ "AND A.CONT_NO=B.CONT_NO AND A.CONT_REV=B.CONT_REV AND A.CONTRACT_TYPE=B.CONTRACT_TYPE "
					+ ""
					+ "AND A.COMPANY_CD=D.COMPANY_CD AND A.COUNTERPARTY_CD=D.COUNTERPARTY_CD AND A.AGMT_NO=D.AGMT_NO AND A.AGMT_REV=D.AGMT_REV "
					+ "AND A.CONT_NO=D.CONT_NO AND A.CONT_REV=D.CONT_REV AND A.CONTRACT_TYPE=D.CONTRACT_TYPE "
					+ ""
					+ "AND A.COMPANY_CD=E.COMPANY_CD AND A.COUNTERPARTY_CD=E.COUNTERPARTY_CD AND A.AGMT_NO=E.AGMT_NO AND A.AGMT_REV=E.AGMT_REV "
					+ "AND A.CONT_NO=E.CONT_NO "
					+ " AND A.CONTRACT_TYPE=E.CONTRACT_TYPE "//AND B.PLANT_SEQ_NO=E.PLANT_SEQ AND D.PLANT_SEQ_NO=E.BU_SEQ
					+ " AND E.PLANT_SEQ=B.PLANT_SEQ_NO AND E.BU_SEQ=D.PLANT_SEQ_NO AND E.GAS_DT=TO_DATE(?,'DD/MM/YYYY') "
					+ " AND E.NOM_REV_NO=(SELECT MAX(NOM_REV_NO) FROM FMS_DLNG_SELLER_NOM_DTL F "
					+ " WHERE F.CONT_NO=E.CONT_NO AND F.AGMT_NO=E.AGMT_NO AND F.COMPANY_CD=E.COMPANY_CD AND F.COUNTERPARTY_CD=E.COUNTERPARTY_CD "
					+ " AND F.BU_SEQ=E.BU_SEQ "
					+ " AND F.PLANT_SEQ=E.PLANT_SEQ AND F.CONTRACT_TYPE=E.CONTRACT_TYPE AND F.GAS_DT=E.GAS_DT AND E.CARGO_NO=F.CARGO_NO) "
					+ ""
					+ " UNION "
					+ ""
					+ "SELECT DISTINCT A.COMPANY_CD,A.COUNTERPARTY_CD "
					+ "FROM FMS_LTCORA_CONT_MST A,"
						+ "FMS_LTCORA_CONT_CARGO_DTL B,"
						+ "FMS_SUPPLY_CONT_PLANT C, "
						+ "FMS_LTCORA_CONT_BU D, "
						+ "FMS_DLNG_SELLER_NOM_DTL E "
					+ "WHERE A.COMPANY_CD=? AND A.BUY_SALE=? AND A.FCC_FLAG=? AND B.CARGO_STATUS=? AND A.AGMT_TYPE=? AND B.BOE_NO IS NOT NULL "
					+ "AND TO_DATE(TO_CHAR(B.ACTUAL_RECPT_DT,'DD/MM/YYYY'),'DD/MM/YYYY')<=TO_DATE(?,'DD/MM/YYYY') AND TO_DATE(TO_CHAR(B.ACTUAL_RECPT_DT,'DD/MM/YYYY'),'DD/MM/YYYY')+NVL(STORAGE_DAYS-1,0)+NVL(STORAGE_EXT_DAYS,0) >=TO_DATE(?,'DD/MM/YYYY') "
					+ "AND A.CONT_REV = (SELECT MAX(B.CONT_REV) FROM FMS_LTCORA_CONT_MST B WHERE A.COMPANY_CD=B.COMPANY_CD "
					+ "AND A.COUNTERPARTY_CD=B.COUNTERPARTY_CD AND A.CONT_NO=B.CONT_NO AND A.AGMT_NO=B.AGMT_NO AND A.AGMT_REV=B.AGMT_REV "
					+ "AND A.CONTRACT_TYPE=B.CONTRACT_TYPE AND A.BUY_SALE=B.BUY_SALE AND A.AGMT_TYPE=B.AGMT_TYPE) "
					+ ""
					+ "AND A.COMPANY_CD=B.COMPANY_CD AND A.COUNTERPARTY_CD=B.COUNTERPARTY_CD AND A.CONT_NO=B.CONT_NO "
					+ "AND A.AGMT_NO=B.AGMT_NO AND A.AGMT_REV=B.AGMT_REV AND A.CONTRACT_TYPE=B.CONTRACT_TYPE AND A.BUY_SALE=B.BUY_SALE AND A.AGMT_TYPE=B.AGMT_TYPE "
					+ ""
					+ "AND A.COMPANY_CD=C.COMPANY_CD AND A.COUNTERPARTY_CD=C.COUNTERPARTY_CD AND A.AGMT_NO=C.AGMT_NO AND A.AGMT_REV=C.AGMT_REV "
					+ "AND A.CONT_NO=C.CONT_NO AND A.CONT_REV=C.CONT_REV AND A.CONTRACT_TYPE=C.CONTRACT_TYPE "
					+ ""
					+ "AND A.COMPANY_CD=D.COMPANY_CD AND A.COUNTERPARTY_CD=D.COUNTERPARTY_CD AND A.AGMT_NO=D.AGMT_NO AND A.AGMT_REV=D.AGMT_REV "
					+ "AND A.CONT_NO=D.CONT_NO AND A.CONT_REV=D.CONT_REV AND A.CONTRACT_TYPE=D.CONTRACT_TYPE "
					+ ""
