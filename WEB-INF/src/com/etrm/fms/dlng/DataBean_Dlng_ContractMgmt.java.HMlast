	public void getDailyBuyerNomination()
	{
		String function_nm="getDailyBuyerNomination()";
		try
		{
			dateTime = dateUtil.getSysdateWithTime24hr();
			String temp_gen_dt=dateUtil.getDate(gas_dt, "-1");
			
			int stmt_cnt=0;
			
			int sub_index=0;
			double trans_plant_wise_total_mmbtu=0;
			double trans_plant_wise_total_scm=0;
			int total_entry=-1;
			
			String entry_range=(total_entry+1)+"-";

			int count = dateUtil.getDays(to_date,from_date);
			
			for(int k=0; k<count; k++)
			{
				String weekofdt=""+dateUtil.getDate(from_date, ""+k);

				int gas_index=0;
				int rowspan=0;
				int periodic_i=0;
				int indexOut=0;
				
				queryString="SELECT A.COMPANY_CD,A.COUNTERPARTY_CD,A.AGMT_NO,A.AGMT_REV,A.CONT_NO,A.CONT_REV,A.CONTRACT_TYPE,"
						+ "A.CONT_REF_NO,"
						+ "'','',"
						+ "A.DCQ,A.CONT_NAME,A.MDCQ_PERCENTAGE,A.TRADE_REF_NO,"
						+ "B.PLANT_SEQ_NO,D.COMPANY_CD,D.PLANT_SEQ_NO,0,'CONT',NULL,NULL,A.TCQ "
						+ "FROM FMS_SUPPLY_CONT_MST A, FMS_SUPPLY_CONT_PLANT B,FMS_SUPPLY_CONT_BU D "
						+ "WHERE A.COMPANY_CD=? AND A.BUYER_NOM_FLAG=? AND A.FCC_FLAG=? AND A.IS_ALLOCATED=? "
						+ "AND A.START_DT<=TO_DATE(?,'DD/MM/YYYY') AND A.END_DT>=TO_DATE(?,'DD/MM/YYYY') "
						+ "AND A.CONTRACT_TYPE IN ('F','E','W') "
						+ "AND A.CONT_REV=(SELECT MAX(CONT_REV) FROM FMS_SUPPLY_CONT_MST B WHERE A.COMPANY_CD=B.COMPANY_CD AND A.COUNTERPARTY_CD=B.COUNTERPARTY_CD "
						+ "AND A.AGMT_NO=B.AGMT_NO AND A.AGMT_REV=B.AGMT_REV AND A.CONT_NO=B.CONT_NO AND A.CONTRACT_TYPE=B.CONTRACT_TYPE) "
						+ "AND A.COMPANY_CD=B.COMPANY_CD AND A.COUNTERPARTY_CD=B.COUNTERPARTY_CD AND A.AGMT_NO=B.AGMT_NO AND A.AGMT_REV=B.AGMT_REV "
						+ "AND A.CONT_NO=B.CONT_NO AND A.CONT_REV=B.CONT_REV AND A.CONTRACT_TYPE=B.CONTRACT_TYPE "
						+ "AND A.COMPANY_CD=D.COMPANY_CD AND A.COUNTERPARTY_CD=D.COUNTERPARTY_CD AND A.AGMT_NO=D.AGMT_NO AND A.AGMT_REV=D.AGMT_REV "
						+ "AND A.CONT_NO=D.CONT_NO AND A.CONT_REV=D.CONT_REV AND A.CONTRACT_TYPE=D.CONTRACT_TYPE ";
				if(callFlag.equalsIgnoreCase("PERIODIC_BUYER_NOM"))
				{
					queryString+="AND A.COUNTERPARTY_CD=? AND A.AGMT_NO=? AND A.AGMT_REV=? AND A.CONT_NO=? AND A.CONT_REV=? AND A.CONTRACT_TYPE=? ";
				}
				queryString+= " UNION ALL "
						+ "SELECT A.COMPANY_CD,A.COUNTERPARTY_CD,A.AGMT_NO,A.AGMT_REV,A.CONT_NO,A.CONT_REV,A.CONTRACT_TYPE,"
						+ "B.CARGO_REF,'','',B.CSOC_QTY,A.CONT_NAME,A.MDCQ_PERCENTAGE,NULL,"
						+ "D.PLANT_SEQ_NO,E.COMPANY_CD,E.PLANT_SEQ_NO,B.CARGO_NO,'LTCORA',A.BUY_SALE,A.AGMT_TYPE,NULL "
						+ ""
						+ "FROM FMS_LTCORA_CONT_MST A,FMS_LTCORA_CONT_CARGO_DTL B,FMS_SUPPLY_CONT_PLANT D,FMS_LTCORA_CONT_BU E "
						+ ""
						+ "WHERE A.COMPANY_CD=? AND A.BUY_SALE=? AND A.FCC_FLAG=? AND B.CARGO_STATUS=? AND A.AGMT_TYPE=? AND B.BOE_NO IS NOT NULL "
						+ "AND TO_DATE(TO_CHAR(B.ACTUAL_RECPT_DT,'DD/MM/YYYY'),'DD/MM/YYYY')<=TO_DATE(?,'DD/MM/YYYY') AND TO_DATE(TO_CHAR(B.ACTUAL_RECPT_DT,'DD/MM/YYYY'),'DD/MM/YYYY')+NVL(STORAGE_DAYS-1,0)+NVL(STORAGE_EXT_DAYS,0) >=TO_DATE(?,'DD/MM/YYYY') "
						+ "AND A.TLU_FLAG=? "
						+ ""
						+ "AND A.CONT_REV = (SELECT MAX(B.CONT_REV) FROM FMS_LTCORA_CONT_MST B WHERE A.COMPANY_CD=B.COMPANY_CD "
						+ "AND A.COUNTERPARTY_CD=B.COUNTERPARTY_CD AND A.CONT_NO=B.CONT_NO AND A.AGMT_NO=B.AGMT_NO AND A.AGMT_REV=B.AGMT_REV "
						+ "AND A.CONTRACT_TYPE=B.CONTRACT_TYPE AND A.BUY_SALE=B.BUY_SALE AND A.AGMT_TYPE=B.AGMT_TYPE) "
						+ ""
						+ "AND A.COMPANY_CD=B.COMPANY_CD AND A.COUNTERPARTY_CD=B.COUNTERPARTY_CD AND A.CONT_NO=B.CONT_NO "
						+ "AND A.AGMT_NO=B.AGMT_NO AND A.AGMT_REV=B.AGMT_REV AND A.CONTRACT_TYPE=B.CONTRACT_TYPE AND A.BUY_SALE=B.BUY_SALE AND A.AGMT_TYPE=B.AGMT_TYPE "
						+ ""
						+ "AND A.COMPANY_CD=D.COMPANY_CD AND A.COUNTERPARTY_CD=D.COUNTERPARTY_CD AND A.CONT_NO=D.CONT_NO AND A.CONT_REV=D.CONT_REV "
						+ "AND A.AGMT_NO=D.AGMT_NO AND A.AGMT_REV=D.AGMT_REV AND A.CONTRACT_TYPE=D.CONTRACT_TYPE "
						+ ""
						+ "AND A.COMPANY_CD=E.COMPANY_CD AND A.COUNTERPARTY_CD=E.COUNTERPARTY_CD AND A.CONT_NO=E.CONT_NO AND A.CONT_REV=E.CONT_REV "
						+ "AND A.AGMT_NO=E.AGMT_NO AND A.AGMT_REV=E.AGMT_REV AND A.CONTRACT_TYPE=E.CONTRACT_TYPE AND A.BUY_SALE=E.BUY_SALE AND A.AGMT_TYPE=E.AGMT_TYPE ";
				if(callFlag.equalsIgnoreCase("PERIODIC_BUYER_NOM"))
				{
					queryString+="AND A.COUNTERPARTY_CD=? AND A.AGMT_NO=? AND A.AGMT_REV=? AND A.CONT_NO=? AND A.CONT_REV=? AND A.CONTRACT_TYPE=? AND B.CARGO_NO=? ";
				}
				stmt_cnt=0;
				stmt = conn.prepareStatement(queryString);
				stmt.setString(++stmt_cnt, comp_cd);
				stmt.setString(++stmt_cnt, "Y");
				stmt.setString(++stmt_cnt, "Y");
				stmt.setString(++stmt_cnt, "Y");
				stmt.setString(++stmt_cnt, weekofdt);
				stmt.setString(++stmt_cnt, weekofdt);
				if(callFlag.equalsIgnoreCase("PERIODIC_BUYER_NOM"))
				{
					stmt.setString(++stmt_cnt, counterparty_cd);
					stmt.setString(++stmt_cnt, agmt_no);
					stmt.setString(++stmt_cnt, agmt_rev_no);
					stmt.setString(++stmt_cnt, cont_no);
					stmt.setString(++stmt_cnt, cont_rev_no);
					stmt.setString(++stmt_cnt, contract_type);
				}
				stmt.setString(++stmt_cnt, comp_cd);
				stmt.setString(++stmt_cnt, "C");
				stmt.setString(++stmt_cnt, "Y");
				stmt.setString(++stmt_cnt, "Y");
				stmt.setString(++stmt_cnt, "A");
				stmt.setString(++stmt_cnt, weekofdt);
				stmt.setString(++stmt_cnt, weekofdt);
				stmt.setString(++stmt_cnt, "Y");
				if(callFlag.equalsIgnoreCase("PERIODIC_BUYER_NOM"))
				{
					stmt.setString(++stmt_cnt, counterparty_cd);
					stmt.setString(++stmt_cnt, agmt_no);
					stmt.setString(++stmt_cnt, agmt_rev_no);
					stmt.setString(++stmt_cnt, cont_no);
					stmt.setString(++stmt_cnt, cont_rev_no);
					stmt.setString(++stmt_cnt, contract_type);
					stmt.setString(++stmt_cnt, cargo_no); 
				}
				rset=stmt.executeQuery();
				while(rset.next())
				{
					indexOut++;
					
					if(callFlag.equalsIgnoreCase("PERIODIC_BUYER_NOM"))
					{
						if(periodic_i==0) {
							VGAS_DT.add(weekofdt);
							int tempDays=dateUtil.getDays(dateUtil.getSysdate(), weekofdt);
							if(tempDays<=0)
							{
								temp_gen_dt=dateUtil.getSysdate();
							}
							else
							{
								temp_gen_dt=dateUtil.getDate(weekofdt, "-1");
							}
							
							sub_index++;
						}
						periodic_i++;
					}
					else
					{
						sub_index++;
					}
					
					gas_index++;
					total_entry++;
					
					String companyCd = rset.getString(1)==null?"":rset.getString(1);
					String countpty_cd = rset.getString(2)==null?"":rset.getString(2);
					String agmt = rset.getString(3)==null?"":rset.getString(3);
					String agmt_rev = rset.getString(4)==null?"":rset.getString(4);
					String cont = rset.getString(5)==null?"":rset.getString(5);
					String cont_rev = rset.getString(6)==null?"":rset.getString(6);
					String cont_type = rset.getString(7)==null?"":rset.getString(7);
					String cont_ref = rset.getString(8)==null?"":rset.getString(8);
					String transporter_cd = rset.getString(9)==null?"":rset.getString(9);
					String transporter_plant_seq = rset.getString(10)==null?"":rset.getString(10);
					String dcq = nf.format(rset.getDouble(11));
					String cont_name = rset.getString(12)==null?"":rset.getString(12);
					String mdcq_percentage = nf.format(rset.getDouble(13));
					double mdcq_qty = (Double.parseDouble(dcq)*Double.parseDouble(mdcq_percentage))/100;
					
					String trade_ref = rset.getString(14)==null?"":rset.getString(14);
					if(cont_type.equals("W")) {
						cont_ref=trade_ref;
					}
					
					String plant_seq = rset.getString(15)==null?"":rset.getString(15);
					String plant_abbr=utilBean.getCounterpartyPlantABBR(conn,countpty_cd, companyCd, plant_seq, "C");
					String buCd = rset.getString(16)==null?"":rset.getString(16);
					String bu_plant_seq = rset.getString(17)==null?"":rset.getString(17);
					String bu_plant_abbr=utilBean.getCounterpartyPlantABBR(conn,buCd, comp_cd, bu_plant_seq, "B");
					String cargo_no = rset.getString(18)==null?"0":rset.getString(18);
					String contractName = rset.getString(19)==null?"":rset.getString(19);
					String buySell = rset.getString(20)==null?"":rset.getString(20);
					String agmtType = rset.getString(21)==null?"":rset.getString(21);

					double tcq = rset.getDouble(22);
					
					String internal_map_id = cont_type+"-"+countpty_cd+"-"+agmt+"-"+agmt_rev+"-"+cont+"-"+cont_rev;
					String ct_cont_mapping = cont_type+"-"+countpty_cd+"-"+agmt+"-%-"+cont+"-%";
					String customer_code=""+utilBean.getTranspoterCustomerCode(conn,companyCd, transporter_cd, countpty_cd, plant_seq, weekofdt);
					
					String dis_cont_mapping= utilBean.NewDealMappingId(companyCd, countpty_cd, agmt, agmt_rev, cont, cont_rev, cont_type, cargo_no);
					
					String variable_dcq="";
					String billingFrq="";
					String taxDtl="";
					if(contractName.equals("LTCORA"))
					{
						ct_cont_mapping+="-"+cargo_no;
						internal_map_id+="-"+cargo_no;
						variable_dcq=utilBean.getCargoVariableCSOC(conn,companyCd, countpty_cd, buySell, agmt, cont, cont_type, cargo_no, weekofdt);
						
						queryString2="SELECT BILLING_FREQ "
								+ "FROM FMS_LTCORA_CONT_BILLING_DTL A "
								+ "WHERE COMPANY_CD=? AND COUNTERPARTY_CD=? AND BUY_SALE=? AND AGMT_TYPE=? "
								+ "AND AGMT_NO=? AND AGMT_REV=? AND CONT_NO=? AND CONT_REV=? AND CONTRACT_TYPE=? ";
						stmt2 = conn.prepareStatement(queryString2);
						stmt2.setString(1, companyCd);
						stmt2.setString(2, countpty_cd);
						stmt2.setString(3, buySell);
						stmt2.setString(4, agmtType);
						stmt2.setString(5, agmt);
						stmt2.setString(6, agmt_rev);
						stmt2.setString(7, cont);
						stmt2.setString(8, cont_rev);
						stmt2.setString(9, cont_type);
						rset2=stmt2.executeQuery();
						if(rset2.next())
				  		{
				  			billingFrq=rset2.getString(1)==null?"":rset2.getString(1);
				  		}
						rset2.close();
						stmt2.close();
						
						String periodStDt=utilBean.getFirstDtOfBillingCycle(billingFrq, "", weekofdt);
						taxDtl=utilBean.getEntityServiceStructureDtl(conn,companyCd, countpty_cd, "C", plant_seq, bu_plant_seq, periodStDt,"SI");
					}
					else
					{
						variable_dcq=utilBean.getContVariableDCQ(conn,companyCd, countpty_cd, agmt, cont, cont_type, weekofdt);
						
						queryString2="SELECT BILLING_FREQ "
								+ "FROM FMS_SUPPLY_BILLING_DTL A "
								+ "WHERE COMPANY_CD=? AND COUNTERPARTY_CD=? "
								+ "AND AGMT_NO=? "//AND AGMT_REV='"+agmt_rev+"' "
								+ "AND CONT_NO=? "//AND CONT_REV='"+cont_rev+"' "
								+ "AND CONTRACT_TYPE=? "
								+ "AND EFF_DT=(SELECT MAX(EFF_DT) FROM FMS_SUPPLY_BILLING_DTL B WHERE A.COMPANY_CD=B.COMPANY_CD "
								+ "AND A.COUNTERPARTY_CD=B.COUNTERPARTY_CD AND A.AGMT_NO=B.AGMT_NO AND A.CONT_NO=B.CONT_NO "
								+ "AND A.CONTRACT_TYPE=B.CONTRACT_TYPE AND TO_DATE(?,'DD/MM/YYYY') > EFF_DT)";
						stmt2 = conn.prepareStatement(queryString2);
						stmt2.setString(1, companyCd);
						stmt2.setString(2, countpty_cd);
						stmt2.setString(3, agmt);
						stmt2.setString(4, cont);
						stmt2.setString(5, cont_type);
						stmt2.setString(6, weekofdt);
						rset2=stmt2.executeQuery();
						if(rset2.next())
				  		{
				  			billingFrq=rset2.getString(1)==null?"":rset2.getString(1);
				  		}
						rset2.close();
						stmt2.close();
						
						String periodStDt=utilBean.getFirstDtOfBillingCycle(billingFrq, "", weekofdt);
						taxDtl=utilBean.getEntityTaxStructureDtl(conn,companyCd, countpty_cd, "C", plant_seq, bu_plant_seq, periodStDt, "S");
					}
					if(!variable_dcq.equals(""))
					{
						dcq=variable_dcq;
					}
					
					VCOUNTERPARTY_CD.add(countpty_cd);
					VCOUNTERPARTY_ABBR.add(""+utilBean.getCounterpartyABBR(conn,countpty_cd));
					VCOUNTERPARTY_NM.add(""+utilBean.getCounterpartyName(conn,countpty_cd));
					VAGMT_NO.add(agmt);
					VAGMT_REV_NO.add(agmt_rev);
					VCONT_NO.add(cont);
					VCONT_REV_NO.add(cont_rev);
					VCONTRACT_TYPE.add(cont_type);
					VCARGO_NO.add(cargo_no);
					VDIS_CONT_MAPPING.add(dis_cont_mapping);
					VCOUNTERPARTY_PLANT_SEQ.add(plant_seq);
					VCOUNTERPARTY_PLANT_ABBR.add(plant_abbr);
					VBU_CD.add(buCd);
					VBU_PLANT_SEQ.add(bu_plant_seq);
					VBU_PLANT_ABBR.add(bu_plant_abbr);
					VDCQ.add(dcq);
					
					double allocated_qty =getAllocatedQty(countpty_cd,cont, agmt, cont_type, gas_dt, cargo_no);
					
					VALLOCATED_MMBTU.add(nf.format(allocated_qty));
					
					double dcq_mt = (Double.parseDouble(dcq) / Double.parseDouble("51.5"));
					
					VDCQ_MT.add(nf.format(dcq_mt));
					VCONT_REF.add(cont_ref);
					VCONT_NAME.add(cont_name);
					VMDCQ_QTY.add(nf.format(mdcq_qty));
					VINTERNAL_MAP_ID.add(internal_map_id);
					
					VCUSTOMER_CODE.add(customer_code);
					VTAX_DTL.add(taxDtl);
					
					//GET BUYER NOMINATION DATA FOR THE CONTRACT WISE
					queryString2="SELECT NOM_REV_NO,GEN_TIME,BASE,GCV,NCV,QTY_MMBTU,QTY_SCM,TO_CHAR(GEN_DT,'DD/MM/YYYY'),QTY_MT "
							+ "FROM FMS_DLNG_BUYER_NOM A "
							+ "WHERE CONT_NO=? AND AGMT_NO=? "
							+ "AND COMPANY_CD=? AND COUNTERPARTY_CD=? "
							+ "AND PLANT_SEQ=? AND CONTRACT_TYPE=? AND BU_SEQ=? "
							+ "AND GAS_DT=TO_DATE(?,'DD/MM/YYYY') AND CARGO_NO=? "
							+ "AND NOM_REV_NO=(SELECT MAX(NOM_REV_NO) FROM FMS_DLNG_BUYER_NOM B "
							+ "WHERE B.CONT_NO=A.CONT_NO AND B.AGMT_NO=A.AGMT_NO "
							+ "AND B.COMPANY_CD=A.COMPANY_CD AND B.COUNTERPARTY_CD=A.COUNTERPARTY_CD "
							+ "AND A.BU_SEQ=B.BU_SEQ "
							+ "AND B.PLANT_SEQ=A.PLANT_SEQ AND B.CONTRACT_TYPE=A.CONTRACT_TYPE "
							+ "AND B.GAS_DT=A.GAS_DT AND B.CARGO_NO=A.CARGO_NO) ";
					stmt2 = conn.prepareStatement(queryString2);
					stmt2.setString(1, cont);
					stmt2.setString(2, agmt);
					stmt2.setString(3, companyCd);
					stmt2.setString(4, countpty_cd);
					stmt2.setString(5, plant_seq);
					stmt2.setString(6, cont_type);
					stmt2.setString(7, bu_plant_seq);
					stmt2.setString(8, weekofdt);
					stmt2.setString(9, cargo_no);
					rset2=stmt2.executeQuery();
					if(rset2.next())
					{
						VNOM_REV_NO.add(rset2.getString(1)==null?"":rset2.getString(1));
						VGEN_TIME.add(rset2.getString(2)==null?"":rset2.getString(2));
						VBASE.add(rset2.getString(3)==null?"":rset2.getString(3));
						VGCV.add(rset2.getString(4)==null?"9802.80":rset2.getString(4));
						VNCV.add(rset2.getString(5)==null?"8831.35":rset2.getString(5));
						VQTY_MMBTU.add(nf.format(rset2.getDouble(6)));
						VQTY_SCM.add(nf.format(rset2.getDouble(7)));
						VQTY_MT.add(nf.format(rset2.getDouble(9)));
						VGEN_DT.add(rset2.getString(8)==null?"":rset2.getString(8));
						
						VNOM_COLOR.add("#99ffcc");	
						
						trans_plant_wise_total_mmbtu += rset2.getDouble(6);
						trans_plant_wise_total_scm += rset2.getDouble(7);
					}
					else
					{
						VNOM_REV_NO.add("");
						
						String split[] = dateTime.split(" ");
						//VGEN_DT.add(split[0]);
						VGEN_DT.add(temp_gen_dt);
						VGEN_TIME.add(split[1]);
						VBASE.add("GCV");
						VGCV.add("9802.80");
						VNCV.add("8831.35");
						VQTY_MMBTU.add("");
						VQTY_SCM.add("");
						VQTY_MT.add("");
						VNOM_COLOR.add("");
					}
					rset2.close();
					stmt2.close();	
					
					int index1=0;
					
					Vector VTEMP_MST_TRUCK_TRANS_CD = new Vector();
					Vector VTEMP_MST_TRUCK_CD = new Vector();
					Vector VTEMP_MST_TRUCK_REG_NUM = new Vector();
					
					Vector VTEMP_MST_TRUCK_VOL_M3 = new Vector();
					Vector VTEMP_MST_TRUCK_VOL_MT = new Vector();
					Vector VTEMP_MST_TRUCK_LOAD_CAP = new Vector();
					
					Vector VTEMP_TRUCK_TRANS_CD = new Vector();
					Vector VTEMP_TRUCK_CD = new Vector();
					Vector VTEMP_TRUCK_REG_NUM = new Vector();
					Vector VTEMP_TRUCK_VOL_M3= new Vector();
					Vector VTEMP_TRUCK_VOL_MT = new Vector();
					Vector VTEMP_TRUCK_LOAD_CAP = new Vector();
					Vector VTEMP_QTY_MMBTU = new Vector();
					Vector VTEMP_QTY_MT = new Vector();
					Vector VTEMP_FILL_STATION_CD = new Vector();
					Vector VTEMP_BAY_CD = new Vector();
					Vector VTEMP_SLOT_START_TIME = new Vector();
					Vector VTEMP_SLOT_END_TIME = new Vector();
					Vector VTEMP_ARRIVAL_DT = new Vector();
					Vector VTEMP_ARRIVAL_TIME = new Vector();
					Vector VTEMP_NEXT_AVAIL_HRS = new Vector();
					Vector VTEMP_REMARK = new Vector();
					Vector VTEMP_TRUCK_AVAIL_DT = new Vector();
					Vector VTEMP_NOM_BLOCK = new Vector();
					
					String queryString="SELECT TRANSPORTER_CD "
							+ "FROM FMS_SUPPLY_CONT_TRUCK_TRANS "
							+ "WHERE COMPANY_CD=? AND COUNTERPARTY_CD=? AND CONT_NO=? "
							+ "AND CONT_REV=? AND AGMT_NO=? AND AGMT_REV=? "
							+ "AND CONTRACT_TYPE=?";
					stmt3 = conn.prepareStatement(queryString);
					stmt3.setString(1, companyCd);
					stmt3.setString(2, countpty_cd);
					stmt3.setString(3, cont);
					stmt3.setString(4, cont_rev);
					stmt3.setString(5, agmt);
					stmt3.setString(6, agmt_rev);
					stmt3.setString(7, cont_type);
					rset3=stmt3.executeQuery();
					while(rset3.next())
					{
						String transCd = rset3.getString(1)==null?"":rset3.getString(1);
						String queryString1="SELECT TRUCK_CD "
								+ "FROM FMS_TRUCK_TRANSPORTER_LINK A "
								+ "WHERE LINK_SEQ=(SELECT MAX(B.LINK_SEQ) FROM FMS_TRUCK_TRANSPORTER_LINK B WHERE A.TRUCK_CD=B.TRUCK_CD) "
								+ "AND EFF_DT<=TO_DATE(?,'DD/MM/YYYY') "
								+ "AND (RELEASE_DT>TO_DATE(?,'DD/MM/YYYY') OR RELEASE_DT IS NULL)"
								+ "AND TRUCK_TRANS_CD=? ";
						stmt1 = conn.prepareStatement(queryString1);
						stmt1.setString(1, weekofdt);
						stmt1.setString(2, weekofdt);
						stmt1.setString(3, transCd);
						rset1=stmt1.executeQuery();
						while(rset1.next())
						{
							String truck_cd = rset1.getString(1)==null?"":rset1.getString(1);
							
							String prevGasDate = dateUtil.getDate(weekofdt, "-1");
							String availAfter =utilBean_DLNG.getTruckOccupancyData(conn, companyCd, prevGasDate, weekofdt, truck_cd);
							
							String queryString2="SELECT TRUCK_REG_NUM,TRUCK_VOL_M3,TRUCK_VOL_MT,TRUCK_LOAD_CAP "
									+ "FROM FMS_TRUCK_MST A "
									+ "WHERE EFF_DT=(SELECT MAX(B.EFF_DT) FROM FMS_TRUCK_MST B WHERE A.TRUCK_CD=B.TRUCK_CD "
									+ "AND TO_DATE(B.EFF_DT,'DD/MM/YYYY')<=TO_DATE(?,'DD/MM/YYYY')) "
									+ "AND ACTIVE_FLAG=? AND TRUCK_CD=? ";
							stmt2 = conn.prepareStatement(queryString2);
							stmt2.setString(1, weekofdt);
							stmt2.setString(2, "Y");
							stmt2.setString(3, truck_cd);
							rset2=stmt2.executeQuery();
							while(rset2.next())
							{
								String truck_reg_num = rset2.getString(1)==null?"":rset2.getString(1);
								
								Float truck_vol_m3 = rset2.getFloat(2);
								Float truck_vol_mt = rset2.getFloat(3);
								
								Double truck_load_cap = rset2.getDouble(4);
								
								VTEMP_MST_TRUCK_TRANS_CD.add(transCd);
								VTEMP_MST_TRUCK_CD.add(truck_cd);
								VTEMP_MST_TRUCK_REG_NUM.add(truck_reg_num);
								
								VTEMP_MST_TRUCK_VOL_M3.add(truck_vol_m3);
								VTEMP_MST_TRUCK_VOL_MT.add(truck_vol_mt);
								VTEMP_MST_TRUCK_LOAD_CAP.add(truck_load_cap);
							}
							rset2.close();
							stmt2.close();
							
							String queryString4="SELECT QTY_MMBTU,QTY_MT,FILL_STATION_CD,BAY_CD,SLOT_START_TIME,SLOT_END_TIME,TO_CHAR(ARRIVAL_DT,'DD/MM/YYYY'),"
									+ "ARRIVAL_TIME,NEXT_AVAIL_HRS,REMARK "
									+ "FROM FMS_DLNG_BUYER_NOM_DTL A "
									+ "WHERE CONT_NO=? AND AGMT_NO=? "
									+ "AND COMPANY_CD=? AND COUNTERPARTY_CD=? "
									+ "AND PLANT_SEQ=? AND CONTRACT_TYPE=? "
									+ "AND GAS_DT=TO_DATE(?,'DD/MM/YYYY') AND BU_SEQ=? "
									+ "AND TRUCK_TRANS_CD=? AND TRUCK_CD=?  AND CARGO_NO=? "
									+ "AND NOM_REV_NO=(SELECT MAX(NOM_REV_NO) FROM FMS_DLNG_BUYER_NOM_DTL B "
									+ " WHERE B.CONT_NO=A.CONT_NO AND B.AGMT_NO=A.AGMT_NO "
									+ " AND B.CONT_REV=A.CONT_REV AND B.AGMT_REV=A.AGMT_REV "
									+ "	AND B.COMPANY_CD=A.COMPANY_CD AND B.COUNTERPARTY_CD=A.COUNTERPARTY_CD "
									+ "	AND B.PLANT_SEQ=A.PLANT_SEQ AND B.BU_SEQ=A.BU_SEQ "
									+ " AND B.CONTRACT_TYPE=A.CONTRACT_TYPE AND B.GAS_DT=A.GAS_DT AND B.CARGO_NO=A.CARGO_NO )";
							stmt4 = conn.prepareStatement(queryString4);
							stmt4.setString(1, cont);
							stmt4.setString(2, agmt);
							stmt4.setString(3, comp_cd);
							stmt4.setString(4, countpty_cd);
							stmt4.setString(5, plant_seq);
							stmt4.setString(6, cont_type);
							stmt4.setString(7, weekofdt);
							stmt4.setString(8, bu_plant_seq);
							stmt4.setString(9, transCd);
							stmt4.setString(10, truck_cd);
							stmt4.setString(11, cargo_no);
							rset4=stmt4.executeQuery();
							while(rset4.next())
							{
								index1++;
								String queryString3="SELECT TRUCK_REG_NUM,TRUCK_VOL_M3,TRUCK_VOL_MT,TRUCK_LOAD_CAP "
										+ "FROM FMS_TRUCK_MST A "
										+ "WHERE "
										//+ "EFF_DT=(SELECT MAX(B.EFF_DT) FROM FMS_TRUCK_MST B WHERE A.TRUCK_CD=B.TRUCK_CD "
										//+ "AND TO_DATE(B.EFF_DT,'DD/MM/YYYY')<=TO_DATE(TO_CHAR(SYSDATE,'DD/MM/YYYY'),'DD/MM/YYYY')) "
										//+ "AND ACTIVE_FLAG=? AND "
										+ "TRUCK_CD=? ";
								stmt2 = conn.prepareStatement(queryString3);
								//stmt2.setString(1, "Y");
								stmt2.setString(1, truck_cd);
								rset2=stmt2.executeQuery();
								while(rset2.next())
								{
									String truck_reg_num = rset2.getString(1)==null?"":rset2.getString(1);
									
									Float truck_vol_m3 = rset2.getFloat(2);
									Float truck_vol_mt = rset2.getFloat(3);
									
									Double truck_load_cap = rset2.getDouble(4);

									VTEMP_TRUCK_TRANS_CD.add(transCd);
									VTEMP_TRUCK_CD.add(truck_cd);
									VTEMP_TRUCK_REG_NUM.add(truck_reg_num);
									VTEMP_TRUCK_VOL_M3.add(truck_vol_m3);
									VTEMP_TRUCK_VOL_MT.add(truck_vol_mt);
									VTEMP_TRUCK_LOAD_CAP.add(truck_load_cap);
								}
								rset2.close();
								stmt2.close();
								
								VTEMP_QTY_MMBTU.add(rset4.getString(1)==null?"":rset4.getString(1));
								VTEMP_QTY_MT.add(rset4.getString(2)==null?"":rset4.getString(2));
								VTEMP_FILL_STATION_CD.add(rset4.getString(3)==null?"":rset4.getString(3));
								VTEMP_BAY_CD.add(rset4.getString(4)==null?"":rset4.getString(4));
								VTEMP_SLOT_START_TIME.add(rset4.getString(5)==null?"":rset4.getString(5));
								VTEMP_SLOT_END_TIME.add(rset4.getString(6)==null?"":rset4.getString(6));
								VTEMP_ARRIVAL_DT.add(rset4.getString(7)==null?"":rset4.getString(7));
								VTEMP_ARRIVAL_TIME.add(rset4.getString(8)==null?"":rset4.getString(8));
								VTEMP_NEXT_AVAIL_HRS.add(rset4.getString(9)==null?"":rset4.getString(9));
								VTEMP_REMARK.add(rset4.getString(10)==null?"":rset4.getString(10));
								
								VTEMP_TRUCK_AVAIL_DT.add(availAfter);
								
								String fill_station_cd = rset4.getString(3)==null?"":rset4.getString(3);
								String bay_cd = rset4.getString(4)==null?"":rset4.getString(4);
								String slot_start_time = rset4.getString(5)==null?"":rset4.getString(5);
								String slot_end_time = rset4.getString(6)==null?"":rset4.getString(6);
								
								String map_id=fill_station_cd+"-"+bay_cd+"-"+slot_start_time+"-"+slot_end_time;
					  			
					  			int isInvoiceSubmitted=isInvoiceSubmitted(countpty_cd, cont, agmt, plant_seq, cont_type, bu_plant_seq, weekofdt,truck_cd,transCd,map_id, false);
								if(isInvoiceSubmitted>0)
								{
									VTEMP_NOM_BLOCK.add("Y");
								}
								else
								{
									int isTruckAllocated=isTruckAllocated(countpty_cd, cont, agmt, plant_seq, cont_type, bu_plant_seq, weekofdt,truck_cd,transCd,fill_station_cd, bay_cd, slot_start_time, slot_end_time);
									if(isTruckAllocated>0)
									{
										VTEMP_NOM_BLOCK.add("A");
									}
									else
									{
										VTEMP_NOM_BLOCK.add("N");
									}
								}
							}
							rset4.close();
							stmt4.close();
							
							VINDEX1.add(indexOut);
							
							rowspan = indexOut;
						}
						rset1.close();
						stmt1.close();
					}
					rset3.close();
					stmt3.close();
					
					VMST_TRUCK_TRANS_CD.add(VTEMP_MST_TRUCK_TRANS_CD);
					VMST_TRUCK_CD.add(VTEMP_MST_TRUCK_CD);
					VMST_TRUCK_REG_NUM.add(VTEMP_MST_TRUCK_REG_NUM);
					
					FillStationData data = getFillStContWise(companyCd,countpty_cd,agmt,cont,cont_type,agmt_rev,cont_rev);
					
					VMST_FILLST_CD.add(data.fillStationCodes);
					VMST_FILLST_NM.add(data.fillStationNames);
					VMST_FILLST_ABBR.add(data.fillStationAbbrs);
					
					VTOTAL_TRUCK_TRANS_CD.add(VTEMP_TRUCK_TRANS_CD);
					VTOTAL_TRUCK_CD.add(VTEMP_TRUCK_CD);
					VTOTAL_TRUCK_REG_NUM.add(VTEMP_TRUCK_REG_NUM);
					VTOTAL_TRUCK_VOL_M3.add(VTEMP_TRUCK_VOL_M3);
					VTOTAL_TRUCK_VOL_MT.add(VTEMP_TRUCK_VOL_MT);
					VTOTAL_TRUCK_LOAD_CAP.add(VTEMP_TRUCK_LOAD_CAP);
					VTOTAL_QTY_MMBTU.add(VTEMP_QTY_MMBTU);
					VTOTAL_QTY_MT.add(VTEMP_QTY_MT);
					VTOTAL_FILL_STATION_CD.add(VTEMP_FILL_STATION_CD);
					VTOTAL_BAY_CD.add(VTEMP_BAY_CD);
					VTOTAL_SLOT_START_TIME.add(VTEMP_SLOT_START_TIME);
					VTOTAL_SLOT_END_TIME.add(VTEMP_SLOT_END_TIME);
					VTOTAL_ARRIVAL_DT.add(VTEMP_ARRIVAL_DT);
					VTOTAL_ARRIVAL_TIME.add(VTEMP_ARRIVAL_TIME);
					VTOTAL_NEXT_AVAIL_HRS.add(VTEMP_NEXT_AVAIL_HRS);
					VTOTAL_REMARK.add(VTEMP_REMARK);
					VTOTAL_AVAIL_DT.add(VTEMP_TRUCK_AVAIL_DT);
					VTOTAL_NOM_BLOCK.add(VTEMP_NOM_BLOCK);
					
					if(index1>0)
					{
						VTRUCK_LINKED.add("Y");
					}
					else
					{
						VTRUCK_LINKED.add("N");
					}
				}
				rset.close();
				stmt.close();
				
				VTRANS_PLANT_WISE_TOTAL_MMBTU.add(nf.format(trans_plant_wise_total_mmbtu));
				VTRANS_PLANT_WISE_TOTAL_SCM.add(nf.format(trans_plant_wise_total_scm));
				
				if(periodic_i>0)
				{
					VGAS_INDEX.add(gas_index);
					VROWSPAN.add(rowspan);
				}
			}
			entry_range+=total_entry;
			VSUB_INDEX.add(sub_index);	
			VENTRY_RANGE.add(entry_range);
		}
		catch(Exception e)
		{
			new SystemErrorLogger().InsertErrorLogger(db_src_file_name, function_nm, e);
		}
	}

	public double getAllocatedQty(String countpty_cd,String cont, String agmt, String cont_type, String gas_dt, String cargo_no)
	{
		String function_nm="getAllocatedQty()";
		double allocated_qty=0;
		try
		{
			int count=0;
			
			queryString=""
					+ "SELECT SUM(QTY_MMBTU) "
					+ "FROM FMS_DLNG_ALLOC_MST A "
					+ "WHERE CONT_NO=? AND AGMT_NO=? "
					+ "AND COMPANY_CD=? AND COUNTERPARTY_CD=? "
					+ "AND CONTRACT_TYPE=? "
					+ "AND CARGO_NO=? "
					//+ "AND GAS_DT!=TO_DATE(?,'DD/MM/YYYY') "
					+ "AND NOM_REV_NO=(SELECT MAX(NOM_REV_NO) FROM FMS_DLNG_ALLOC_MST B "
					+ "WHERE B.CONT_NO=A.CONT_NO AND B.AGMT_NO=A.AGMT_NO "
					+ "AND B.COMPANY_CD=A.COMPANY_CD AND B.COUNTERPARTY_CD=A.COUNTERPARTY_CD "
					+ "AND A.BU_SEQ=B.BU_SEQ "
					+ "AND B.PLANT_SEQ=A.PLANT_SEQ AND B.CONTRACT_TYPE=A.CONTRACT_TYPE "
					+ "AND B.GAS_DT=A.GAS_DT AND B.CARGO_NO=A.CARGO_NO) ";
			stmt_temp1 = conn.prepareStatement(queryString);
			stmt_temp1.setString(++count, cont);
			stmt_temp1.setString(++count, agmt);
			stmt_temp1.setString(++count, comp_cd);
			stmt_temp1.setString(++count, countpty_cd);
			stmt_temp1.setString(++count, cont_type);
			stmt_temp1.setString(++count, cargo_no);
			//stmt_temp1.setString(++count, gas_dt);
			rset_temp1=stmt_temp1.executeQuery();
			if(rset_temp1.next())
			{
				allocated_qty = rset_temp1.getInt(1);
			}
			rset_temp1.close();
			stmt_temp1.close();
		}
		catch(Exception e)
		{
			new SystemErrorLogger().InsertErrorLogger(db_src_file_name, function_nm, e);
		}
		return allocated_qty;
	}

	public double getTruckAllocatedQty(String countpty_cd,String cont, String agmt, String cont_type, 
			String gas_dt, String fillst_cd, String bay_cd, String slot_start_time, String slot_end_time,
			String truck_trans_cd, String truck_cd)
	{
		String function_nm="getTruckAllocatedQty()";
		double allocated_qty=0;
		try
		{
			int count=0;
			
			queryString=""
					+ "SELECT QTY_MMBTU "
					+ "FROM FMS_DLNG_ALLOC_MST A "
					+ "WHERE CONT_NO=? AND AGMT_NO=? "
					+ "AND COMPANY_CD=? AND COUNTERPARTY_CD=? "
					+ "AND CONTRACT_TYPE=? "
					+ "AND GAS_DT=TO_DATE(?,'DD/MM/YYYY') "
					+ "AND TRUCK_TRANS_CD=? AND TRUCK_CD=? "
					+ "AND FILL_STATION_CD=? AND BAY_CD=? "
					+ "AND SLOT_START_TIME=? AND SLOT_END_TIME=? "
					+ "AND NOM_REV_NO=(SELECT MAX(NOM_REV_NO) FROM FMS_DLNG_ALLOC_MST B "
					+ "WHERE B.CONT_NO=A.CONT_NO AND B.AGMT_NO=A.AGMT_NO "
					+ "AND B.COMPANY_CD=A.COMPANY_CD AND B.COUNTERPARTY_CD=A.COUNTERPARTY_CD "
					+ "AND A.BU_SEQ=B.BU_SEQ "
					+ "AND B.PLANT_SEQ=A.PLANT_SEQ AND B.CONTRACT_TYPE=A.CONTRACT_TYPE "
					+ "AND B.GAS_DT=A.GAS_DT "
					+ "AND B.TRUCK_TRANS_CD=A.TRUCK_TRANS_CD AND A.TRUCK_CD=B.TRUCK_CD "
					+ "AND B.FILL_STATION_CD=A.FILL_STATION_CD AND B.BAY_CD=A.BAY_CD "
					+ "AND B.SLOT_START_TIME=A.SLOT_START_TIME AND B.SLOT_END_TIME=A.SLOT_END_TIME "
					+ "AND B.CARGO_NO=A.CARGO_NO) ";
			stmt_temp1 = conn.prepareStatement(queryString);
			stmt_temp1.setString(++count, cont);
			stmt_temp1.setString(++count, agmt);
			stmt_temp1.setString(++count, comp_cd);
			stmt_temp1.setString(++count, countpty_cd);
			stmt_temp1.setString(++count, cont_type);
			stmt_temp1.setString(++count, gas_dt);
			stmt_temp1.setString(++count, truck_trans_cd);
			stmt_temp1.setString(++count, truck_cd);
			stmt_temp1.setString(++count, fillst_cd);
			stmt_temp1.setString(++count, bay_cd);
			stmt_temp1.setString(++count, slot_start_time);
			stmt_temp1.setString(++count, slot_end_time);
			rset_temp1=stmt_temp1.executeQuery();
			if(rset_temp1.next())
			{
				allocated_qty = rset_temp1.getInt(1);
			}
			rset_temp1.close();
			stmt_temp1.close();
		}
		catch(Exception e)
		{
			new SystemErrorLogger().InsertErrorLogger(db_src_file_name, function_nm, e);
		}
		return allocated_qty;
	}
	
	public int isInvoiceSubmitted(String countpty_cd,String cont, String agmt,String plant_seq, String cont_type, String bu_plant_seq, String gas_dt, String truck_cd, String truck_trans_cd, String map_id, boolean isAllocation)
	{
		String function_nm="isInvoiceSubmitted()";
		int count=0;
		try
		{
			int selCnt=0;
			
			queryString="SELECT COUNT(*) "
					+ "FROM FMS_DLNG_INVOICE_MST "
					+ "WHERE COMPANY_CD=? AND COUNTERPARTY_CD=? AND CONT_NO=? AND AGMT_NO=? AND CONTRACT_TYPE=? "
					+ "AND PLANT_SEQ=? AND BU_UNIT=? AND TRUCK_CD=? AND TRUCK_TRANS_CD=? "
					+ "AND PERIOD_START_DT=TO_DATE(?,'DD/MM/YYYY') AND PERIOD_END_DT=TO_DATE(?,'DD/MM/YYYY') "
					+ "AND APPROVED_FLAG=? AND MAPPING_ID=? ";
			stmt_temp1 = conn.prepareStatement(queryString);
			stmt_temp1.setString(++selCnt, comp_cd);
			stmt_temp1.setString(++selCnt, countpty_cd);
			stmt_temp1.setString(++selCnt, cont);
			stmt_temp1.setString(++selCnt, agmt);
			stmt_temp1.setString(++selCnt, cont_type);
			stmt_temp1.setString(++selCnt, plant_seq);
			stmt_temp1.setString(++selCnt, bu_plant_seq);
			stmt_temp1.setString(++selCnt, truck_cd);
			stmt_temp1.setString(++selCnt, truck_trans_cd);
			stmt_temp1.setString(++selCnt, gas_dt);
			stmt_temp1.setString(++selCnt, gas_dt);
			stmt_temp1.setString(++selCnt, "Y");
			stmt_temp1.setString(++selCnt, map_id);
			rset_temp1=stmt_temp1.executeQuery();
			if(rset_temp1.next())
			{
				count=rset_temp1.getInt(1);
			}
			rset_temp1.close();
			stmt_temp1.close();
			
			if(isAllocation)
			{
				selCnt=0;
				
				queryString2="SELECT COUNT(*) "
						+ "FROM FMS_DLNG_INVOICE_MST "
						+ "WHERE COMPANY_CD=? AND COUNTERPARTY_CD=? AND CONT_NO=? AND AGMT_NO=? AND CONTRACT_TYPE=? "
						+ "AND PLANT_SEQ=? AND BU_UNIT=? AND TRUCK_CD=? AND TRUCK_TRANS_CD=? "
						+ "AND PERIOD_START_DT=TO_DATE(?,'DD/MM/YYYY') AND PERIOD_END_DT=TO_DATE(?,'DD/MM/YYYY') "
						+ "AND MAPPING_ID=? "
						+ "AND INV_FLAG IN ('CR','DR') AND CRITERIA LIKE ? "
						+ "AND (APPROVED_FLAG != ? OR APPROVED_FLAG IS NULL) ";
				stmt_temp2 = conn.prepareStatement(queryString2);
				stmt_temp2.setString(++selCnt, comp_cd);
				stmt_temp2.setString(++selCnt, countpty_cd);
				stmt_temp2.setString(++selCnt, cont);
				stmt_temp2.setString(++selCnt, agmt);
				stmt_temp2.setString(++selCnt, cont_type);
				stmt_temp2.setString(++selCnt, plant_seq);
				stmt_temp2.setString(++selCnt, bu_plant_seq);
				stmt_temp2.setString(++selCnt, truck_cd);
				stmt_temp2.setString(++selCnt, truck_trans_cd);
				stmt_temp2.setString(++selCnt, gas_dt);
				stmt_temp2.setString(++selCnt, gas_dt);
				stmt_temp2.setString(++selCnt, map_id);
				stmt_temp2.setString(++selCnt, "%QTY%");
				stmt_temp2.setString(++selCnt, "Y");
				rset_temp2=stmt_temp2.executeQuery();
				if(rset_temp2.next())
				{
					int temp_count=rset_temp2.getInt(1);
					
					if(temp_count > 0)
					{
						count=-1;
					}
				}
				rset_temp2.close();
				stmt_temp2.close();
			}
		}
		catch(Exception e)
		{
			new SystemErrorLogger().InsertErrorLogger(db_src_file_name, function_nm, e);
		}
		return count;
	}

	public int isTruckAllocated(String countpty_cd,String cont, String agmt,String plant_seq, 
			String cont_type, String bu_plant_seq, String gas_dt, String truck_cd, String truck_trans_cd, 
			String fill_station_cd, String bay_cd, String slot_start_time, String slot_end_time)
	{
		String function_nm="isTruckAllocated()";
		int count=0;
		try
		{
			int selCnt=0;
			
			queryString="SELECT COUNT(*) "
					+ "FROM FMS_DLNG_ALLOC_MST A "
					+ "WHERE CONT_NO=? AND AGMT_NO=? "
					+ "AND COMPANY_CD=? AND COUNTERPARTY_CD=? "
					+ "AND PLANT_SEQ=? AND CONTRACT_TYPE=? AND BU_SEQ=? "
					+ "AND GAS_DT=TO_DATE(?,'DD/MM/YYYY') AND TRUCK_TRANS_CD=? AND TRUCK_CD=? "
					+ "AND FILL_STATION_CD=? AND BAY_CD=? "
					+ "AND SLOT_START_TIME=? AND SLOT_END_TIME=? "
					+ "AND NOM_REV_NO=(SELECT MAX(NOM_REV_NO) FROM FMS_DLNG_ALLOC_MST B "
					+ "WHERE B.CONT_NO=A.CONT_NO AND B.AGMT_NO=A.AGMT_NO "
					+ "AND B.COMPANY_CD=A.COMPANY_CD AND B.COUNTERPARTY_CD=A.COUNTERPARTY_CD "
					+ "AND B.BU_SEQ=A.BU_SEQ "
					+ "AND B.PLANT_SEQ=A.PLANT_SEQ AND B.CONTRACT_TYPE=A.CONTRACT_TYPE "
					+ "AND B.GAS_DT=A.GAS_DT AND B.TRUCK_TRANS_CD=A.TRUCK_TRANS_CD AND A.TRUCK_CD=B.TRUCK_CD "
					+ "AND B.FILL_STATION_CD=A.FILL_STATION_CD AND B.BAY_CD=A.BAY_CD "
					+ "AND B.SLOT_START_TIME=A.SLOT_START_TIME AND B.SLOT_END_TIME=A.SLOT_END_TIME AND B.CARGO_NO=A.CARGO_NO) ";
			stmt_temp1 = conn.prepareStatement(queryString);
			stmt_temp1.setString(++selCnt, cont);
			stmt_temp1.setString(++selCnt, agmt);
			stmt_temp1.setString(++selCnt, comp_cd);
			stmt_temp1.setString(++selCnt, countpty_cd);
			stmt_temp1.setString(++selCnt, plant_seq);
			stmt_temp1.setString(++selCnt, cont_type);
			stmt_temp1.setString(++selCnt, bu_plant_seq);
			stmt_temp1.setString(++selCnt, gas_dt);
			stmt_temp1.setString(++selCnt, truck_trans_cd);
			stmt_temp1.setString(++selCnt, truck_cd);
			stmt_temp1.setString(++selCnt, fill_station_cd);
			stmt_temp1.setString(++selCnt, bay_cd);
			stmt_temp1.setString(++selCnt, slot_start_time);
			stmt_temp1.setString(++selCnt, slot_end_time);
			rset_temp1=stmt_temp1.executeQuery();
			if(rset_temp1.next())
			{
				count=rset_temp1.getInt(1);
			}
			rset_temp1.close();
			stmt_temp1.close();
		}
		catch(Exception e)
		{
			new SystemErrorLogger().InsertErrorLogger(db_src_file_name, function_nm, e);
		}
		return count;
	}
	
	public void getContractTCQ()
	{
		String function_nm="getContractTCQ()";
		try
		{
			queryString="SELECT COMPANY_CD,COUNTERPARTY_CD,AGMT_NO,AGMT_REV,CONT_NO,CONT_REV,CONTRACT_TYPE,"
					+ "TO_CHAR(START_DT,'DD/MM/YYYY'),TO_CHAR(END_DT,'DD/MM/YYYY'),TCQ "
					+ "FROM FMS_SUPPLY_CONT_MST A "
					+ "WHERE COMPANY_CD=? AND BUYER_NOM_FLAG=? AND A.FCC_FLAG=? AND IS_ALLOCATED=? "
					+ "AND START_DT<=TO_DATE(?,'DD/MM/YYYY') AND END_DT>=TO_DATE(?,'DD/MM/YYYY') "
					+ "AND A.CONT_REV=(SELECT MAX(B.CONT_REV) FROM FMS_SUPPLY_CONT_MST B "
					+ "WHERE A.COMPANY_CD=B.COMPANY_CD AND A.COUNTERPARTY_CD=B.COUNTERPARTY_CD "
					+ "AND A.AGMT_NO=B.AGMT_NO AND A.AGMT_REV=B.AGMT_REV AND A.CONT_NO=B.CONT_NO AND A.CONTRACT_TYPE=B.CONTRACT_TYPE) ";
			stmt = conn.prepareStatement(queryString);
			stmt.setString(1, comp_cd);
			stmt.setString(2, "Y");
			stmt.setString(3, "Y");
			stmt.setString(4, "Y");
			stmt.setString(5, gas_dt);
			stmt.setString(6, gas_dt);
			rset=stmt.executeQuery();
			while(rset.next())
			{
				String companyCd = rset.getString(1)==null?"":rset.getString(1);
				String countpty_cd = rset.getString(2)==null?"":rset.getString(2);
				String agmt = rset.getString(3)==null?"":rset.getString(3);
				String agmt_rev = rset.getString(4)==null?"":rset.getString(4);
				String cont = rset.getString(5)==null?"":rset.getString(5);
				String cont_rev = rset.getString(6)==null?"":rset.getString(6);
				String cont_type = rset.getString(7)==null?"":rset.getString(7);
				String start_dt = rset.getString(8)==null?"":rset.getString(8);
				String end_dt = rset.getString(9)==null?"":rset.getString(9);
				double tcq = rset.getDouble(10);
				
				String cargo_no="0"; 
				
				String internal_map_id = cont_type+"-"+countpty_cd+"-"+agmt+"-"+agmt_rev+"-"+cont+"-"+cont_rev;
				
				int count = 0;
				
				double total_buyerNom=0;
				queryString1="SELECT SUM(TOTAL_MMBTU) "
						+ "FROM ("
						+ "SELECT SUM(QTY_MMBTU) AS TOTAL_MMBTU "
						+ "FROM FMS_DLNG_ALLOC_MST A "
						+ "WHERE CONT_NO=? AND AGMT_NO=? "
						+ "AND COMPANY_CD=? AND COUNTERPARTY_CD=? "
						+ "AND CONTRACT_TYPE=? "
						+ "AND GAS_DT!=TO_DATE(?,'DD/MM/YYYY') AND CARGO_NO=? "
						+ "AND NOM_REV_NO=(SELECT MAX(NOM_REV_NO) FROM FMS_DLNG_ALLOC_MST B "
						+ "WHERE B.CONT_NO=A.CONT_NO AND B.AGMT_NO=A.AGMT_NO "
						+ "AND B.COMPANY_CD=A.COMPANY_CD AND B.COUNTERPARTY_CD=A.COUNTERPARTY_CD "
						+ "AND A.BU_SEQ=B.BU_SEQ "
						+ "AND B.PLANT_SEQ=A.PLANT_SEQ AND B.CONTRACT_TYPE=A.CONTRACT_TYPE "
						+ "AND B.GAS_DT=A.GAS_DT AND B.CARGO_NO=A.CARGO_NO) "
						+ "UNION "
						+ "SELECT SUM(QTY_MMBTU) AS TOTAL_MMBTU "
		  				+ "FROM FMS_DLNG_BUYER_NOM C "
		  				+ "WHERE CONT_NO=? AND AGMT_NO=? "
						+ "AND COMPANY_CD=? AND COUNTERPARTY_CD=? "
						+ "AND CONTRACT_TYPE=? "
						+ "AND GAS_DT!=TO_DATE(?,'DD/MM/YYYY') AND CARGO_NO=? "
						+ "AND GAS_DT > (SELECT MAX(GAS_DT) FROM FMS_DLNG_ALLOC_MST E "
						+ "WHERE E.CONT_NO=C.CONT_NO AND E.AGMT_NO=C.AGMT_NO "
						+ "AND E.COMPANY_CD=C.COMPANY_CD AND E.COUNTERPARTY_CD=C.COUNTERPARTY_CD "
						//+ "AND E.BU_SEQ=C.BU_SEQ "
						//+ "AND E.PLANT_SEQ=C.PLANT_SEQ "
						+ "AND E.CONTRACT_TYPE=C.CONTRACT_TYPE AND E.CARGO_NO=C.CARGO_NO ) "
						+ "AND NOM_REV_NO=(SELECT MAX(NOM_REV_NO) FROM FMS_DLNG_BUYER_NOM D "
						+ "WHERE D.CONT_NO=C.CONT_NO AND D.AGMT_NO=C.AGMT_NO "
						+ "AND D.COMPANY_CD=C.COMPANY_CD AND D.COUNTERPARTY_CD=C.COUNTERPARTY_CD "
						+ "AND C.BU_SEQ=D.BU_SEQ "
						+ "AND D.PLANT_SEQ=C.PLANT_SEQ "
						+ "AND D.CONTRACT_TYPE=C.CONTRACT_TYPE "
						+ "AND D.GAS_DT=C.GAS_DT AND D.CARGO_NO=C.CARGO_NO) "
						+ ")";
				String tempQString = queryString1;
				stmt1 = conn.prepareStatement(tempQString);
				stmt1.setString(++count, cont);
				stmt1.setString(++count, agmt);
				stmt1.setString(++count, companyCd);
				stmt1.setString(++count, countpty_cd);
				stmt1.setString(++count, cont_type);
				stmt1.setString(++count, gas_dt);
				stmt1.setString(++count, cargo_no);
				stmt1.setString(++count, cont);
				stmt1.setString(++count, agmt);
				stmt1.setString(++count, companyCd);
				stmt1.setString(++count, countpty_cd);
				stmt1.setString(++count, cont_type);
				stmt1.setString(++count, gas_dt);
				stmt1.setString(++count, cargo_no);
				rset1=stmt1.executeQuery();
				if(rset1.next())
				{
					total_buyerNom=rset1.getDouble(1);
				}
				rset1.close();
				stmt1.close();
				
				VCONT_INTERNAL_MAPP_ID.add(internal_map_id);
				VCONT_BUYER_NOM.add(nf.format(total_buyerNom));
				VCONT_TCQ.add(nf.format(tcq));
			}
			rset.close();
			stmt.close();
		}
		catch(Exception e)
		{
			new SystemErrorLogger().InsertErrorLogger(db_src_file_name, function_nm, e);
		}
	}
	
	public void getContractWiseTCQ(String type)
	{
		String function_nm="getContractWiseTCQ()";
		try
		{
			int count1 = 0;
			double total_buyerNom=0;
			
			String tableName ="";
			
			if(type.equals("B")) 
			{
				tableName = "FMS_DLNG_BUYER_NOM";
			}
			else
			{
				tableName = "FMS_DLNG_SELLER_NOM_DTL";
			}
			
			queryString3="SELECT SUM(TOTAL_MMBTU) "
					+ "FROM ("
					+ "SELECT SUM(QTY_MMBTU) AS TOTAL_MMBTU "
					+ "FROM FMS_DLNG_ALLOC_MST A "
					+ "WHERE CONT_NO=? AND AGMT_NO=? "
					+ "AND COMPANY_CD=? AND COUNTERPARTY_CD=? "
					+ "AND CONTRACT_TYPE=? AND CARGO_NO=? "
					//+ "AND GAS_DT!=TO_DATE(?,'DD/MM/YYYY') "
					+ "AND NOM_REV_NO=(SELECT MAX(NOM_REV_NO) FROM FMS_DLNG_ALLOC_MST B "
					+ "WHERE B.CONT_NO=A.CONT_NO AND B.AGMT_NO=A.AGMT_NO "
					+ "AND B.COMPANY_CD=A.COMPANY_CD AND B.COUNTERPARTY_CD=A.COUNTERPARTY_CD "
					+ "AND A.BU_SEQ=B.BU_SEQ "
					+ "AND B.PLANT_SEQ=A.PLANT_SEQ AND B.CONTRACT_TYPE=A.CONTRACT_TYPE "
					+ "AND B.GAS_DT=A.GAS_DT AND B.CARGO_NO=A.CARGO_NO) "
					+ "UNION "
					+ "SELECT SUM(QTY_MMBTU) AS TOTAL_MMBTU "
	  				+ "FROM "+tableName+" C "
	  				+ "WHERE CONT_NO=? AND AGMT_NO=? "
					+ "AND COMPANY_CD=? AND COUNTERPARTY_CD=? "
					+ "AND CONTRACT_TYPE=? AND CARGO_NO=? "
					+ "AND GAS_DT > (SELECT MAX(GAS_DT) FROM FMS_DLNG_ALLOC_MST E "
					+ "WHERE E.CONT_NO=C.CONT_NO AND E.AGMT_NO=C.AGMT_NO "
					+ "AND E.COMPANY_CD=C.COMPANY_CD AND E.COUNTERPARTY_CD=C.COUNTERPARTY_CD "
					+ "AND E.CONTRACT_TYPE=C.CONTRACT_TYPE AND E.CARGO_NO=C.CARGO_NO ) "
					+ "AND NOM_REV_NO=(SELECT MAX(NOM_REV_NO) FROM "+tableName+" D "
					+ "WHERE D.CONT_NO=C.CONT_NO AND D.AGMT_NO=C.AGMT_NO "
					+ "AND D.COMPANY_CD=C.COMPANY_CD AND D.COUNTERPARTY_CD=C.COUNTERPARTY_CD "
					+ "AND C.BU_SEQ=D.BU_SEQ "
					+ "AND D.PLANT_SEQ=C.PLANT_SEQ AND D.CONTRACT_TYPE=C.CONTRACT_TYPE "
					+ "AND D.GAS_DT=C.GAS_DT AND D.CARGO_NO=C.CARGO_NO ) "
					+ ")";
			String tempQString = queryString3;
			stmt3 = conn.prepareStatement(tempQString);
			stmt3.setString(++count1, cont_no);
			stmt3.setString(++count1, agmt_no);
			stmt3.setString(++count1, comp_cd);
			stmt3.setString(++count1, counterparty_cd);
			stmt3.setString(++count1, contract_type);
			stmt3.setString(++count1, cargo_no);
			//stmt3.setString(++count1, weekofdt);
			stmt3.setString(++count1, cont_no);
			stmt3.setString(++count1, agmt_no);
			stmt3.setString(++count1, comp_cd);
			stmt3.setString(++count1, counterparty_cd);
			stmt3.setString(++count1, contract_type);
			stmt3.setString(++count1, cargo_no);
			rset3=stmt3.executeQuery();
			if(rset3.next())
			{
				total_buyerNom=rset3.getDouble(1);
			}
			rset3.close();
			stmt3.close();
			
			totalBuyerNom=total_buyerNom;
		}
		catch(Exception e)
		{
			new SystemErrorLogger().InsertErrorLogger(db_src_file_name, function_nm, e);
		}
	}

	public void getDailySellerNomination()
	{
		String function_nm="getDailySellerNomination()";
		try
		{
			dateTime = dateUtil.getSysdateWithTime24hr();
			
			int index=0;
			
			int count = dateUtil.getDays(to_date,from_date);
			int total_entry=-1;
			String entry_range=(total_entry+1)+"-";
			
			for(int k=0; k<count; k++)
			{
				String weekofdt=""+dateUtil.getDate(from_date, ""+k);
				
				int gas_index=0;
				int rowspan=0;
				int periodic_i=0;
				int indexOut=0;
				
				queryString="SELECT A.COMPANY_CD,A.COUNTERPARTY_CD,A.AGMT_NO,A.AGMT_REV,A.CONT_NO,A.CONT_REV,A.CONTRACT_TYPE,"
						+ "A.CONT_REF_NO,'','',A.DCQ,A.CONT_NAME,A.MDCQ_PERCENTAGE,A.TRADE_REF_NO,"
						+ "B.PLANT_SEQ_NO,D.COMPANY_CD,D.PLANT_SEQ_NO AS BU_SEQ_NO,0,'CONT',NULL,A.AGMT_TYPE,"
						+ "E.NOM_REV_NO,E.QTY_MMBTU,E.QTY_SCM,E.QTY_MT,TO_CHAR(E.GEN_DT,'DD/MM/YYYY'),E.GEN_TIME,E.BASE,E.GCV,E.NCV,A.TCQ "
						+ "FROM FMS_SUPPLY_CONT_MST A,"
						+ "FMS_SUPPLY_CONT_PLANT B, "
						+ "FMS_SUPPLY_CONT_BU D, "
						+ "FMS_DLNG_BUYER_NOM E "
						+ "WHERE A.COMPANY_CD=? AND A.BUYER_NOM_FLAG=? AND A.FCC_FLAG=? AND A.IS_ALLOCATED=? "
						+ "AND A.START_DT<=TO_DATE(?,'DD/MM/YYYY') AND A.END_DT>=TO_DATE(?,'DD/MM/YYYY') "
						+ "AND A.CONTRACT_TYPE IN ('F','E','W') "
						+ "AND A.CONT_REV=(SELECT MAX(CONT_REV) FROM FMS_SUPPLY_CONT_MST B WHERE A.COMPANY_CD=B.COMPANY_CD AND A.COUNTERPARTY_CD=B.COUNTERPARTY_CD "
						+ "AND A.AGMT_NO=B.AGMT_NO AND A.AGMT_REV=B.AGMT_REV AND A.CONT_NO=B.CONT_NO AND A.CONTRACT_TYPE=B.CONTRACT_TYPE) "
						+ ""
						+ "AND A.COMPANY_CD=B.COMPANY_CD AND A.COUNTERPARTY_CD=B.COUNTERPARTY_CD AND A.AGMT_NO=B.AGMT_NO AND A.AGMT_REV=B.AGMT_REV "
						+ "AND A.CONT_NO=B.CONT_NO AND A.CONT_REV=B.CONT_REV AND A.CONTRACT_TYPE=B.CONTRACT_TYPE "
						+ ""
						+ "AND A.COMPANY_CD=D.COMPANY_CD AND A.COUNTERPARTY_CD=D.COUNTERPARTY_CD AND A.AGMT_NO=D.AGMT_NO AND A.AGMT_REV=D.AGMT_REV "
						+ "AND A.CONT_NO=D.CONT_NO AND A.CONT_REV=D.CONT_REV AND A.CONTRACT_TYPE=D.CONTRACT_TYPE "
						+ ""
						+ "AND A.COMPANY_CD=E.COMPANY_CD AND A.COUNTERPARTY_CD=E.COUNTERPARTY_CD AND A.AGMT_NO=E.AGMT_NO AND A.AGMT_REV=E.AGMT_REV "
						+ "AND A.CONT_NO=E.CONT_NO "
						+ "AND A.CONTRACT_TYPE=E.CONTRACT_TYPE "//AND B.PLANT_SEQ_NO=E.PLANT_SEQ AND D.PLANT_SEQ_NO=E.BU_SEQ
						+ " AND E.PLANT_SEQ=B.PLANT_SEQ_NO AND E.BU_SEQ=D.PLANT_SEQ_NO AND E.GAS_DT=TO_DATE(?,'DD/MM/YYYY') "
						+ " AND E.NOM_REV_NO=(SELECT MAX(NOM_REV_NO) FROM FMS_DLNG_BUYER_NOM F "
						+ " WHERE F.CONT_NO=E.CONT_NO AND F.AGMT_NO=E.AGMT_NO AND F.COMPANY_CD=E.COMPANY_CD AND F.COUNTERPARTY_CD=E.COUNTERPARTY_CD "
						+ " AND F.BU_SEQ=E.BU_SEQ "
						+ " AND F.PLANT_SEQ=E.PLANT_SEQ AND F.CONTRACT_TYPE=E.CONTRACT_TYPE AND F.GAS_DT=E.GAS_DT) ";
				if(callFlag.equalsIgnoreCase("PERIODIC_SELLER_NOM"))
				{
					queryString+="AND A.COUNTERPARTY_CD=? AND A.AGMT_NO=? AND A.AGMT_REV=? AND A.CONT_NO=? AND A.CONT_REV=? AND A.CONTRACT_TYPE=? ";
				}
				queryString+= " UNION ALL "
						+ "SELECT A.COMPANY_CD,A.COUNTERPARTY_CD,A.AGMT_NO,A.AGMT_REV,A.CONT_NO,A.CONT_REV,A.CONTRACT_TYPE,"
						+ "B.CARGO_REF,'','',B.CSOC_QTY,A.CONT_NAME,A.MDCQ_PERCENTAGE,NULL,"
