							+ "AND A.CONT_NO=E.CONT_NO "
							+ "AND A.CONTRACT_TYPE=E.CONTRACT_TYPE "//AND B.PLANT_SEQ_NO=E.PLANT_SEQ AND D.PLANT_SEQ_NO=E.BU_SEQ
							+ " AND E.PLANT_SEQ=B.PLANT_SEQ_NO AND E.BU_SEQ=D.PLANT_SEQ_NO AND E.GAS_DT=TO_DATE(?,'DD/MM/YYYY') "
							+ " AND E.NOM_REV_NO=(SELECT MAX(NOM_REV_NO) FROM FMS_DLNG_SELLER_NOM_DTL F "
							+ " WHERE F.CONT_NO=E.CONT_NO AND F.AGMT_NO=E.AGMT_NO AND F.COMPANY_CD=E.COMPANY_CD AND F.COUNTERPARTY_CD=E.COUNTERPARTY_CD "
							+ " AND F.BU_SEQ=E.BU_SEQ "
							+ " AND F.PLANT_SEQ=E.PLANT_SEQ AND F.CONTRACT_TYPE=E.CONTRACT_TYPE AND F.GAS_DT=E.GAS_DT AND E.CARGO_NO=F.CARGO_NO) "
							+ "AND E.COMPANY_CD=? AND E.COUNTERPARTY_CD=? "
							+ "AND E.PLANT_SEQ=? "
							//+ "AND E.CONTRACT_TYPE IN ('F','E','W') "
							//+ "AND E.BU_SEQ=? "
							+ "AND E.GAS_DT=TO_DATE(?,'DD/MM/YYYY') "
							+ "AND (TRUCK_TRANS_CD != ? AND TRUCK_CD != ? AND FILL_STATION_CD != ? AND BAY_CD != ? "
							//+ "AND SLOT_START_TIME LIKE (?) AND SLOT_END_TIME LIKE (?)"
							+ "AND (SLOT_START_TIME LIKE '__:__' AND CAST(SUBSTR(SLOT_START_TIME, 1, 2) AS INT) < 24 AND CAST(SUBSTR(SLOT_START_TIME, 4, 2) AS INT) < 60) "
							+ "AND (SLOT_END_TIME LIKE '__:__' AND CAST(SUBSTR(SLOT_END_TIME, 1, 2) AS INT) < 24 AND CAST(SUBSTR(SLOT_END_TIME, 4, 2) AS INT) < 60) "
							+ ")"//HM20251018 : Excluding seller nom data for which truck is released (20251018 LIVE Issue)
							+ ""
							+ " UNION "
