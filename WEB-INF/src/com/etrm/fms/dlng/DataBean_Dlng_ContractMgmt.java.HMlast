							+ "AND (SLOT_END_TIME LIKE '__:__' AND CAST(SUBSTR(SLOT_END_TIME, 1, 2) AS INT) < 24 AND CAST(SUBSTR(SLOT_END_TIME, 4, 2) AS INT) < 60) )"//HM20251018 : Excluding seller nom data for which truck is released (20251018 LIVE Issue)
							+ "";
					stmt_cnt=0;
