					stmt1.executeUpdate();
					isOperated=true;
					stmt1.close();

					if(sell_invoice_seq.length>0 && sell_invoice_seq != null)
					{
						for(int i=0; i<sell_invoice_seq.length;i++)
						{
							insCount=0;

							query2="INSERT INTO FMS_DLNG_SVC_INVOICE_DTL(COMPANY_CD, "
									+ "FINANCIAL_YEAR, "
