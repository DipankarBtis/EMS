							+ "QTY,QTY_UNIT,DIST_UNIT,SALE_PRICE,SALE_PRICE_UNIT,SALE_AMT,EXCHG_RATE_CD,EXCHG_RATE_DT,"
							+ "EXCHG_RATE_VALUE,INVOICE_RAISED_IN,GROSS_AMT,TAX_AMT,TAX_STRUCT_CD,"
							+ "INVOICE_AMT,NET_PAYABLE_AMT,ENT_BY,ENT_DT,FINANCIAL_YEAR,REMARK_1,REMARK_2,EXCHG_RATE_TYPE,"
							+ "TCS_TDS,TCS_AMT,TCS_FACTOR,INVOICE_NO,INVOICE_ID_SEQ,"
