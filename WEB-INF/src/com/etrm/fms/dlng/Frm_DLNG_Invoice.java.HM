					stmt1.setString(++insCount, comp_cd);
					stmt1.setString(++insCount, counterparty_cd);
					stmt1.setString(++insCount, agmt_no);
					stmt1.setString(++insCount, agmt_rev);
					stmt1.setString(++insCount, cont_no);
					stmt1.setString(++insCount, cont_rev);
					stmt1.setString(++insCount, contract_type);
					stmt1.setString(++insCount, bu_unit);
					stmt1.setString(++insCount, bu_contact_person);
					stmt1.setString(++insCount, bu_state_tin);
					stmt1.setString(++insCount, plant_seq);
					stmt1.setString(++insCount, contact_person);
					stmt1.setString(++insCount, invoice_seq);
					stmt1.setString(++insCount, invoice_dt);
					stmt1.setString(++insCount, billing_cycle);
