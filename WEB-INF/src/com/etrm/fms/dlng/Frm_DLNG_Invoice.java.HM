						msg = "Failed! - "+invdtl+" Invoice for "+counterparty_abbr+" "+temp_deal_no+" Already Generated for "+period_end_dt+"!";
						msg_type="E";
					}

					msg = "Successful! - "+invdtl+" Invoice for "+counterparty_abbr+" "+temp_deal_no+" Generated for "+period_end_dt+"!";
