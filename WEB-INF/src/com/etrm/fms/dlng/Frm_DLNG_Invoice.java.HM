							+ "INV_FLAG,SELL_CONT_MAP,SAC_CD,ITEM_DESCRIPTION) "
							+ "VALUES(?,?,?,?,?,?,?,?,?,?,?,?,?,"
							+ "TO_DATE(?,'DD/MM/YYYY'),?,"
							+ "TO_DATE(?,'DD/MM/YYYY'),"
							+ "TO_DATE(?,'DD/MM/YYYY'),"
							+ "TO_DATE(?,'DD/MM/YYYY'),?,?,?,?,?,?,?,"
							+ "TO_DATE(?,'DD/MM/YYYY'),?,?,?,?,?,"
							+ "?,?,?,SYSDATE,?,?,?,?,?,?,?,?,?,?,"
							+ "?,?,?,"
							+ "?,?,?,?)";
