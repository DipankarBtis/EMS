							+ "INVOICE_NO=?,INVOICE_ID_SEQ=?,TCS_STRUCT_CD=?,"
							+ "TDS_GROSS_AMT=?,TDS_GROSS_PERCENT=?,TDS_STRUCT_CD=?,"
