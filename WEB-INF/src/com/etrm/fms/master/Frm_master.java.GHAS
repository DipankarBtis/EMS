			String bank_email=request.getParameter("bank_email")==null?"":request.getParameter("bank_email");
			
			if(opration.equals("MODIFY"))
			{
				if(!bank_cd.equals(""))
				{
					query="UPDATE FMS_BANK_MST SET BANK_NAME=?, BANK_ABBR=?, BRANCH_NAME=?, "
							+ "EFF_DT=TO_DATE(?,'DD/MM/YYYY'), ADDR=?,CITY=?,PIN=?,STATE=?,COUNTRY=?, "
							+ "PHONE=?,MOBILE=?,ALT_PHONE=?,FAX_1=?,FAX_2=?,EMAIL=?,REMARK=?, "
							+ "BRANCH_IFSC_CD=?,ACTIVE_FLAG=?,MOD_PROFILE=? "
