				{
					bank_cd=""+(rset.getInt(1)+1);
				}
				else
				{
					bank_cd="1001";
				}
				rset.close();
				stmt.close();
				
				if(!bank_cd.equals(""))
				{
					query1="INSERT INTO FMS_BANK_MST(BANK_CD,BANK_NAME,BANK_ABBR,BRANCH_NAME,EFF_DT,ADDR,CITY,PIN,STATE, "
						+ "COUNTRY,PHONE,MOBILE,ALT_PHONE,FAX_1,FAX_2,EMAIL,REMARK,BRANCH_IFSC_CD,ACTIVE_FLAG,ENT_PROFILE) "
						+ "VALUES(?,?,?,?,TO_DATE(?,'DD/MM/YYYY'),?,?, "
						+ "?,?,?,?,?,?,?,?,"
						+ "?,?,?,?,?)";
					stmt1=dbcon.prepareStatement(query1);
					stmt1.setString(1, bank_cd);
					stmt1.setString(2, bank_nm);
					stmt1.setString(3, bank_abbr);
					stmt1.setString(4, bank_branch);
