			new SystemErrorLogger().InsertErrorLogger(db_src_file_name, function_nm, infoLogger);
		}
	}
	
	private void InsertUpdateProductMaster(HttpServletRequest request) throws SQLException 
	{
		String function_nm="InsertUpdateProductMaster()";
		msg="";
		msg_type="";
		url="";
		
		HttpSession session = request.getSession();
		String emp_cd = (String)session.getAttribute("emp_cd")==null?"":(String)session.getAttribute("emp_cd");
		String comp_cd = (String)session.getAttribute("comp_cd")==null?"":(String)session.getAttribute("comp_cd");
		
		try
		{
			String opration=request.getParameter("opration")==null?"":request.getParameter("opration");
			
			String product_cd=request.getParameter("product_cd")==null?"":request.getParameter("product_cd");
			String product_nm=request.getParameter("product_nm")==null?"":request.getParameter("product_nm");
			String product_abbr=request.getParameter("product_abbr")==null?"":request.getParameter("product_abbr");
			String desc=request.getParameter("desc")==null?"":request.getParameter("desc");
			String status_flag=request.getParameter("status_flag")==null?"Y":request.getParameter("status_flag");
			
			if(opration.equals("MODIFY"))
			{
				if(!product_cd.equals(""))
				{
		   			query="UPDATE FMS_PRODUCT_MST SET PROD_NM=?, PROD_ABBR=?, PROD_DESC=?,"
		   					+ "MOD_DT=SYSDATE,MOD_BY=?,PROD_FLAG=?,MOD_PROFILE=? "
							+ "WHERE PROD_CD=? ";
					stmt=dbcon.prepareStatement(query);
					stmt.setString(1, product_nm);
					stmt.setString(2, product_abbr);
					stmt.setString(3, desc);
					stmt.setString(4, emp_cd);
					stmt.setString(5, status_flag);
					stmt.setString(6, comp_cd);
					stmt.setString(7, product_cd);
					stmt.executeUpdate();
					
					stmt.close();
					
					msg = "Successful! - "+product_nm+" Product updated!";
					msg_type="S";
				}
				else
				{
					msg = "Failed! - Data Modification for "+product_nm+" Failed!";
					msg_type="E";
				}
			}
			else
			{
				product_cd="1";
				
				query="SELECT NVL(MAX(PROD_CD),0) "
						+ "FROM FMS_PRODUCT_MST ";
				stmt=dbcon.prepareStatement(query);
				rset=stmt.executeQuery();
				if(rset.next())
				{
					product_cd=""+(rset.getInt(1)+1);
				}				
				rset.close();
				stmt.close();
				
				if(!product_cd.equals(""))
				{
					query1="INSERT INTO FMS_PRODUCT_MST(PROD_CD,PROD_NM,PROD_ABBR,PROD_DESC,"
							+ "PROD_FLAG,ENT_BY,ENT_DT,ENT_PROFILE) "
						+ "VALUES(?,?,?,?,?,?,SYSDATE,?)";
