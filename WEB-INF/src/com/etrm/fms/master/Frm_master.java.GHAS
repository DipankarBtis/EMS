	private void InsertUpdateProductmoleMaster(HttpServletRequest request) throws SQLException 
	{
		String function_nm="InsertUpdateProductmoleMaster()";
		msg="";
		msg_type="";
		url="";
		
		HttpSession session = request.getSession();
		String emp_cd = (String)session.getAttribute("emp_cd")==null?"":(String)session.getAttribute("emp_cd");
		String comp_cd = (String)session.getAttribute("comp_cd")==null?"":(String)session.getAttribute("comp_cd");
		
		try
		{
			String opration=request.getParameter("opration")==null?"":request.getParameter("opration");
			
			String product_cd=request.getParameter("product_cd")==null?"":request.getParameter("product_cd");
			String molecule_cd=request.getParameter("molecule_cd")==null?"":request.getParameter("molecule_cd");
			String molecule_nm=request.getParameter("molecule_nm")==null?"":request.getParameter("molecule_nm");
			String molecule_abbr=request.getParameter("molecule_abbr")==null?"":request.getParameter("molecule_abbr");
			String desc=request.getParameter("desc")==null?"":request.getParameter("desc");
			String status_flag=request.getParameter("status_flag")==null?"Y":request.getParameter("status_flag");
			
			if(opration.equals("MODIFY"))
			{
				if(!product_cd.equals("") && !molecule_cd.equals(""))
				{
					int upCnt=0;
					query="UPDATE FMS_PRODUCT_MOLECULE_MST SET PROD_CD=?, MOLE_NM=?, MOLE_ABBR=?, MOLE_DESC=?,"
							+ "MOD_DT=SYSDATE,MOD_BY=?,MOLE_FLAG=?,MOD_PROFILE=? "
							+ "WHERE MOLE_CD=? ";
					stmt=dbcon.prepareStatement(query);
					stmt.setString(++upCnt, product_cd);
					stmt.setString(++upCnt, molecule_nm);
					stmt.setString(++upCnt, molecule_abbr);
					stmt.setString(++upCnt, desc);
					stmt.setString(++upCnt, emp_cd);
					stmt.setString(++upCnt, status_flag);
					stmt.setString(++upCnt, comp_cd);
					stmt.setString(++upCnt, molecule_cd);
					stmt.executeUpdate();
					
					stmt.close();
					
					msg = "Successful! - "+molecule_nm+" Product Molecule updated!";
					msg_type="S";
				}
				else
				{
					msg = "Failed! - Data Modification for "+molecule_nm+" Failed!";
					msg_type="E";
				}
			}
			else
			{
				molecule_cd="1";
				
				query="SELECT NVL(MAX(MOLE_CD),0) "
						+ "FROM FMS_PRODUCT_MOLECULE_MST ";
						//+ "WHERE PROD_CD=? ";
				stmt=dbcon.prepareStatement(query);
				//stmt.setString(1,product_cd);
				rset=stmt.executeQuery();
				if(rset.next())
				{
					molecule_cd=""+(rset.getInt(1)+1);
				}				
				rset.close();
				stmt.close();
				
				if(!molecule_cd.equals(""))
				{
					query1="INSERT INTO FMS_PRODUCT_MOLECULE_MST(PROD_CD,MOLE_CD,MOLE_NM,MOLE_ABBR,MOLE_DESC,"
							+ "MOLE_FLAG,ENT_BY,ENT_DT,ENT_PROFILE) "
							+ "VALUES(?,?,?,?,?,?,?,SYSDATE,?)";
					stmt1=dbcon.prepareStatement(query1);
					stmt1.setString(1, product_cd);
					stmt1.setString(2, molecule_cd);
					stmt1.setString(3, molecule_nm);
					stmt1.setString(4, molecule_abbr);
					stmt1.setString(5, desc);
					stmt1.setString(6, status_flag);
					stmt1.setString(7, emp_cd);
					stmt1.setString(8, comp_cd);
					stmt1.executeUpdate();
					
					stmt1.close();
				}
				
				msg = "Successful! - "+molecule_nm+" Product Molecule Added!";
				msg_type="S";
			}	
			
			url = "../master/frm_product_molecule_mst.jsp?&msg="+msg+"&msg_type="+msg_type+"&opration="+opration+commonUrl_pra;
			
			dbcon.commit();
		}
		catch(Exception e)
		{
			dbcon.rollback();
			new SystemErrorLogger().InsertErrorLogger(db_src_file_name, function_nm, e);
			url=CommonVariable.errorpage_url+"?e="+e;
			msg = "Error in Exception! - Product Molecule Master Insert/Update Failed!";
			
