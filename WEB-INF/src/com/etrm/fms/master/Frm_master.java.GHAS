	private void InsertUpdateShipMaster(HttpServletRequest request) throws SQLException 
	{
		String function_nm="InsertUpdateShipMaster()";
		msg="";
		msg_type="";
		url="";
		
		HttpSession session = request.getSession();
		String emp_cd = (String)session.getAttribute("emp_cd")==null?"":(String)session.getAttribute("emp_cd");
		String comp_cd = (String)session.getAttribute("comp_cd")==null?"":(String)session.getAttribute("comp_cd");
		
		try
		{
			String opration=request.getParameter("opration")==null?"":request.getParameter("opration");
			
			String ship_cd=request.getParameter("ship_cd")==null?"":request.getParameter("ship_cd");
			String ship_nm=request.getParameter("ship_nm")==null?"":request.getParameter("ship_nm");
			String ship_call_sign=request.getParameter("ship_call_sign")==null?"":request.getParameter("ship_call_sign");
			String imo_no=request.getParameter("imo_no")==null?"":request.getParameter("imo_no");
			String ship_flag=request.getParameter("ship_flag")==null?"Y":request.getParameter("ship_flag");
			String class_soc=request.getParameter("class_soc")==null?"":request.getParameter("class_soc");
			String inmarsat_no=request.getParameter("inmarsat_no")==null?"":request.getParameter("inmarsat_no");
			String vessel_owner=request.getParameter("vessel_owner")==null?"":request.getParameter("vessel_owner");
			String vessel_operator=request.getParameter("vessel_operator")==null?"":request.getParameter("vessel_operator");
			String fax_no=request.getParameter("fax_no")==null?"":request.getParameter("fax_no");
			String telex_no=request.getParameter("telex_no")==null?"":request.getParameter("telex_no");
			String vessel_email=request.getParameter("vessel_email")==null?"":request.getParameter("vessel_email");
			String gross_tonnage=request.getParameter("gross_tonnage")==null?"":request.getParameter("gross_tonnage");
			String approx_cargo_cap=request.getParameter("approx_cargo_cap")==null?"":request.getParameter("approx_cargo_cap");
			String app_cargo_capecity_unit=request.getParameter("app_cargo_capecity_unit")==null?"":request.getParameter("app_cargo_capecity_unit");
			String cap_per=request.getParameter("cap_per")==null?"":request.getParameter("cap_per");
			String items=request.getParameter("items").equals("")?"LNG":request.getParameter("items");
			String eff_dt=request.getParameter("eff_dt")==null?"":request.getParameter("eff_dt");
			
			if(opration.equals("MODIFY"))
			{
				if(!ship_cd.equals(""))
				{
					int count = 0;
					
					queryString = "SELECT COUNT(*) FROM FMS_SHIP_MST "
							+ "WHERE SHIP_CD=? AND EFF_DT=TO_DATE(?,'DD/MM/YYYY') ";
					stmt=dbcon.prepareStatement(queryString);
					stmt.setString(1, ship_cd);
					stmt.setString(2, eff_dt);
					rset = stmt.executeQuery();
			   		if(rset.next())
			   		{
			   			count = rset.getInt(1);
			   		}
			   		rset.close();
			   		stmt.close();
			   		
			   		if(count==0)
			   		{
			   			query1="INSERT INTO FMS_SHIP_MST(SHIP_CD,SHIP_NAME,SHIP_CALL_SIGN,SHIP_FLAG,"
								+ "SHIP_IMO_NO,SHIP_CLASS_SOC,INMARSAT_NO,SHIP_OWNER_NAME,SHIP_OPERATOR_NAME,SHIP_FAX_NO,"
								+ "SHIP_TELEX_NO,SHIP_EMAIL,GROSS_TONNAGE,CARGO_CAPACITY,VOLUME_UNIT,PERCENTAGE_CAPACITY,SHIP_ITEM,"
								+ "ENT_BY,ENT_DT,EFF_DT,ENT_PROFILE) "
							+ "VALUES(?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,SYSDATE,TO_DATE(?,'DD/MM/YYYY'),?)";
						stmt1=dbcon.prepareStatement(query1);
						stmt1.setString(1, ship_cd);
						stmt1.setString(2, ship_nm);
						stmt1.setString(3, ship_call_sign);
						stmt1.setString(4, ship_flag);
						stmt1.setString(5, imo_no);
						stmt1.setString(6, class_soc);
						stmt1.setString(7, inmarsat_no);
						stmt1.setString(8, vessel_owner);
						stmt1.setString(9, vessel_operator);
						stmt1.setString(10, fax_no);
						stmt1.setString(11, telex_no);
						stmt1.setString(12, vessel_email);
						stmt1.setString(13, gross_tonnage);
						stmt1.setString(14, approx_cargo_cap);
						stmt1.setString(15, app_cargo_capecity_unit);
						stmt1.setString(16, cap_per);
						stmt1.setString(17, items);
						stmt1.setString(18, emp_cd);
						stmt1.setString(19, eff_dt);
						stmt1.setString(20, comp_cd);
						stmt1.executeUpdate();
						
						stmt1.close();
						
						msg = "Successful! - "+ship_nm+" Vessel Added!";
						msg_type="S";
			   		}
			   		else
			   		{
			   			query="UPDATE FMS_SHIP_MST SET SHIP_NAME=?, SHIP_CALL_SIGN=?, SHIP_FLAG=?,SHIP_IMO_NO=?,SHIP_CLASS_SOC=?, "
								+ "INMARSAT_NO=?,SHIP_OWNER_NAME=?,SHIP_OPERATOR_NAME=?,SHIP_FAX_NO=?,SHIP_TELEX_NO=?,SHIP_EMAIL=?,"
								+ "GROSS_TONNAGE=?,CARGO_CAPACITY=?,VOLUME_UNIT=?,PERCENTAGE_CAPACITY=?,SHIP_ITEM=?,MODIFY_DT=SYSDATE,"
								+ "MODIFY_BY=?,EFF_DT=TO_DATE(?,'DD/MM/YYYY'),MOD_PROFILE=? "
								+ "WHERE SHIP_CD=? AND EFF_DT=TO_DATE(?,'DD/MM/YYYY') ";
						stmt=dbcon.prepareStatement(query);
						stmt.setString(1, ship_nm);
						stmt.setString(2, ship_call_sign);
						stmt.setString(3, ship_flag);
						stmt.setString(4, imo_no);
						stmt.setString(5, class_soc);
						stmt.setString(6, inmarsat_no);
						stmt.setString(7, vessel_owner);
						stmt.setString(8, vessel_operator);
						stmt.setString(9, fax_no);
						stmt.setString(10, telex_no);
						stmt.setString(11, vessel_email);
						stmt.setString(12, gross_tonnage);
						stmt.setString(13, approx_cargo_cap);
						stmt.setString(14, app_cargo_capecity_unit);
						stmt.setString(15, cap_per);
						stmt.setString(16, items);
						stmt.setString(17, emp_cd);
						stmt.setString(18, eff_dt);
						stmt.setString(19, comp_cd);
						stmt.setString(20, ship_cd);
						stmt.setString(21, eff_dt);
						stmt.executeUpdate();
						
						stmt.close();
						
						msg = "Successful! - "+ship_nm+" Vessel updated!";
						msg_type="S";
			   		}
				}
				else
				{
					msg = "Failed! - Data Modification for "+ship_nm+" Failed!";
					msg_type="E";
				}
			}
			else
			{
				ship_cd="1";
				
				query="SELECT NVL(MAX(SHIP_CD),0) "
						+ "FROM FMS_SHIP_MST ";
				stmt=dbcon.prepareStatement(query);
				rset=stmt.executeQuery();
				if(rset.next())
				{
					ship_cd=""+(rset.getInt(1)+1);
				}				
				rset.close();
				stmt.close();
				
				if(!ship_cd.equals(""))
				{
					query1="INSERT INTO FMS_SHIP_MST(SHIP_CD,SHIP_NAME,SHIP_CALL_SIGN,SHIP_FLAG,"
							+ "SHIP_IMO_NO,SHIP_CLASS_SOC,INMARSAT_NO,SHIP_OWNER_NAME,SHIP_OPERATOR_NAME,SHIP_FAX_NO,"
							+ "SHIP_TELEX_NO,SHIP_EMAIL,GROSS_TONNAGE,CARGO_CAPACITY,VOLUME_UNIT,PERCENTAGE_CAPACITY,SHIP_ITEM,"
							+ "ENT_BY,ENT_DT,EFF_DT,ENT_PROFILE) "
						+ "VALUES(?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,SYSDATE,TO_DATE(?,'DD/MM/YYYY'),?)";
					stmt1=dbcon.prepareStatement(query1);
					stmt1.setString(1, ship_cd);
					stmt1.setString(2, ship_nm);
					stmt1.setString(3, ship_call_sign);
					stmt1.setString(4, ship_flag);
					stmt1.setString(5, imo_no);
					stmt1.setString(6, class_soc);
					stmt1.setString(7, inmarsat_no);
					stmt1.setString(8, vessel_owner);
					stmt1.setString(9, vessel_operator);
					stmt1.setString(10, fax_no);
					stmt1.setString(11, telex_no);
					stmt1.setString(12, vessel_email);
					stmt1.setString(13, gross_tonnage);
					stmt1.setString(14, approx_cargo_cap);
					stmt1.setString(15, app_cargo_capecity_unit);
					stmt1.setString(16, cap_per);
					stmt1.setString(17, items);
					stmt1.setString(18, emp_cd);
					stmt1.setString(19, eff_dt);
					stmt1.setString(20, comp_cd);
					stmt1.executeUpdate();
					
					stmt1.close();
				}
				
				msg = "Successful! - "+ship_nm+" Vessel Added!";
				msg_type="S";
			}	
			
			url = "../master/frm_vessel_ship_mst.jsp?ship_cd="+ship_cd+"&msg="+msg+"&msg_type="+msg_type+"&opration="+opration+commonUrl_pra;
			
			dbcon.commit();
		}
		catch(Exception e)
		{
			dbcon.rollback();
			new SystemErrorLogger().InsertErrorLogger(db_src_file_name, function_nm, e);
			url=CommonVariable.errorpage_url+"?e="+e;
			msg = "Error in Exception! - Vessel Master Insert/Update Failed!";

		}
		
		try
		{
			new com.etrm.fms.util.InfoLogger().InsertInfoLogger(emp_cd, comp_cd,(String)session.getAttribute("emp_nm"), (String)session.getAttribute("ip"), form_id, form_nm,mod_cd,mod_nm, old_value, new_value, msg);  	
