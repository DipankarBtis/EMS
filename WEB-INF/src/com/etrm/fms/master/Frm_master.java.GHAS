					stmt.setString(3, bank_branch);
					stmt.setString(4, eff_dt);
					stmt.setString(5, bank_addr);
					stmt.setString(6, bank_city);
					stmt.setString(7, bank_pin);
					stmt.setString(8, state_cd);
					stmt.setString(9, country_cd);
					stmt.setString(10, bank_phone);
					stmt.setString(11, bank_mobile);
					stmt.setString(12, bank_alt_phone);
					stmt.setString(13, fax1);
					stmt.setString(14, fax2);
					stmt.setString(15, bank_email);
					stmt.setString(16, remarks);
					stmt.setString(17, bank_ifsc_code);
					stmt.setString(18, status_flag);
					stmt.setString(19, comp_cd);
					stmt.setString(20, bank_cd);
					stmt.executeUpdate();
					
					stmt.close();
					
					msg = "Successful! - "+bank_nm+" updated!";
					msg_type="S";
				}
				else
				{
					msg = "Failed! - Data Modification for "+bank_nm+" Failed!";
					msg_type="E";
				}
			}
			else
			{
				bank_cd="1001";
