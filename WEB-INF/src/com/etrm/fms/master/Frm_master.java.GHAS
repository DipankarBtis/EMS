		}
		catch(Exception infoLogger)
		{
			new SystemErrorLogger().InsertErrorLogger(db_src_file_name, function_nm, infoLogger);
		}
	}
	
	private void InsertUpdateSACMaster(HttpServletRequest request) throws SQLException
	{
		String function_nm="InsertUpdateSACMaster()";
		msg="";
		msg_type="";
		url="";
		String opration ="";
		HttpSession session = request.getSession();
		String emp_cd = (String)session.getAttribute("emp_cd")==null?"":(String)session.getAttribute("emp_cd");
		String comp_cd = (String)session.getAttribute("comp_cd")==null?"":(String)session.getAttribute("comp_cd");
		try
		{
			String sac_cd = request.getParameter("sac_cd")==null?"":request.getParameter("sac_cd");
			String sac_code = request.getParameter("sac_code")==null?"":request.getParameter("sac_code");
			String sac_desc = request.getParameter("desc")==null?"":request.getParameter("desc");
			String sac_remark = request.getParameter("remark")==null?"":request.getParameter("remark");
			opration = request.getParameter("opration")==null?"":request.getParameter("opration");
			String status_flag = request.getParameter("status_flag")==null?"":request.getParameter("status_flag");
			
			if(opration.equals("MODIFY"))
			{
				if(!sac_cd.equals(""))
				{
					query="UPDATE FMS_SAC_MST SET SAC_CODE=?,SAC_DESC=?,REMARKS=?, "
							+ "MODIFY_DT=SYSDATE,MODIFY_BY=?,SAC_FLAG=?,MOD_PROFILE=?  "
							+ "WHERE SAC_CD=? ";
					stmt=dbcon.prepareStatement(query);
					stmt.setString(1, sac_code);
					stmt.setString(2, sac_desc);
					stmt.setString(3, sac_remark);
					stmt.setString(4, emp_cd);
					stmt.setString(5, status_flag);
					stmt.setString(6, comp_cd);
					stmt.setString(7, sac_cd);
					stmt.executeUpdate();
					
					stmt.close();
					
					msg = "Successful! "+sac_code+" - SAC Updated!";
					msg_type="S";
				}
				else
				{
					msg = "Failed! - Data Modification for "+sac_code+" Failed!";
					msg_type="E";
				}
			}
			else
			{
				queryString = "SELECT NVL(MAX(SAC_CD),0) FROM FMS_SAC_MST";
				stmt = dbcon.prepareStatement(queryString);
				rset = stmt.executeQuery();
				if(rset.next())
				{
					sac_cd = ""+(rset.getInt(1)+1);
				}
				rset.close();
				stmt.close();
				
				if(!sac_cd.equals(""))
				{
					query1 = "INSERT INTO FMS_SAC_MST"
							+ "(SAC_CD,SAC_CODE,SAC_DESC,REMARKS,SAC_FLAG,ENT_BY,ENT_DT,ENT_PROFILE) "
							+ "VALUES(?,?,?,?,?,?,SYSDATE,?)";
					stmt1=dbcon.prepareStatement(query1);
					stmt1.setString(1, sac_cd);
					stmt1.setString(2, sac_code);
					stmt1.setString(3, sac_desc);
					stmt1.setString(4, sac_remark);
					stmt1.setString(5, status_flag);
					stmt1.setString(6, emp_cd);
					stmt1.setString(7, comp_cd);
					stmt1.executeUpdate();
					
					stmt1.close();
				}
				msg = "Successful! - "+sac_code+" SAC Added!";
				msg_type="S";
			}
			
			url = "../master/frm_sac_mst.jsp?sac_cd="+sac_cd+"&msg="+msg+"&msg_type="+msg_type+"&opration="+opration+commonUrl_pra;
			dbcon.commit();
		}
		catch(Exception e)
		{
			dbcon.rollback();
			new SystemErrorLogger().InsertErrorLogger(db_src_file_name, function_nm, e);
			url=CommonVariable.errorpage_url+"?e="+e;
			msg = "Error in Exception! - SAC Master Insert/Update Failed!";
		}
		try
		{
			new com.etrm.fms.util.InfoLogger().InsertInfoLogger(emp_cd, comp_cd,(String)session.getAttribute("emp_nm"), (String)session.getAttribute("ip"), form_id, form_nm,mod_cd,mod_nm, old_value, new_value, msg);  	
		}
		catch(Exception infoLogger)
		{
			new SystemErrorLogger().InsertErrorLogger(db_src_file_name, function_nm, infoLogger);
		}
	}
	
