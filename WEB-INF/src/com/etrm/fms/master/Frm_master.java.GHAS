					stmt1.setString(3, product_abbr);
					stmt1.setString(4, desc);
					stmt1.setString(5, status_flag);
					stmt1.setString(6, emp_cd);
					stmt1.setString(7, comp_cd);
					stmt1.executeUpdate();
					
					stmt1.close();
				}
				
				msg = "Successful! - "+product_nm+" Product Added!";
				msg_type="S";
			}	
			
			url = "../master/frm_product_mst.jsp?product_cd="+product_cd+"&msg="+msg+"&msg_type="+msg_type+"&opration="+opration+commonUrl_pra;
			
			dbcon.commit();
		}
		catch(Exception e)
		{
